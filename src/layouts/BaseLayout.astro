---
import BaseHead from '@components/layout/BaseHead.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import GlassFilter from '@components/ui/GlassFilter.astro';
import Preloader from '@components/ui/Preloader.astro';
import LeadCaptureModal from '@components/lead/LeadCaptureModal';
import SchemaBreadcrumbs from '@components/seo/SchemaBreadcrumbs.astro';
import SchemaOrganizationGraph from '@components/seo/SchemaOrganizationGraph.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import '@styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  showHeader?: boolean;
  showFooter?: boolean;
  showGlassFilter?: boolean;
  showPreloader?: boolean;
  showLeadCaptureModal?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType,
  noindex,
  showHeader = true,
  showFooter = true,
  showGlassFilter = true,
  showPreloader = true,
  showLeadCaptureModal = true,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <BaseHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />
    {!noindex && <SchemaOrganizationGraph />}
    {!noindex && <SchemaBreadcrumbs />}
    <slot name="head" />
  </head>
  <body>
    {showPreloader && <Preloader />}
    {showGlassFilter && <GlassFilter />}
    {showHeader && <Header />}
    <main id="main-content" class:list={[showHeader && 'pt-16']}>
      <slot />
    </main>
    {showFooter && <Footer />}
    {showLeadCaptureModal && <LeadCaptureModal client:load />}
    <Analytics />
    <SpeedInsights />
  </body>
</html>
