---
import { legalLogos } from '@data/legalLogos';

interface Props {
  label?: string;
  class?: string;
}

const {
  label = 'Escritorios de advocacia que ja confiaram na Scale',
  class: className = '',
} = Astro.props;

const logos = legalLogos;
const marqueeLogos = [...logos, ...logos, ...logos, ...logos];
---

<section class:list={['legal-logos-strip', className]} aria-label={label}>
  <p class="legal-logos-strip__label">{label}</p>
  <div class="legal-logos-strip__viewport">
    <div class="legal-logos-strip__track">
      {marqueeLogos.map((logo, index) => (
        <div class="legal-logos-strip__item" aria-hidden={index >= logos.length ? 'true' : undefined}>
          <img
            src={logo.src}
            alt={index >= logos.length ? '' : logo.alt}
            loading="lazy"
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .legal-logos-strip {
    position: relative;
    overflow: hidden;
    padding: 2.25rem 0 2.75rem;
    border-block: 1px solid rgba(255, 255, 255, 0.06);
    background:
      radial-gradient(circle at 50% 0%, rgba(0, 119, 255, 0.08), transparent 42%),
      #010000;
    color: #ffffff;
  }

  .legal-logos-strip__label {
    position: relative;
    z-index: 1;
    margin: 0 1.25rem 1.65rem;
    color: rgba(255, 255, 255, 0.34);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    line-height: 1.4;
    text-align: center;
    text-transform: uppercase;
  }

  .legal-logos-strip__viewport {
    overflow: hidden;
    -webkit-mask: linear-gradient(90deg, transparent 0%, #000 10%, #000 90%, transparent 100%);
    mask: linear-gradient(90deg, transparent 0%, #000 10%, #000 90%, transparent 100%);
  }

  .legal-logos-strip__track {
    display: flex;
    width: max-content;
    align-items: center;
    gap: clamp(2rem, 5vw, 4.5rem);
    animation: legalLogoMarquee 32s linear infinite;
    will-change: transform;
  }

  .legal-logos-strip__item {
    display: flex;
    width: clamp(8.5rem, 14vw, 12rem);
    height: 4.5rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
  }

  .legal-logos-strip__item img {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: 3.2rem;
    object-fit: contain;
    opacity: 0.78;
    filter: brightness(0) invert(1) grayscale(1);
    transition: opacity 180ms ease, filter 180ms ease, transform 180ms ease;
  }

  .legal-logos-strip__item:hover img {
    opacity: 1;
    filter: brightness(0) invert(1) grayscale(1);
    transform: translateY(-1px);
  }

  @keyframes legalLogoMarquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .legal-logos-strip {
      padding: 1.9rem 0 2.2rem;
    }

    .legal-logos-strip__item {
      width: 8rem;
      height: 3.75rem;
    }

    .legal-logos-strip__item img {
      max-height: 2.65rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .legal-logos-strip__track {
      animation: none;
    }
  }
</style>
