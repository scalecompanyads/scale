---
import { services } from '@data/services';
import { 
  TrendingUp, 
  Search, 
  Share2, 
  Zap, 
  ArrowRight
} from 'lucide-react';

const serviceIcons = {
  'trafego-pago': TrendingUp,
  'landing-pages': Zap,
  'seo': Search,
  'redes-sociais': Share2,
};

const items = services; 
const totalSteps = items.length;
---

<section 
  id="servicos" 
  class="relative h-[100vh] bg-[#010f1c] overflow-hidden"
  data-total-steps={totalSteps}
>
  <!-- Background Grid Fine Lines -->
  <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 120px 120px;"></div>

  <div class="container mx-auto h-full flex flex-col md:flex-row relative z-10 px-6 md:px-12">
    
    <!-- NAVIGATION COLUMN (LEFT) -->
    <div class="srv-nav w-full md:w-48 flex md:flex-col items-center justify-center md:justify-center pt-[60px] pb-2 md:py-0 relative z-10">
      
      <!-- DESKTOP PROGRESS LINE -->
      <div 
        id="srv-nav-wrap-desktop"
        class="hidden md:flex flex-col relative"
      >
        <div id="srv-line-container-v" class="absolute left-[-2.5rem] top-0 bottom-0 w-[1.5px] pointer-events-none">
           <div class="absolute inset-x-0 top-0 bottom-0 bg-white/[0.05]"></div>
           <div 
              id="srv-fill-v" 
              class="absolute inset-x-0 top-0 bottom-0 bg-gradient-to-b from-[#00BAFF] via-[#00BAFF] to-[#1630DF] origin-top scale-y-0"
           >
              <div class="absolute bottom-0 left-[-4px] w-[10px] h-[10px] bg-[#00BAFF] blur-[4px] rounded-full"></div>
           </div>
        </div>

        <div class="flex flex-col gap-10 lg:gap-12">
          {items.map((_, i) => (
            <div 
              class="srv-num-desktop text-4xl lg:text-5xl font-light font-heading cursor-default tracking-tighter text-white opacity-20"
              data-num-idx={i}
            >
              0{i + 1}
            </div>
          ))}
        </div>
      </div>

      <!-- MOBILE NAVIGATION - Adjusted for better spacing and line width -->
      <div id="srv-nav-wrap-mobile" class="md:hidden flex flex-col items-center w-full px-10">
        <div class="flex gap-8 mb-4 relative py-4 w-full justify-center">
          <!-- Mobile Base Line - matched to content width -->
          <div class="absolute bottom-0 left-0 right-0 h-[1px] bg-white/[0.05]"></div>
          <!-- Mobile Active Line - matched to content width -->
          <div 
            id="srv-fill-h" 
            class="absolute bottom-0 left-0 right-0 h-[1.5px] bg-[#00BAFF] origin-left scale-x-0"
          ></div>
          
          {items.map((_, i) => (
            <div 
              class="srv-num-mobile text-xl font-bold font-heading text-white opacity-20"
              data-num-idx={i}
            >
              0{i + 1}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- MAIN CONTENT STAGE (RIGHT) - justify-start on mobile to control gap -->
    <div class="srv-stage flex-1 relative z-20 flex items-start md:items-center justify-center p-0 md:p-12 lg:p-24 overflow-visible pt-12 md:pt-12">
      
      {items.map((service, i) => {
        const Icon = serviceIcons[service.id] || Zap;
        return (
          <div 
            class="srv-content absolute inset-0 flex flex-col md:flex-row items-center md:items-center justify-start md:justify-center gap-6 md:gap-16 lg:gap-24 text-center md:text-left opacity-0 translate-y-8 invisible pointer-events-none pt-20 md:pt-0"
            data-content-idx={i}
          >
            <!-- TECH GRADIENT ICONS -->
              <div class="srv-icon-wrap relative shrink-0 scale-90 md:scale-95 opacity-0" data-icon-idx={i}>
              <!-- Large Ambient Glow (único halo suave por slide) -->
              <div class="absolute inset-[-50px] bg-gradient-to-br from-[#00BAFF]/8 to-[#1630DF]/8 blur-[40px] rounded-full"></div>
              
              <!-- Icon Layer - Shadow/Glow -->
              <Icon 
                className="w-32 h-32 md:w-56 md:h-56 lg:w-64 lg:h-64 text-[#00BAFF]/10 drop-shadow-[0_0_48px_rgba(0,186,255,0.2)]" 
                strokeWidth={0.5} 
                aria-hidden="true" 
              />
              
              <!-- Icon Layer - Main Tech Gradient (SVG mask approach) -->
              <div class="absolute inset-0 flex items-center justify-center">
                <Icon 
                  className="w-32 h-32 md:w-56 md:h-56 lg:w-64 lg:h-64 transition-all duration-700" 
                  strokeWidth={0.8} 
                  style={{ stroke: 'url(#tech-gradient)', filter: 'drop-shadow(0 0 16px rgba(0,186,255,0.28))' }}
                  aria-hidden="true" 
                />
              </div>

              <!-- SVG Definition for the gradient (hidden) -->
              <svg width="0" height="0" class="absolute">
                <defs>
                  <linearGradient id="tech-gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#00BAFF" />
                    <stop offset="100%" stop-color="#1630DF" />
                  </linearGradient>
                </defs>
              </svg>
            </div>

            <!-- Text Content -->
            <div class="max-w-xl px-4">
              <h3 
                class="text-4xl md:text-5xl lg:text-6xl font-bold font-heading leading-[1.1] mb-4 md:mb-8 text-white tracking-tighter"
                style="background: linear-gradient(to bottom, #ffffff 60%, rgba(255,255,255,0.4) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
              >
                {service.name}
              </h3>
              
              <p class="text-base md:text-lg text-white/40 leading-[1.6] mb-6 md:mb-10 font-body max-w-md mx-auto md:mx-0">
                {service.description}
              </p>

              <a 
                href={`/servicos/${service.slug}`} 
                class="group pointer-events-auto inline-flex items-center gap-3 text-xs font-bold uppercase tracking-[0.25em] text-[#00BAFF]"
              >
                <span class="relative">
                   Saiba mais
                   <span class="absolute -bottom-1.5 left-0 w-0 h-[1.5px] bg-[#00BAFF]/60 transition-all duration-500 ease-out group-hover:w-full"></span>
                </span>
                <ArrowRight className="w-4 h-4 transition-transform duration-500 group-hover:translate-x-2" />
              </a>
            </div>
          </div>
        );
      })}

    </div>

  </div>
</section>

<style>
  .srv-num-desktop, .srv-num-mobile, .srv-content, .srv-icon-wrap, #srv-fill-v, #srv-fill-h {
    transition: none !important;
  }
  
  #srv-minimal-pinned::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 0%, #010f1c 90%);
    pointer-events: none;
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const initSrvFinalTweaksV2 = () => {
    const section = document.getElementById('servicos');
    if (!section) return;

    ScrollTrigger.getAll().forEach(t => {
      if (t.trigger === section || (t as any).vars?.trigger === "#servicos") {
        t.kill();
      }
    });

    const numsD = gsap.utils.toArray<HTMLElement>('.srv-num-desktop', section);
    const numsM = gsap.utils.toArray<HTMLElement>('.srv-num-mobile', section);
    const contents = gsap.utils.toArray<HTMLElement>('.srv-content', section);
    const icons = gsap.utils.toArray<HTMLElement>('.srv-icon-wrap', section);
    const fillV = section.querySelector('#srv-fill-v');
    const fillH = section.querySelector('#srv-fill-h');
    
    const totalCount = parseInt(section.dataset.totalSteps || "6");

    // Pinning with top offset to avoid header (80px header approx)
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 80px", // Pin when section is 80px from top
        end: "+=180%", // Slightly adjusted feel
        pin: true,
        scrub: 1,
        invalidateOnRefresh: true,
      }
    });

    // Initial State
    tl.set([numsD[0], numsM[0]], { opacity: 1 });
    tl.set(contents[0], { opacity: 1, y: 0, autoAlpha: 1, visibility: 'visible' });
    tl.set(icons[0], { scale: 1, opacity: 1 });

    for (let i = 1; i < totalCount; i++) {
      const prev = i - 1;
      tl.to(contents[prev], { opacity: 0, y: -20, autoAlpha: 0, duration: 0.5 }, i - 1);
      tl.to(icons[prev], { scale: 0.85, opacity: 0, duration: 0.5 }, i - 1);
      tl.to([numsD[prev], numsM[prev]], { opacity: 0.2, duration: 0.5 }, i - 1);

      tl.fromTo(contents[i], 
        { opacity: 0, y: 30, autoAlpha: 0, visibility: 'hidden' },
        { opacity: 1, y: 0, autoAlpha: 1, visibility: 'visible', duration: 0.5 }, 
        i - 0.5
      );
      tl.to([numsD[i], numsM[i]], { opacity: 1, duration: 0.5 }, i - 0.5);
      tl.fromTo(icons[i], 
        { scale: 0.9, opacity: 0 },
        { scale: 1, opacity: 1, duration: 0.5 }, 
        i - 0.5
      );
    }

    const masterDuration = totalCount - 1;
    if (fillV) tl.to(fillV, { scaleY: 1, duration: masterDuration, ease: "none" }, 0);
    if (fillH) tl.to(fillH, { scaleX: 1, duration: masterDuration, ease: "none" }, 0);
  };

  document.addEventListener('astro:page-load', initSrvFinalTweaksV2);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initSrvFinalTweaksV2();
  }
</script>
