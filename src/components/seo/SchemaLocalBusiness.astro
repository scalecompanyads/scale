---
import type { City } from '@data/cities';
import { brand, getLocalBusinessId, organizationId, websiteId } from '@data/seo';

interface Props {
  city: City;
}

const { city } = Astro.props;
const siteUrl = import.meta.env.SITE || brand.url;
const localUrl = new URL(`/${city.slug}`, siteUrl).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ProfessionalService'],
  '@id': getLocalBusinessId(city, siteUrl),
  name: `${brand.name} - ${city.name}`,
  legalName: brand.legalName,
  url: localUrl,
  telephone: brand.telephone,
  email: brand.email,
  logo: brand.logo,
  image: brand.image,
  priceRange: brand.priceRange,
  openingHours: brand.openingHours,
  parentOrganization: {
    '@id': organizationId,
  },
  isPartOf: {
    '@id': websiteId,
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: brand.address.streetAddress,
    addressLocality: city.id === 'espirito-santo' ? 'Vila Velha' : city.name,
    addressRegion: city.stateAbbr,
    postalCode: brand.address.postalCode,
    addressCountry: brand.address.addressCountry,
  },
  areaServed: [
    {
      '@type': city.id === 'espirito-santo' ? 'State' : 'City',
      name: city.name,
    },
    {
      '@type': 'State',
      name: city.state,
    },
  ],
  sameAs: brand.sameAs.length > 0 ? brand.sameAs : undefined,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
