---
import type { CollectionEntry } from 'astro:content';
import { brand, organizationId, websiteId } from '@data/seo';

interface Props {
  article: CollectionEntry<'blog'>;
}

const { article } = Astro.props;
const siteUrl = import.meta.env.SITE || brand.url;
const { title, description, publishDate, updatedDate, coverImage, tags } = article.data;
const coverSrc = coverImage?.src;

const articleUrl = new URL(`/blog/${article.slug}`, siteUrl).href;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${articleUrl}#article`,
  headline: title,
  description,
  url: articleUrl,
  mainEntityOfPage: articleUrl,
  isPartOf: {
    '@id': websiteId,
  },
  datePublished: publishDate.toISOString(),
  dateModified: (updatedDate ?? publishDate).toISOString(),
  image: coverSrc ? new URL(coverSrc, siteUrl).href : brand.image,
  keywords: tags,
  inLanguage: 'pt-BR',
  author: {
    '@id': organizationId,
  },
  publisher: {
    '@id': organizationId,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
