---
/**
 * BaseHead.astro — Meta tags, OG, canonical e JSON-LD base
 * Incluído em todos os layouts via BaseLayout.astro
 */
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  /** 'website' para páginas, 'article' para posts do blog */
  ogType?: 'website' | 'article';
  noindex?: boolean;
  includeFonts?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  noindex = false,
  includeFonts = true,
} = Astro.props;

const siteUrl = import.meta.env.SITE || 'https://www.scalecompany.com.br';
const resolvedCanonical = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage
  ? new URL(ogImage, siteUrl).href
  : new URL('/assets/brand/og-default.jpg', siteUrl).href;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<!-- SEO básico -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={resolvedCanonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type"        content={ogType} />
<meta property="og:url"         content={resolvedCanonical} />
<meta property="og:title"       content={title} />
<meta property="og:description" content={description} />
<meta property="og:image"       content={resolvedOgImage} />
<meta property="og:locale"      content="pt_BR" />
<meta property="og:site_name"   content="Scale" />

<!-- Twitter Card -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={resolvedOgImage} />

<!-- Favicon (substituir após receber identidade visual) -->
<link rel="icon" type="image/png" href="/images/favicon.png" />
<link rel="apple-touch-icon" href="/images/favicon.png" />

<!-- Fontes -->
{includeFonts && (
  <>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  </>
)}
