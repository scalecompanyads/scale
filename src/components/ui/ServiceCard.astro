---
import Badge from './Badge.astro';
import type { Service } from '@data/services';

interface Props {
  service: Service;
  showLink?: boolean;
}

const { service, showLink = true } = Astro.props;
---

<article class="bg-surface-card border border-edge border-t-4 border-t-brand-primary rounded-xl p-6 flex flex-col hover:-translate-y-0.5 transition-transform duration-200 shadow-sm hover:shadow-md">
  <span class="text-4xl mb-4 block" aria-hidden="true">{service.icon}</span>
  <h3 class="font-heading text-lg font-bold text-ink mb-2">{service.name}</h3>
  <div class="flex flex-1 flex-col min-h-0">
    <p class="text-sm text-ink-light leading-relaxed mb-3">{service.shortDesc}</p>
    {service.includes && service.includes.length > 0 && (
      <ul class="mb-3 space-y-1.5 text-xs text-ink-mid leading-snug border-t border-edge pt-3">
        {service.includes.map((line) => (
          <li class="flex gap-2">
            <span class="text-brand-primary shrink-0" aria-hidden="true">✓</span>
            <span>{line}</span>
          </li>
        ))}
      </ul>
    )}
  </div>
  <p class="font-mono text-xs text-brand-primary font-semibold mb-4">{service.volume}</p>

  <div class="flex flex-wrap gap-2 mb-4">
    {service.tags.map((tag) => <Badge variant="subtle">{tag}</Badge>)}
  </div>

  {showLink && (
    <a
      href={`/servicos/${service.slug}`}
      class="mt-auto inline-flex items-center gap-1 text-sm font-semibold text-brand-primary hover:text-brand-secondary transition-colors"
    >
      Saiba mais →
    </a>
  )}
</article>
