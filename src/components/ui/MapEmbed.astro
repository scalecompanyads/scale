---
interface Props {
  src?: string;
  title?: string;
  height?: number;
}

const {
  src = 'https://maps.google.com/maps?q=Estilo+Center+Av+Hugo+Musso+Sala+105+Praia+da+Costa+Vila+Velha+ES+29101-280&output=embed',
  title = 'Scale | Vila Velha, ES',
  height = 400,
} = Astro.props;
---

<div class="rounded-xl overflow-hidden border border-edge bg-surface-subtle">
  <iframe
    src={src}
    width="100%"
    height={height}
    style="border:0;"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title={title}
    class="block"
  ></iframe>
</div>
