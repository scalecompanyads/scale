  <div id="calculatorLeadModal" class="fixed inset-0 z-[420] hidden items-center justify-center bg-black/70 px-4 py-6 backdrop-blur-sm" role="dialog" aria-modal="true" aria-labelledby="calculatorLeadTitle" aria-hidden="true">
    <div class="relative max-h-[92dvh] w-full max-w-xl overflow-y-auto rounded-[12px] border border-white/[0.08] bg-[#010f1c] p-5 text-white shadow-2xl shadow-black/40 md:p-7">
      <button
        id="calculatorLeadClose"
        type="button"
        class="absolute right-4 top-4 flex h-9 w-9 items-center justify-center rounded-full border border-white/10 text-xl leading-none text-white/60 transition hover:border-white/25 hover:text-white"
