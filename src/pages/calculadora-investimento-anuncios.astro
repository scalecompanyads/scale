            <input id="calcLeadInstagram" name="instagram" type="text" autocomplete="off" class="block h-12 w-full rounded-[8px] border border-white/10 bg-white px-4 text-slate-950 outline-none transition placeholder:text-slate-400 focus:border-[#00BAFF]" placeholder="@suaempresa ou site.com.br" />
