---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCanonicalUrl, organizationId, websiteId } from '@data/seo';
import { ArrowRight, Calculator, CheckCircle2, LineChart, Target } from 'lucide-react';

const canonical = getCanonicalUrl('/calculadora-investimento-anuncios');
const leadWebhookUrl = ''; // import.meta.env.PUBLIC_LEAD_WEBHOOK_URL ?? '';
const excelWebhookUrl = ''; // import.meta.env.PUBLIC_EXCEL_WEBHOOK_URL ?? '';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${canonical}#calculator`,
  name: 'Calculadora de Captação para Advogados',
  url: canonical,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  description:
    'Ferramenta gratuita para estimar contatos qualificados, contratos fechados, honorários gerados e investimento em anúncios para advogados.',
  isPartOf: {
    '@id': websiteId,
  },
  provider: {
    '@id': organizationId,
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'BRL',
  },
};
---

<BaseLayout
  title="Calculadora de Captação para Advogados | Scale"
  description="Estime contatos qualificados, contratos fechados, honorários gerados e investimento em anúncios para escritórios de advocacia."
  canonical={canonical}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="relative -mt-16 overflow-hidden bg-[#010f1c] pt-32 pb-16 md:pt-40 md:pb-20">
    <div class="absolute inset-0 bg-[url('/images/calculadora-investimento-hero.png')] bg-cover bg-center opacity-75" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#010f1c] via-[#010f1c]/82 to-[#010f1c]/38" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#010f1c] via-transparent to-[#010f1c]/45" aria-hidden="true"></div>
    <div class="absolute inset-0 home-bg-grid opacity-45" aria-hidden="true"></div>
    <div class="container relative z-10">
      <div class="max-w-4xl">
        <span class="home-label-caps mb-5">Ferramenta gratuita</span>
        <h1 class="font-heading text-[clamp(2.6rem,5.8vw,5.4rem)] font-extrabold leading-[1] text-white">
          Calcule quantos clientes a advocacia pode gerar com anúncios.
        </h1>
        <p class="mt-7 max-w-3xl text-lg leading-relaxed text-white/62 md:text-xl">
          Em poucos passos, estime contatos qualificados, novos contratos, honorários projetados e o investimento necessário para sua área de atuação.
        </p>
        <p class="mt-4 max-w-3xl text-sm leading-relaxed text-white/46">
          Os resultados são estimativas baseadas nos dados informados. Eles servem para orientar decisões e não representam garantia de contratos, honorários ou retorno.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-10 light-section">
    <div class="container">
      <div class="space-y-6">
        <div class="mx-auto grid max-w-5xl grid-cols-1 gap-4 md:grid-cols-[1.3fr_0.7fr]">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#1630DF]">Diagnóstico rápido</p>
            <h2 class="mt-2 font-heading text-3xl font-bold leading-tight text-ink">Preencha como se estivesse planejando captação para o seu escritório.</h2>
            <p class="mt-3 text-sm leading-relaxed text-ink-light">
              A calculadora guia você por área jurídica, verba, custo por contato e honorários médios. No final, liberamos um dashboard com leitura do funil e próximos passos.
            </p>
          </div>
          <div class="rounded-[10px] border border-amber-200 bg-amber-50 p-5">
            <p class="text-sm font-bold text-amber-950">Importante</p>
            <p class="mt-2 text-sm leading-relaxed text-amber-900/75">
              Use dados próximos da sua realidade. Custo por contato, honorários e contratos variam conforme área, cidade, prova social, atendimento e regras éticas da OAB.
            </p>
          </div>
        </div>

        <div id="calculatorPanel" class="mx-auto max-w-5xl rounded-[10px] border border-edge bg-white p-5 shadow-xl shadow-blue-950/5 md:p-8">
          <div class="mb-7 flex items-center gap-3">
            <span class="flex h-11 w-11 items-center justify-center rounded-[8px] bg-blue-50 text-[#1630DF]">
              <Calculator size={24} strokeWidth={1.8} />
            </span>
            <div>
              <h2 class="font-heading text-2xl font-bold text-ink">Calculadora para advocacia</h2>
              <p class="text-sm text-ink-light">Estime contatos, contratos fechados e honorários gerados com tráfego pago.</p>
            </div>
          </div>

          <form id="ads-calculator" class="space-y-7">
            <input id="roas" type="hidden" value="3" />
            <input id="competitorFee" type="hidden" value="0" />
            <input id="ownFee" type="hidden" value="0" />

            <div class="grid grid-cols-2 gap-2 rounded-[10px] bg-slate-100 p-1 md:grid-cols-4">
              <button type="button" data-step-target="0" class="rounded-[8px] bg-white px-3 py-3 text-sm font-bold text-ink shadow-sm">1. Área</button>
              <button type="button" data-step-target="1" class="rounded-[8px] px-3 py-3 text-sm font-semibold text-ink-light">2. Captação</button>
              <button type="button" data-step-target="2" class="rounded-[8px] px-3 py-3 text-sm font-semibold text-ink-light">3. Honorários</button>
              <button type="button" data-step-target="3" class="rounded-[8px] px-3 py-3 text-sm font-semibold text-ink-light">4. Cenário</button>
            </div>

            <div data-step-panel="0" class="space-y-5">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#1630DF]">Etapa 1 de 4</p>
                <h3 class="mt-2 font-heading text-2xl font-bold text-ink">Qual área do direito você quer captar?</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-light">A área muda o custo do contato e o valor médio dos honorários. Use o padrão como ponto de partida e ajuste depois.</p>
              </div>
              <div>
                <label for="segment" class="mb-2 block text-sm font-bold text-ink">Área de atuação</label>
                <select id="segment" class="w-full rounded-[8px] border border-slate-300 bg-white px-4 py-3 text-ink outline-none transition focus:border-[#1630DF]">
                  <option value="familia" data-cpl="45" data-ticket="3500" data-contracts="4">Família e sucessões</option>
                  <option value="trabalhista" data-cpl="35" data-ticket="3000" data-contracts="5">Trabalhista</option>
                  <option value="previdenciario" data-cpl="32" data-ticket="2500" data-contracts="6">Previdenciário</option>
                  <option value="criminal" data-cpl="70" data-ticket="6000" data-contracts="3">Criminal</option>
                  <option value="empresarial" data-cpl="90" data-ticket="8500" data-contracts="2">Empresarial</option>
                  <option value="imobiliario" data-cpl="60" data-ticket="5500" data-contracts="3">Imobiliário</option>
                  <option value="tributario" data-cpl="110" data-ticket="10000" data-contracts="2">Tributário</option>
                </select>
              </div>
              <div class="rounded-[10px] border border-sky-200 bg-sky-50 p-5">
                <p class="text-sm font-bold text-ink">Dica</p>
                <p class="mt-2 text-sm leading-relaxed text-ink-light">Escolha a área que você quer escalar agora, não necessariamente a maior área do escritório. A projeção fica mais útil quando foca em uma oferta.</p>
              </div>
            </div>

            <div data-step-panel="1" class="hidden space-y-5">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#1630DF]">Etapa 2 de 4</p>
                <h3 class="mt-2 font-heading text-2xl font-bold text-ink">Quanto você quer investir em captação?</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-light">Aqui estimamos quantos contatos qualificados a verba pode gerar e quantos contratos podem sair desse volume.</p>
              </div>
              <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div>
                  <label for="investment" class="mb-2 flex min-h-10 items-end text-sm font-bold leading-tight text-ink">Verba mensal em anúncios (R$)</label>
                  <input id="investment" inputmode="decimal" type="number" min="0" value="3000" class="h-12 w-full rounded-[8px] border border-slate-300 bg-white px-4 text-ink outline-none transition focus:border-[#1630DF]" />
                  <p class="mt-2 text-xs text-ink-light">Exemplo: R$ 3.000 por mês em Google ou Meta Ads.</p>
                </div>
                <div>
                  <label for="cpl" class="mb-2 flex min-h-10 items-end text-sm font-bold leading-tight text-ink">Custo por contato qualificado (R$)</label>
                  <input id="cpl" readonly inputmode="decimal" type="number" min="1" value="45" class="h-12 w-full rounded-[8px] border border-slate-200 bg-slate-50 px-4 text-ink/70 outline-none transition cursor-not-allowed" title="Valor estimado automaticamente com base na área" />
                  <p class="mt-2 text-xs text-ink-light">Estimativa fixa baseada na área de atuação e no cenário escolhido.</p>
                </div>
                <div>
                  <label for="contracts" class="mb-2 flex min-h-10 items-end text-sm font-bold leading-tight text-ink">Contratos fechados por mês</label>
                  <input id="contracts" inputmode="decimal" type="number" min="0" step="0.1" value="4" class="h-12 w-full rounded-[8px] border border-slate-300 bg-white px-4 text-ink outline-none transition focus:border-[#1630DF]" />
                  <p class="mt-2 text-xs text-ink-light">Exemplo: 4 contratos fechados a partir dos contatos do mês.</p>
                </div>
              </div>
            </div>

            <div data-step-panel="2" class="hidden space-y-5">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#1630DF]">Etapa 3 de 4</p>
                <h3 class="mt-2 font-heading text-2xl font-bold text-ink">Quanto esses contratos geram em honorários?</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-light">Use o valor médio dos honorários iniciais ou do contrato fechado. Se houver parcelamento, use o valor total contratado.</p>
              </div>
              <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <div>
                  <label for="ticket" class="mb-2 flex min-h-10 items-end text-sm font-bold leading-tight text-ink">Honorários por contrato (R$)</label>
                  <input id="ticket" inputmode="decimal" type="number" min="1" value="3500" class="h-12 w-full rounded-[8px] border border-slate-300 bg-white px-4 text-ink outline-none transition focus:border-[#1630DF]" />
                  <p class="mt-2 text-xs text-ink-light">Exemplo: R$ 3.500 de honorários médios por cliente.</p>
                </div>
                <div>
                  <label for="goal" class="mb-2 flex min-h-10 items-end text-sm font-bold leading-tight text-ink">Meta de honorários no mês (R$)</label>
                  <input id="goal" inputmode="decimal" type="number" min="0" value="50000" class="h-12 w-full rounded-[8px] border border-slate-300 bg-white px-4 text-ink outline-none transition focus:border-[#1630DF]" />
                  <p class="mt-2 text-xs text-ink-light">Quanto você quer gerar em novos contratos por mês.</p>
                </div>
                <div>
                  <label for="months" class="mb-2 flex min-h-10 items-end text-sm font-bold leading-tight text-ink">Meses de projeção</label>
                  <input id="months" inputmode="numeric" type="number" min="1" max="36" value="6" class="h-12 w-full rounded-[8px] border border-slate-300 bg-white px-4 text-ink outline-none transition focus:border-[#1630DF]" />
                  <p class="mt-2 text-xs text-ink-light">Opcional: para estimar honorários acumulados.</p>
                </div>
              </div>
            </div>

            <div data-step-panel="3" class="hidden space-y-5">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#1630DF]">Etapa 4 de 4</p>
                <h3 class="mt-2 font-heading text-2xl font-bold text-ink">Escolha o cenário da projeção</h3>
                <p class="mt-2 text-sm leading-relaxed text-ink-light">Cenários ajudam a enxergar risco: o pessimista encarece o contato e reduz contratos; o otimista melhora eficiência.</p>
              </div>
              <div class="rounded-[10px] border border-edge bg-white p-5">
                <div class="grid grid-cols-3 gap-2 rounded-full bg-slate-100 p-1">
                  <button type="button" data-scenario-button="pessimista" class="rounded-full px-3 py-3 text-sm font-semibold text-ink-light transition hover:text-ink">Pessimista</button>
                  <button type="button" data-scenario-button="realista" class="rounded-full bg-gradient-to-r from-[#1630DF] to-[#00BAFF] px-3 py-3 text-sm font-bold text-white shadow-sm">Realista</button>
                  <button type="button" data-scenario-button="otimista" class="rounded-full px-3 py-3 text-sm font-semibold text-ink-light transition hover:text-ink">Otimista</button>
                </div>
                <div class="mt-5 inline-grid grid-cols-2 gap-1 rounded-full bg-slate-100 p-1">
                  <button type="button" data-period-button="mensal" class="rounded-full bg-[#00BAFF] px-4 py-2 text-sm font-bold text-white">Mensal</button>
                  <button type="button" data-period-button="diario" class="rounded-full px-4 py-2 text-sm font-semibold text-ink-light transition hover:text-ink">Diário</button>
                </div>
              </div>
              <div class="rounded-[10px] border border-amber-200 bg-amber-50 p-5">
                <p class="text-sm font-bold text-amber-950">Antes de calcular</p>
                <p class="mt-2 text-sm leading-relaxed text-amber-900/75">A projeção é estimativa. Ela não considera todos os fatores de fechamento, como atendimento, reputação, urgência do caso, localização e limites éticos da publicidade jurídica.</p>
              </div>
            </div>

            <div class="flex flex-col-reverse gap-3 border-t border-edge pt-6 sm:flex-row sm:items-center sm:justify-between">
              <button
                id="calculatorStepBack"
                type="button"
                class="inline-flex w-full items-center justify-center rounded-lg border border-slate-200 bg-white px-6 py-3 text-sm font-bold text-ink transition hover:border-[#1630DF]/30 sm:w-auto"
              >
                Voltar
              </button>
              <div class="flex w-full flex-col gap-3 sm:w-auto sm:flex-row">
                <button
                  id="calculatorStepNext"
                  type="button"
                  class="inline-flex w-full items-center justify-center gap-2 rounded-lg border border-[#00BAFF]/30 bg-gradient-to-r from-[#1630DF] to-[#00BAFF] px-8 py-3 text-sm font-bold text-white shadow-lg shadow-sky-950/20 transition hover:opacity-90 sm:w-auto"
                >
                  Próximo
                  <ArrowRight size={16} strokeWidth={2.4} />
                </button>
                <button
                  id="calculatorSubmit"
                  type="submit"
                  class="hidden w-full items-center justify-center gap-2 rounded-lg border border-[#00BAFF]/30 bg-gradient-to-r from-[#1630DF] to-[#00BAFF] px-8 py-3 text-sm font-bold text-white shadow-lg shadow-sky-950/20 transition hover:opacity-90 sm:w-auto"
                >
                  Calcular projeção
                  <ArrowRight size={16} strokeWidth={2.4} />
                </button>
              </div>
            </div>
          </form>
        </div>

        <aside
          id="calculator-result-card"
          data-webhook-url={leadWebhookUrl}
          data-excel-webhook-url={excelWebhookUrl}
          class="relative mx-auto hidden max-w-6xl overflow-hidden rounded-[10px] border border-white/[0.08] bg-[#010f1c] p-5 text-white shadow-xl shadow-blue-950/15 md:p-8"
        >
          <div id="resultPlaceholder" class="flex min-h-[540px] flex-col items-center justify-center rounded-[10px] border border-dashed border-white/15 bg-white/[0.025] p-8 text-center">
            <span class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-white/[0.06] text-[#00BAFF]">
              <LineChart size={30} strokeWidth={1.6} />
            </span>
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#00BAFF]">Dashboard bloqueado</p>
            <h2 class="mt-3 font-heading text-3xl font-bold leading-tight text-white">
              Sua projeção aparece aqui depois do cálculo.
            </h2>
            <p class="mt-4 max-w-md text-sm leading-relaxed text-white/52">
              Preencha os dados ao lado e clique em calcular para liberar seu dashboard personalizado.
            </p>
          </div>

          <div id="resultContent" class="hidden" aria-hidden="true">
            <div class="mb-7 flex items-start justify-between gap-5">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.22em] text-[#00BAFF]">Dashboard de projeção</p>
                <h2 class="mt-2 font-heading text-3xl font-bold leading-tight text-white">Resultado da sua simulação</h2>
              </div>
              <span id="resultRoasBadge" class="shrink-0 rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 text-xs font-bold text-emerald-300">
                ROAS 3.0x
              </span>
            </div>

            <div class="rounded-[10px] border border-[#00BAFF]/20 bg-gradient-to-br from-[#00BAFF]/14 to-white/[0.035] p-6">
              <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between">
                <div>
                  <p id="resultRevenueLabel" class="text-sm font-semibold text-white/48">Honorários gerados no mês</p>
                  <p id="resultRevenue" class="mt-2 font-heading text-[clamp(2.5rem,6vw,4.6rem)] font-extrabold leading-none text-white">R$ 9.000</p>
                </div>
                <div class="grid min-w-[230px] gap-3">
                  <div class="rounded-[8px] border border-white/[0.08] bg-[#010f1c]/55 px-4 py-3">
                    <p class="text-xs font-bold uppercase tracking-[0.16em] text-white/35">ROAS atual</p>
                    <p id="resultActualRoas" class="mt-1 text-2xl font-bold text-white">3.0x</p>
                    <p id="resultMarketDiff" class="mt-1 text-xs font-semibold text-emerald-300">Dentro da meta</p>
                  </div>
                  <div class="rounded-[8px] border border-white/[0.08] bg-[#010f1c]/55 px-4 py-3">
                    <p class="text-xs font-bold uppercase tracking-[0.16em] text-white/35">Meta mensal</p>
                    <p id="resultGoalProgressText" class="mt-1 text-sm font-semibold text-white">18% da meta</p>
                  </div>
                </div>
              </div>
              <div class="mt-6 h-3 overflow-hidden rounded-full bg-white/[0.08]">
                <div id="resultGoalProgressBar" class="h-full rounded-full bg-gradient-to-r from-[#1630DF] to-[#00BAFF]" style="width: 18%"></div>
              </div>
            </div>

            <div class="mt-4 grid grid-cols-2 gap-3">
              <div class="rounded-[8px] border border-white/[0.08] bg-white/[0.04] p-5">
                <p class="text-sm text-white/45">Contatos qualificados</p>
                <p id="resultLeads" class="mt-2 font-heading text-3xl font-bold text-white">67</p>
                <p id="resultLeadCost" class="mt-1 text-xs text-white/35">Custo por contato</p>
              </div>
              <div class="rounded-[8px] border border-white/[0.08] bg-white/[0.04] p-5">
                <p class="text-sm text-white/45">Contratos fechados</p>
                <p id="resultSales" class="mt-2 font-heading text-3xl font-bold text-white">5</p>
                <p id="resultConversionText" class="mt-1 text-xs text-white/35">Conversão estimada</p>
              </div>
              <div class="rounded-[8px] border border-white/[0.08] bg-white/[0.04] p-5">
                <p class="text-sm text-white/45">Custo por contrato</p>
                <p id="resultCac" class="mt-2 font-heading text-3xl font-bold text-white">R$ 600</p>
                <p class="mt-1 text-xs text-white/35">CPA médio</p>
              </div>
              <div class="rounded-[8px] border border-white/[0.08] bg-white/[0.04] p-5">
                <p class="text-sm text-white/45">Investimento para meta</p>
                <p id="resultRequired" class="mt-2 font-heading text-3xl font-bold text-white">R$ 16.667</p>
                <p class="mt-1 text-xs text-white/35">Verba estimada em anúncios</p>
              </div>
            </div>

            <div class="mt-4 grid grid-cols-1 gap-4 lg:grid-cols-2">
              <div class="rounded-[10px] border border-white/[0.08] bg-white/[0.035] p-5">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#00BAFF]">Análise financeira</p>
                <div class="mt-4 grid grid-cols-2 gap-3">
                  <div class="rounded-[8px] bg-white/[0.04] p-4">
                    <p id="resultInvestmentLabel" class="text-xs text-white/38">Investimento</p>
                    <p id="resultInvestment" class="mt-1 text-xl font-bold text-white">R$ 3.000/mês</p>
                  </div>
                  <div class="rounded-[8px] bg-white/[0.04] p-4">
                    <p class="text-xs text-white/38">ROI (retorno líquido)</p>
                    <p id="resultRoi" class="mt-1 text-xl font-bold text-white">200%</p>
                  </div>
                </div>
              </div>

              <div class="rounded-[10px] border border-[#00BAFF]/20 bg-[#00BAFF]/10 p-5">
                <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#00BAFF]">Sugestão de investimento</p>
                <p id="resultSuggestionText" class="mt-3 text-sm leading-relaxed text-white/62">
                  Para atingir sua meta, recomendamos ajustar a verba mensal.
                </p>
                <p id="resultSuggestionValue" class="mt-3 font-heading text-3xl font-bold text-white">R$ 16.667</p>
                <p id="resultSuggestionPeriod" class="mt-1 text-xs text-white/38">por mês</p>
              </div>
            </div>

            <div class="mt-4 rounded-[10px] border border-white/[0.08] bg-white/[0.035] p-5">
              <div class="mb-5 flex items-center justify-between gap-4">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.18em] text-[#00BAFF]">Funil projetado</p>
                  <h3 class="mt-1 font-heading text-xl font-bold text-white">Da verba até os honorários</h3>
                </div>
                <LineChart className="h-7 w-7 text-[#00BAFF]" strokeWidth={1.6} />
              </div>

              <div class="space-y-4">
                <div>
                  <div class="mb-1 flex justify-between gap-3 text-xs font-semibold text-white/55">
                    <span>Mídia investida</span>
                    <span id="funnelInvestment">R$ 3.000</span>
                  </div>
                  <div class="h-2 rounded-full bg-white/[0.08]">
                    <div class="h-full w-full rounded-full bg-white/35"></div>
                  </div>
                </div>
                <div>
                  <div class="mb-1 flex justify-between gap-3 text-xs font-semibold text-white/55">
                    <span>Contatos qualificados</span>
                    <span id="funnelLeads">67 contatos</span>
                  </div>
                  <div class="h-2 rounded-full bg-white/[0.08]">
                    <div id="funnelLeadBar" class="h-full rounded-full bg-[#00BAFF]" style="width: 64%"></div>
                  </div>
                </div>
                <div>
                  <div class="mb-1 flex justify-between gap-3 text-xs font-semibold text-white/55">
                    <span>Contratos fechados</span>
                    <span id="funnelSales">5 contratos</span>
                  </div>
