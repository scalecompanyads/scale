              <p class="mt-3 text-sm leading-relaxed text-ink-light">{item.desc}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById('ads-calculator');
      if (!form) return;
      const calculatorPanel = document.getElementById('calculatorPanel');
      const resultCard = document.getElementById('calculator-result-card');
      const leadModal = document.getElementById('calculatorLeadModal');
      const leadClose = document.getElementById('calculatorLeadClose');
      const leadForm = document.getElementById('calculator-lead-form');
      const resultContent = document.getElementById('resultContent');
      const resultPlaceholder = document.getElementById('resultPlaceholder');
      const leadError = document.getElementById('calculatorLeadError');
      const newCalculationButton = document.getElementById('startNewCalculation');
      const stepPanels = Array.from(document.querySelectorAll('[data-step-panel]'));
      const stepButtons = Array.from(document.querySelectorAll('[data-step-target]'));
      const stepBackButton = document.getElementById('calculatorStepBack');
      const stepNextButton = document.getElementById('calculatorStepNext');
      const submitCalculationButton = document.getElementById('calculatorSubmit');

      const fields = {
        segment: document.getElementById('segment'),
        investment: document.getElementById('investment'),
        roas: document.getElementById('roas'),
        cpl: document.getElementById('cpl'),
        ticket: document.getElementById('ticket'),
        contracts: document.getElementById('contracts'),
        competitorFee: document.getElementById('competitorFee'),
        ownFee: document.getElementById('ownFee'),
        goal: document.getElementById('goal'),
        months: document.getElementById('months'),
      };

      const outputs = {
        revenueLabel: document.getElementById('resultRevenueLabel'),
        revenue: document.getElementById('resultRevenue'),
        roasBadge: document.getElementById('resultRoasBadge'),
        actualRoas: document.getElementById('resultActualRoas'),
        marketDiff: document.getElementById('resultMarketDiff'),
        goalProgressText: document.getElementById('resultGoalProgressText'),
        goalProgressBar: document.getElementById('resultGoalProgressBar'),
        leads: document.getElementById('resultLeads'),
        leadCost: document.getElementById('resultLeadCost'),
        sales: document.getElementById('resultSales'),
        conversionText: document.getElementById('resultConversionText'),
        cac: document.getElementById('resultCac'),
        required: document.getElementById('resultRequired'),
        investmentLabel: document.getElementById('resultInvestmentLabel'),
        investment: document.getElementById('resultInvestment'),
        roi: document.getElementById('resultRoi'),
        suggestionText: document.getElementById('resultSuggestionText'),
        suggestionValue: document.getElementById('resultSuggestionValue'),
        suggestionPeriod: document.getElementById('resultSuggestionPeriod'),
        projection: document.getElementById('resultProjection'),
        funnelInvestment: document.getElementById('funnelInvestment'),
        funnelLeads: document.getElementById('funnelLeads'),
        funnelSales: document.getElementById('funnelSales'),
        funnelRevenue: document.getElementById('funnelRevenue'),
        funnelLeadBar: document.getElementById('funnelLeadBar'),
        funnelSalesBar: document.getElementById('funnelSalesBar'),
        funnelRevenueBar: document.getElementById('funnelRevenueBar'),
        efficiency: document.getElementById('resultEfficiency'),
        commonAgencyRoi: document.getElementById('resultCommonAgencyRoi'),
        scaleAgencyRoi: document.getElementById('resultScaleAgencyRoi'),
        agencyDiff: document.getElementById('resultAgencyDiff'),
        scenarioPessimisticRoas: document.getElementById('scenarioPessimisticRoas'),
        scenarioPessimisticRevenue: document.getElementById('scenarioPessimisticRevenue'),
        scenarioPessimisticSales: document.getElementById('scenarioPessimisticSales'),
        scenarioRealisticRoas: document.getElementById('scenarioRealisticRoas'),
        scenarioRealisticRevenue: document.getElementById('scenarioRealisticRevenue'),
        scenarioRealisticSales: document.getElementById('scenarioRealisticSales'),
        scenarioOptimisticRoas: document.getElementById('scenarioOptimisticRoas'),
        scenarioOptimisticRevenue: document.getElementById('scenarioOptimisticRevenue'),
        scenarioOptimisticSales: document.getElementById('scenarioOptimisticSales'),
        diagnosticTitle: document.getElementById('diagnosticTitle'),
        diagnosticText: document.getElementById('diagnosticText'),
      };

      let latestResult = {};
      let resultsUnlocked = false;
      let activeScenario = 'realista';
      let activePeriod = 'mensal';
      let activeStep = 0;
      const scenarioButtons = Array.from(document.querySelectorAll('[data-scenario-button]'));
      const periodButtons = Array.from(document.querySelectorAll('[data-period-button]'));
      const scenarioAdjustments = {
        pessimista: { cpl: 1.2, contracts: 0.75 },
        realista: { cpl: 1, contracts: 1 },
        otimista: { cpl: 0.85, contracts: 1.3 },
      };

      const currency = new Intl.NumberFormat('pt-BR', {
        style: 'currency',
        currency: 'BRL',
        maximumFractionDigits: 0,
      });

      const currencyPrecise = new Intl.NumberFormat('pt-BR', {
        style: 'currency',
        currency: 'BRL',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      });

      function numberValue(input, fallback = 0) {
        const value = Number(input?.value);
        return Number.isFinite(value) ? value : fallback;
      }

      function percent(value) {
        return `${value.toLocaleString('pt-BR', { maximumFractionDigits: 1 })}%`;
      }

      function roasText(value) {
        return `${value.toLocaleString('pt-BR', { maximumFractionDigits: 2 })}x`;
      }

      function updateToggleButtons(buttons, attribute, activeValue) {
        buttons.forEach((button) => {
          const isActive = button.dataset[attribute] === activeValue;
          button.classList.toggle('bg-gradient-to-r', isActive && attribute === 'scenarioButton');
          button.classList.toggle('from-[#1630DF]', isActive && attribute === 'scenarioButton');
          button.classList.toggle('to-[#00BAFF]', isActive && attribute === 'scenarioButton');
          button.classList.toggle('bg-[#00BAFF]', isActive && attribute === 'periodButton');
          button.classList.toggle('text-white', isActive);
          button.classList.toggle('font-bold', isActive);
          button.classList.toggle('text-ink-light', !isActive);
          button.classList.toggle('font-semibold', !isActive);
          button.classList.toggle('shadow-sm', isActive);
        });
      }

      function showStep(step) {
        activeStep = Math.max(0, Math.min(step, stepPanels.length - 1));
        stepPanels.forEach((panel, index) => {
          panel.classList.toggle('hidden', index !== activeStep);
        });
        stepButtons.forEach((button, index) => {
          const isActive = index === activeStep;
          button.classList.toggle('bg-white', isActive);
          button.classList.toggle('text-ink', isActive);
          button.classList.toggle('font-bold', isActive);
          button.classList.toggle('shadow-sm', isActive);
          button.classList.toggle('text-ink-light', !isActive);
          button.classList.toggle('font-semibold', !isActive);
        });
        stepBackButton?.classList.toggle('invisible', activeStep === 0);
        stepNextButton?.classList.toggle('hidden', activeStep === stepPanels.length - 1);
        submitCalculationButton?.classList.toggle('hidden', activeStep !== stepPanels.length - 1);
        submitCalculationButton?.classList.toggle('inline-flex', activeStep === stepPanels.length - 1);
      }

      function scenarioResult(base, adjustment) {
        const adjustedCpl = Math.max(base.cpl * adjustment.cpl, 1);
        const contracts = Math.max(base.contracts * adjustment.contracts, 0);
        const leads = base.investment / adjustedCpl;
        const revenue = contracts * base.ticket;
        const roas = base.investment > 0 ? revenue / base.investment : 0;
        return { cpl: adjustedCpl, leads, contracts, revenue, roas };
      }

      function calculate() {
        const investment = numberValue(fields.investment);
        const desiredRoas = numberValue(fields.roas);
        const cpl = Math.max(numberValue(fields.cpl, 1), 1);
        const ticket = Math.max(numberValue(fields.ticket), 0);
        const contracts = Math.max(numberValue(fields.contracts), 0);
        const goal = numberValue(fields.goal);
        const months = Math.max(numberValue(fields.months, 1), 1);
        const competitorFee = Math.max(numberValue(fields.competitorFee), 0);
        const ownFee = Math.max(numberValue(fields.ownFee), 0);
        const base = { investment, cpl, ticket, contracts };
        const selectedScenario = scenarioAdjustments[activeScenario] || scenarioAdjustments.realista;
        const current = scenarioResult(base, selectedScenario);
        const divisor = activePeriod === 'diario' ? 30 : 1;
        const periodLabel = activePeriod === 'diario' ? 'diário' : 'mensal';
        const periodSuffix = activePeriod === 'diario' ? '/dia' : '/mês';

        const revenue = current.revenue;
        const leads = current.leads;
        const sales = current.contracts;
        const actualRoas = current.roas;
        const conversionRate = leads > 0 ? (sales / leads) * 100 : 0;
        const cac = sales > 0 ? investment / sales : 0;
        const roi = investment > 0 ? ((revenue - investment) / investment) * 100 : 0;
        const requiredInvestment = actualRoas > 0 ? goal / actualRoas : 0;
        const projection = revenue * months;
        const goalProgress = goal > 0 ? Math.min((revenue / goal) * 100, 100) : 0;
        const leadBar = Math.max(8, Math.min((leads / Math.max(leads, 100)) * 100, 100));
        const salesBar = Math.max(8, Math.min((sales / Math.max(sales, 12)) * 100, 100));
        const revenueBar = Math.max(8, goal > 0 ? Math.min((revenue / goal) * 100, 100) : 100);
        const commonTotalCost = investment + competitorFee;
        const scaleTotalCost = investment + ownFee;
        const commonRoi = commonTotalCost > 0 ? ((revenue - commonTotalCost) / commonTotalCost) * 100 : roi;
        const scaleRoi = ownFee > 0 || competitorFee > 0
          ? (scaleTotalCost > 0 ? ((revenue - scaleTotalCost) / scaleTotalCost) * 100 : roi)
          : roi + 17.5;
        const agencyDiff = scaleRoi - commonRoi;
        const marketDiff = desiredRoas > 0 ? ((actualRoas - desiredRoas) / desiredRoas) * 100 : 0;
        const scenarios = {
          pessimista: scenarioResult(base, scenarioAdjustments.pessimista),
          realista: scenarioResult(base, scenarioAdjustments.realista),
          otimista: scenarioResult(base, scenarioAdjustments.otimista),
        };

        latestResult = {
          segmento: fields.segment?.selectedOptions?.[0]?.textContent?.trim() || '',
          investimentoMensal: investment,
          roasDesejado: desiredRoas,
          roasReal: actualRoas,
          cpl,
          honorariosPorContrato: ticket,
          contratosFechados: contracts,
          cenario: activeScenario,
          periodo: activePeriod,
          conversaoLeadContrato: conversionRate,
          metaHonorarios: goal,
          meses: months,
          honorariosGerados: revenue,
          contatosQualificados: leads,
          contratosEstimados: sales,
          cacEstimado: cac,
          roi,
          mensalidadeConcorrente: competitorFee,
          suaMensalidade: ownFee,
          investimentoParaMeta: requiredInvestment,
          projecaoAcumulada: projection,
        };

        outputs.revenueLabel.textContent = `Honorários gerados ${periodLabel}`;
        outputs.revenue.textContent = `${currencyPrecise.format(revenue / divisor)}${periodSuffix}`;
        outputs.roasBadge.textContent = `ROAS ${roasText(actualRoas)}`;
        outputs.actualRoas.textContent = roasText(actualRoas);
        outputs.marketDiff.textContent = desiredRoas > 0
          ? `${marketDiff >= 0 ? '+' : ''}${percent(marketDiff)} vs referência de ${roasText(desiredRoas)}`
          : 'Referência de ROAS não informada';
        outputs.marketDiff.classList.toggle('text-emerald-300', marketDiff >= 0);
        outputs.marketDiff.classList.toggle('text-amber-300', marketDiff < 0);
        outputs.goalProgressText.textContent = goal > 0
          ? `${Math.round(goalProgress).toLocaleString('pt-BR')}% da meta`
          : 'Meta não informada';
        outputs.goalProgressBar.style.width = `${Math.max(goalProgress, goal > 0 ? 3 : 0)}%`;
        outputs.leads.textContent = Math.round(leads).toLocaleString('pt-BR');
        outputs.leadCost.textContent = `Custo por contato ${currency.format(cpl)}`;
        outputs.sales.textContent = sales.toLocaleString('pt-BR', { maximumFractionDigits: 1 });
        outputs.conversionText.textContent = `${percent(conversionRate)} conversão/mês`;
        outputs.cac.textContent = sales > 0 ? currency.format(cac) : 'Sem contratos';
        outputs.required.textContent = currency.format(requiredInvestment);
        outputs.investmentLabel.textContent = `Investimento ${periodLabel}`;
        outputs.investment.textContent = `${currencyPrecise.format(investment / divisor)}${periodSuffix}`;
        outputs.roi.textContent = percent(roi);
        outputs.suggestionText.textContent = goal > 0
          ? `Para atingir sua meta de honorários de ${currencyPrecise.format(goal)}/mês, o investimento estimado em anúncios seria:`
          : 'Informe uma meta de honorários para calcular o investimento recomendado.';
        outputs.suggestionValue.textContent = currencyPrecise.format(requiredInvestment);
        outputs.suggestionPeriod.textContent = 'por mês';
        outputs.projection.textContent = `Em ${months} ${months === 1 ? 'mês' : 'meses'}, este cenário pode projetar ${currency.format(projection)} em honorários atribuídos à mídia.`;
        outputs.funnelInvestment.textContent = currency.format(investment);
        outputs.funnelLeads.textContent = `${Math.round(leads).toLocaleString('pt-BR')} contatos`;
        outputs.funnelSales.textContent = `${sales.toLocaleString('pt-BR', { maximumFractionDigits: 1 })} contratos`;
        outputs.funnelRevenue.textContent = currency.format(revenue);
        outputs.funnelLeadBar.style.width = `${leadBar}%`;
        outputs.funnelSalesBar.style.width = `${salesBar}%`;
        outputs.funnelRevenueBar.style.width = `${revenueBar}%`;
        outputs.efficiency.textContent = sales > 0
          ? `Cada contrato custa aproximadamente ${currency.format(cac)} em mídia.`
          : 'Os contratos informados ainda não geram uma leitura de CPA neste cenário.';
        outputs.commonAgencyRoi.textContent = percent(commonRoi);
        outputs.scaleAgencyRoi.textContent = percent(scaleRoi);
        outputs.agencyDiff.textContent = `${agencyDiff >= 0 ? '+' : ''}${percent(agencyDiff)} de lucro extra`;
        outputs.scenarioPessimisticRoas.textContent = roasText(scenarios.pessimista.roas);
        outputs.scenarioPessimisticRevenue.textContent = currency.format(scenarios.pessimista.revenue);
        outputs.scenarioPessimisticSales.textContent = scenarios.pessimista.contracts.toLocaleString('pt-BR', { maximumFractionDigits: 1 });
        outputs.scenarioRealisticRoas.textContent = roasText(scenarios.realista.roas);
        outputs.scenarioRealisticRevenue.textContent = currency.format(scenarios.realista.revenue);
        outputs.scenarioRealisticSales.textContent = scenarios.realista.contracts.toLocaleString('pt-BR', { maximumFractionDigits: 1 });
        outputs.scenarioOptimisticRoas.textContent = roasText(scenarios.otimista.roas);
        outputs.scenarioOptimisticRevenue.textContent = currency.format(scenarios.otimista.revenue);
        outputs.scenarioOptimisticSales.textContent = scenarios.otimista.contracts.toLocaleString('pt-BR', { maximumFractionDigits: 1 });

        if (goal > 0 && revenue >= goal) {
          outputs.diagnosticTitle.textContent = 'Cenário forte para escala';
          outputs.diagnosticText.textContent = 'A projeção bate ou supera sua meta mensal de honorários. O próximo passo é validar se a oferta, a página e o atendimento conseguem sustentar esse volume com segurança ética.';
        } else if (actualRoas >= desiredRoas && sales >= 3) {
          outputs.diagnosticTitle.textContent = 'Cenário promissor';
          outputs.diagnosticText.textContent = 'A simulação indica potencial de retorno, mas a meta ainda depende de mais verba, melhora de conversão ou aumento de ticket médio.';
        } else if (conversionRate < 5) {
          outputs.diagnosticTitle.textContent = 'Atenção à conversão comercial';
          outputs.diagnosticText.textContent = 'O gargalo mais provável está depois do lead: triagem, velocidade de atendimento, proposta ou qualificação. Melhorar conversão pode reduzir o investimento necessário.';
        } else {
          outputs.diagnosticTitle.textContent = 'Cenário para validação controlada';
          outputs.diagnosticText.textContent = 'Vale começar com teste estruturado, acompanhar custo e qualidade dos contatos, e ajustar campanha, página e atendimento antes de aumentar a verba.';
        }
      }

      fields.segment?.addEventListener('change', () => {
        const selected = fields.segment.selectedOptions[0];
        fields.cpl.value = selected.dataset.cpl || fields.cpl.value;
        fields.ticket.value = selected.dataset.ticket || fields.ticket.value;
        fields.contracts.value = selected.dataset.contracts || fields.contracts.value;
        calculate();
      });

      Object.values(fields).forEach((field) => {
        field?.addEventListener('input', calculate);
      });

      stepButtons.forEach((button) => {
        button.addEventListener('click', () => {
          showStep(Number(button.dataset.stepTarget || 0));
        });
      });

      stepBackButton?.addEventListener('click', () => {
        showStep(activeStep - 1);
      });

      stepNextButton?.addEventListener('click', () => {
        showStep(activeStep + 1);
      });

      scenarioButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeScenario = button.dataset.scenarioButton || 'realista';
          updateToggleButtons(scenarioButtons, 'scenarioButton', activeScenario);
          calculate();
        });
      });

      periodButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activePeriod = button.dataset.periodButton || 'mensal';
          updateToggleButtons(periodButtons, 'periodButton', activePeriod);
          calculate();
        });
      });

      function formatPhone(value) {
        const digits = value.replace(/\D/g, '').slice(0, 11);
        if (digits.length <= 2) return digits;
        if (digits.length <= 6) return `(${digits.slice(0, 2)}) ${digits.slice(2)}`;
        if (digits.length <= 10) {
          return `(${digits.slice(0, 2)}) ${digits.slice(2, 6)}-${digits.slice(6)}`;
        }
        return `(${digits.slice(0, 2)}) ${digits.slice(2, 7)}-${digits.slice(7)}`;
      }

      function showLeadError(message) {
        if (!leadError) return;
        leadError.textContent = message;
        leadError.classList.remove('hidden');
      }

      function clearLeadError() {
        if (!leadError) return;
        leadError.textContent = '';
        leadError.classList.add('hidden');
      }

      function openLeadModal() {
        clearLeadError();
        leadModal?.classList.remove('hidden');
        leadModal?.classList.add('flex');
        leadModal?.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        window.setTimeout(() => document.getElementById('calcLeadName')?.focus(), 80);
      }

      function closeLeadModal() {
        leadModal?.classList.add('hidden');
        leadModal?.classList.remove('flex');
        leadModal?.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      function unlockResults() {
        resultsUnlocked = true;
        closeLeadModal();
        calculatorPanel?.classList.add('hidden');
        resultCard?.classList.remove('hidden');
        resultPlaceholder?.classList.add('hidden');
        resultContent?.classList.remove('hidden');
        resultContent?.removeAttribute('aria-hidden');
        resultCard?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      function showCalculatorForNewCalculation() {
        calculatorPanel?.classList.remove('hidden');
        resultCard?.classList.add('hidden');
        calculatorPanel?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      document.getElementById('calcLeadPhone')?.addEventListener('input', (event) => {
        event.target.value = formatPhone(event.target.value);
      });

      form.addEventListener('submit', (event) => {
        event.preventDefault();
        if (activeStep < stepPanels.length - 1) {
          showStep(activeStep + 1);
          return;
        }
        calculate();
        if (resultsUnlocked) {
          unlockResults();
          return;
        }
        openLeadModal();
      });

      newCalculationButton?.addEventListener('click', showCalculatorForNewCalculation);

      leadClose?.addEventListener('click', closeLeadModal);
      leadModal?.addEventListener('click', (event) => {
        if (event.target === leadModal) closeLeadModal();
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !leadModal?.classList.contains('hidden')) {
          closeLeadModal();
        }
      });

      leadForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        clearLeadError();

        const submitButton = leadForm.querySelector('button[type="submit"]');
        const formData = new FormData(leadForm);
        const nome = String(formData.get('nome') || '').trim();
        const email = String(formData.get('email') || '').trim();
        const telefone = String(formData.get('telefone') || '').trim();
        const phoneDigits = telefone.replace(/\D/g, '');
        const instagram = String(formData.get('instagram') || '').trim();

        if (!nome || nome.length < 3) {
          showLeadError('Informe seu nome completo.');
          return;
        }
        if (!email.includes('@') || !email.includes('.')) {
          showLeadError('Informe um e-mail válido.');
          return;
        }
        if (phoneDigits.length < 10) {
          showLeadError('Informe um WhatsApp válido com DDD.');
          return;
        }

        submitButton.disabled = true;
        submitButton.textContent = 'Liberando projeção...';

        const payload = {
          nome,
          email,
          number: Number(phoneDigits),
          fields: {
            number: {
              type: 'text',
              value: formatPhone(phoneDigits),
              rawValue: formatPhone(phoneDigits),
            },
          },
          faturamento: 'calculadora_investimento_anuncios',
          instagram,
          sourceUrl: window.location.href,
          submittedAt: new Date().toISOString(),
          calculator: latestResult,
        };

        const webhookUrl = resultCard?.dataset.webhookUrl?.trim();
        const excelWebhookUrl = resultCard?.dataset.excelWebhookUrl?.trim();

        try {
          if (excelWebhookUrl) {
            fetch(excelWebhookUrl, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            }).catch(() => {});
          }

          if (webhookUrl) {
            const response = await fetch(webhookUrl, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload),
            });
            if (!response.ok) throw new Error('Falha ao enviar');
          }

          unlockResults();
        } catch (error) {
          showLeadError('Não foi possível enviar agora. Tente novamente em alguns segundos.');
          submitButton.disabled = false;
          submitButton.textContent = 'Ver minha projeção no dashboard';
        }
      });

      showStep(0);
      calculate();
    })();
  </script>
</BaseLayout>
