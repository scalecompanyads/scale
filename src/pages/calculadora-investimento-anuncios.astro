  <section class="section bg-white light-section">
    <div class="container">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {[
          { icon: Target, title: 'Use como ponto de partida', desc: 'A projeção ajuda a entender ordem de grandeza. O plano real depende de funil, oferta, margem e capacidade comercial.' },
          { icon: CheckCircle2, title: 'Ajuste com dados reais', desc: 'Substitua CPL, ticket e contratos por dados do seu CRM ou histórico de campanhas.' },
          { icon: LineChart, title: 'Compare cenários', desc: 'Teste diferentes ROAS, tickets e metas antes de decidir quanto investir em mídia.' },
        ].map((item) => {
          const Icon = item.icon;
          return (
            <div class="rounded-[8px] border border-edge bg-white p-7">
              <Icon className="mb-5 h-8 w-8 text-[#1630DF]" strokeWidth={1.7} />
