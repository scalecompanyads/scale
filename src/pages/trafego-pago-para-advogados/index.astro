---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import LegalLogosMarquee from '@components/sections/LegalLogosMarquee.astro';
import {
  legalAreas,
  legalOffer,
  legalTeam,
  oabCompliance,
} from '@data/legalSeo';
import { brand, getCanonicalUrl, organizationId, websiteId } from '@data/seo';
import {
  ArrowRight,
  BadgeCheck,
  BarChart3,
  Eye,
  FileText,
  Gauge,
  Landmark,
  Layers,
  LineChart,
  MousePointerClick,
  Search,
  ShieldCheck,
} from 'lucide-react';

const canonical = getCanonicalUrl('/trafego-pago-para-advogados');
const pageDescription =
  'Tráfego pago para advogados com campanhas de fundo de funil, landing pages ultrarrápidas, qualificação inteligente e comunicação alinhada à OAB.';

const heroMetrics = [
  {
    value: 'Google Ads',
    label: 'fundo de funil',
    Icon: Search,
  },
  {
    value: 'OAB',
    label: 'rigor ético',
    Icon: ShieldCheck,
  },
];

const conversionCards = [
  {
    title: 'Verba',
    desc: 'Agência generalista compra volume. No jurídico, volume barato costuma virar triagem cara, WhatsApp lotado e equipe comercial cansada.',
    Icon: MousePointerClick,
  },
  {
    title: 'Filtro',
    desc: 'A campanha já nasce com intenção, negativas e linguagem de qualificação para reduzir curiosos antes do primeiro contato.',
    Icon: Gauge,
  },
  {
    title: 'WhatsApp',
    desc: 'O contato chega com mais contexto, área, urgência e fit comercial. Menos atendimento desperdiçado, mais conversa com chance real.',
    Icon: FileText,
  },
  {
    title: 'Contrato',
    desc: 'A leitura não termina no lead. Acompanhamos origem, qualidade, atendimento e sinais que aproximam mídia de honorários.',
    Icon: LineChart,
  },
];

const technologyDifferentials = [
  {
    title: 'Milissegundos valem contratos',
    desc:
      'Desenvolvemos landing pages em Astro e JAMstack para que o clique pago encontre uma página leve, estável e pronta para converter no celular.',
    Icon: Layers,
  },
  {
    title: 'Grafite, silêncio visual e respeito',
    desc:
      'A estética é parte da venda: grafite, contraste limpo e minimalismo institucional criam autoridade sem parecer anúncio desesperado.',
    Icon: Eye,
  },
  {
    title: 'O fim do achismo comercial',
    desc:
      'Mapeamos clique no WhatsApp, formulário, origem da campanha e sinais de qualidade para saber qual palavra-chave trouxe oportunidade real.',
    Icon: BarChart3,
  },
];

const specialtyHighlights = [
  {
    title: 'Advocacia Criminal: urgência e sigilo',
    href: '/trafego-pago-para-advogados/advogados-criminalistas',
    desc:
      'O mercado criminal não perdoa lentidão. Capturamos o momento da dor sem sensacionalismo, com página rápida, mensagem discreta e foco em conversa válida.',
    metrics: ['custo por conversa válida', 'tempo até primeiro atendimento'],
  },
  {
    title: 'Direito Previdenciário: triagem documental',
    href: '/trafego-pago-para-advogados/advogados-previdenciarios',
    desc:
      'Volume vazio quebra a operação previdenciária. O funil separa curiosidade de demanda madura e favorece contatos com documentos e contexto para análise.',
    metrics: ['custo por lead com documento', 'CNIS e laudos prontos'],
  },
  {
    title: 'Tributário e Empresarial: aquisição B2B',
    href: '/trafego-pago-para-advogados/advogados-empresariais',
    secondaryHref: '/trafego-pago-para-advogados/advogados-tributaristas',
    desc:
      'CEO e diretor financeiro não respondem a anúncio amador. O funil filtra porte, cargo, escopo e problema antes da conversa comercial.',
    metrics: ['custo por decisor', 'porte da empresa'],
  },
  {
    title: 'Família e Imobiliário: clareza patrimonial',
    href: '/trafego-pago-para-advogados/advogados-de-familia',
    secondaryHref: '/trafego-pago-para-advogados/advogados-imobiliarios',
    desc:
      'Demandas sensíveis exigem discrição e definição. Segmentamos divórcio, guarda, inventário, locação e bloqueios patrimoniais sem misturar dores diferentes.',
    metrics: ['custo por demanda definida', 'privacidade no contato'],
  },
];

const faqs = [
  {
    question: 'Por que a Scale não trata lead jurídico como lead de e-commerce?',
    answer:
      'Porque contratação jurídica depende de intenção, urgência, confiança, capacidade de pagamento e compliance. Por isso a operação une mídia, página, triagem e leitura comercial, em vez de otimizar só para lead barato.',
  },
  {
    question: 'Quanto tempo até uma campanha começar a gerar demanda?',
    answer:
      'Campanhas de fundo de funil em Google Ads podem gerar contatos nas primeiras semanas, mas resultado financeiro depende da área, do atendimento e do ticket. Criminal tende a ter decisão mais rápida; consultivo empresarial costuma exigir maturação.',
  },
  {
    question: 'Por que construir a landing em Astro melhora o ROI?',
    answer:
      'Porque clique pago não tolera página lenta. Uma landing leve, estável e objetiva reduz abandono, melhora a experiência no celular e dá mais chance para cada real de mídia virar conversa qualificada.',
  },
  {
    question: 'A estratégia respeita o Provimento 205/2021?',
    answer:
      'Sim. A comunicação evita promessa de resultado, mercantilização, sensacionalismo e comparação depreciativa. Criativos, páginas e textos são validados com o escritório antes da veiculação.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonical}#service`,
  name: 'Tráfego Pago para Advogados',
  alternateName: legalOffer.name,
  description: pageDescription,
  url: canonical,
  provider: {
    '@id': organizationId,
  },
  isPartOf: {
    '@id': websiteId,
  },
  areaServed: {
    '@type': 'Country',
    name: 'Brasil',
  },
  serviceType: 'Gestão de Google Ads e Meta Ads para escritórios de advocacia',
  audience: {
    '@type': 'Audience',
    audienceType: 'Advogados e escritórios de advocacia',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Áreas jurídicas atendidas',
    itemListElement: legalAreas.map((area) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: `Tráfego pago para ${area.name}`,
        description: area.metaDescription,
      },
    })),
  },
  brand: {
    '@type': 'Brand',
    name: brand.name,
  },
  award: 'Google Ads Search Certification',
  certifications: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Certification',
      name: 'Google Ads Search Certification',
      url: 'https://www.credential.net/cdf1811d-e059-4074-9e10-b571c0bf86f8',
      recognizedBy: {
        '@type': 'Organization',
        name: 'Google Skillshop'
      }
    }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  isPartOf: {
    '@id': websiteId,
  },
  mainEntity: faqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title="Tráfego Pago para Advogados | Motor de Captação Jurídica | Scale"
  description={pageDescription}
  canonical={canonical}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/scale-advogados/assets/desktop.webp"
    type="image/webp"
    media="(min-width: 769px)"
    fetchpriority="high"
  />
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/scale-advogados/assets/mobile%20(2).png"
    type="image/png"
    media="(max-width: 768px)"
    fetchpriority="high"
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script slot="head" is:inline>
    (() => {
      const root = document.documentElement;
      root.classList.add('trafego-advogados-page');

      const updateHeaderVisibility = () => {
        root.classList.toggle('trafego-advogados-scrolled', window.scrollY > 80);
      };

      updateHeaderVisibility();
      window.addEventListener('scroll', updateHeaderVisibility, { passive: true });
      window.addEventListener('load', updateHeaderVisibility, { once: true });
    })();
  </script>
  <style slot="head" is:global>
    html.trafego-advogados-page #header-outer {
      transition:
        opacity 260ms ease,
        transform 260ms ease,
        padding 0.4s cubic-bezier(0.16, 1, 0.3, 1),
        top 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    html.trafego-advogados-page:not(.trafego-advogados-scrolled) #header-outer {
      opacity: 0;
      pointer-events: none;
      transform: translateY(-120%);
    }

    html.trafego-advogados-page.trafego-advogados-scrolled #header-outer {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    html.trafego-advogados-page #main-content {
      padding-top: 0 !important;
    }
  </style>

  <div class="paid-advogados">
    <section class="scale-hero" aria-labelledby="hero-title">
      <picture class="scale-hero__picture" aria-hidden="true">
        <source media="(max-width: 768px)" srcset="/scale-advogados/assets/mobile%20(2).png" />
        <img
          src="/scale-advogados/assets/desktop.webp"
          alt=""
          class="scale-hero__image"
          width="1920"
          height="1080"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      <div class="scale-container scale-hero__container">
        <div class="scale-hero__content">
          <span class="scale-eyebrow">
            <Landmark size={16} strokeWidth={1.8} />
            O fim da dependência de indicações.
          </span>
          <h1 id="hero-title" class="scale-hero__headline">
            Tráfego pago de alta performance para a advocacia.
          </h1>
          <p class="scale-hero__subheadline">
            A Scale constrói o seu motor de captação: campanhas de fundo de funil, qualificação inteligente e landing pages ultrarrápidas para transformar buscas jurídicas em contratos assinados. Rigor ético, tecnologia premium e previsibilidade de caixa.
          </p>

          <div class="scale-hero__ctas">
            <Button href="/contato" variant="ring" size="lg">
              Solicitar diagnóstico do motor de captação
              <ArrowRight size={17} strokeWidth={2.4} />
            </Button>
          </div>

          <div class="scale-authority" aria-label="Pilares do projeto">
            {heroMetrics.map((metric) => {
              const Icon = metric.Icon;
              return (
                <div class="scale-authority__item">
                  <Icon size={18} strokeWidth={1.8} />
                  <span>{metric.value} · {metric.label}</span>
                </div>
              );
            })}
          </div>
        </div>
      </div>

    </section>

    <LegalLogosMarquee label="Escritórios de advocacia que já escalaram suas operações com o método da Scale" />

    <section class="scale-section scale-section--dark">
      <div class="scale-container">
        <div class="scale-split">
          <div class="scale-section-heading scale-section-heading--left">
            <h2>O seu escritório não é um e-commerce. Por que sua agência trata seus leads como se fossem?</h2>
            <p>
              Agências generalistas compram volume. No jurídico, isso vira WhatsApp cheio de curiosos, demandas sem honorários e triagem desperdiçada.
            </p>
            <p>
              A Scale filtra intenção, negativa termos ruins e orienta cada clique por potencial de contrato, não por vaidade de métrica.
            </p>
            <div style="margin-top: 2rem;">
              <Button href="/contato" variant="ring" size="lg">
                Quero captação qualificada
                <ArrowRight size={17} strokeWidth={2.4} />
              </Button>
            </div>
          </div>

          <div class="scale-card-grid scale-card-grid--two">
            {conversionCards.map((item) => {
              const Icon = item.Icon;
              return (
                <article class="scale-card">
                  <div class="scale-card__icon">
                    <Icon size={24} strokeWidth={1.8} />
                  </div>
                  <h3>{item.title}</h3>
                  <p>{item.desc}</p>
                </article>
              );
            })}
          </div>
        </div>
      </div>
    </section>

    <section class="scale-section scale-section--dark scale-section--conversion">
      <div class="scale-container">
        <div class="scale-conversion-layout">
          <div class="scale-section-heading scale-section-heading--left scale-conversion-copy">
            <span class="scale-kicker">Engenharia da conversão</span>
            <h2>Velocidade e sofisticação: onde a concorrência perde o seu cliente.</h2>
            <p>
              O lead jurídico pesquisa pelo celular no momento da dor: um familiar em desespero, um empresário com risco fiscal, um cliente tentando proteger patrimônio. Se a página for lenta ou confusa, ele volta ao Google. Você paga pelo clique; outro escritório atende o cliente.
            </p>
            <div style="margin-top: 2rem;">
              <Button href="/contato" variant="ring" size="lg">
                Melhorar minha conversão
                <ArrowRight size={17} strokeWidth={2.4} />
              </Button>
            </div>
          </div>

          <div class="scale-conversion-system">
            <div class="scale-conversion-flow" aria-label="Pontos da jornada de conversão">
              {['Busca', 'Página', 'WhatsApp', 'Contrato'].map((step, index) => (
                <div class="scale-conversion-flow__item">
                  <span>{String(index + 1).padStart(2, '0')}</span>
                  <strong>{step}</strong>
                </div>
              ))}
            </div>

            <div class="scale-conversion-list">
              {technologyDifferentials.map((item, index) => {
                const Icon = item.Icon;
                return (
                  <article class="scale-conversion-item">
                    <span class="scale-conversion-item__bg-num" aria-hidden="true">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <div class="scale-conversion-item__head">
                      <div class="scale-conversion-icon">
                        <Icon size={22} strokeWidth={1.8} />
                      </div>
                      <h3>{item.title}</h3>
                    </div>
                    <p>{item.desc}</p>
                  </article>
                );
              })}
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="areas" class="scale-section scale-section--light">
      <div class="scale-container">
        <div class="scale-section-heading">
          <h2>A triagem começa no anúncio. Captação cirúrgica por especialidade.</h2>
          <p>
            Cada área do Direito exige uma isca, uma página e um critério de qualificação diferente. Colocar todas as demandas no mesmo balaio é transformar orçamento em ruído.
          </p>
        </div>

        <div class="scale-area-grid">
          {specialtyHighlights.map((area) => (
            <article class="scale-area-card">
              <div class="scale-area-card__top">
                <div>
                  <h3>{area.title}</h3>
                </div>
                <a href={area.href} class="scale-icon-link" aria-label={`Ver página de ${area.title}`}>
                  <ArrowRight size={16} strokeWidth={2.2} />
                </a>
              </div>
              <p>{area.desc}</p>
              <div class="scale-tags">
                {area.metrics.map((metric) => (
                  <span>{metric}</span>
                ))}
              </div>
              {area.secondaryHref && (
                <a href={area.secondaryHref} class="scale-related-link">
                  Ver cluster relacionado
                  <ArrowRight size={15} strokeWidth={2.2} />
                </a>
              )}
            </article>
          ))}
        </div>
        <div style="margin-top: 4rem; display: flex; justify-content: center;">
          <Button href="/contato" variant="primary" size="lg">
            Atrair clientes qualificados
            <ArrowRight size={17} strokeWidth={2.4} />
          </Button>
        </div>
      </div>
    </section>

    <section class="scale-section scale-section--dark">
      <div class="scale-container">
        <div class="scale-oab-strip">
          <div>
            <div class="scale-oab-strip__head">
              <div class="scale-oab-strip__icon">
                <ShieldCheck size={30} strokeWidth={1.6} />
              </div>
              <h2>O Provimento 205/2021 não é um obstáculo. É o nosso manual de alta conversão.</h2>
            </div>
            <p>
              Crescimento agressivo não precisa flertar com infração ética. A Scale constrói campanhas com autoridade técnica, linguagem sóbria e validação do escritório antes de qualquer anúncio ir para o ar.
            </p>
            <div class="scale-tags scale-tags--dark">
              {[
                'Linguagem informativa',
                'Sem promessa de resultado',
                'Sem sensacionalismo',
                'Validação do escritório',
                ...oabCompliance.principles.slice(1, 3),
              ].map((item) => (
                <span>
                  <BadgeCheck size={13} strokeWidth={2.2} />
                  {item}
                </span>
              ))}
            </div>
          </div>
          <div class="scale-oab-strip__action">
            <Button href="/contato" variant="ring" size="lg">
              Solicitar diagnóstico
              <ArrowRight size={17} strokeWidth={2.4} />
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- VIDEOS -->
    <section class="scale-section scale-section--dark scale-section--proof" id="videos">
      <div class="scale-container">
        <div class="scale-section-heading" style="text-align:center;margin-bottom:40px;">
          <span class="scale-kicker">Depoimentos & Resultados</span>
          <h2>Advogados que já estruturaram o crescimento com a Scale</h2>
          <p style="max-width:800px;margin:24px auto 0;">Histórias de escritórios que saíram do improviso e passaram a acompanhar aquisição, atendimento e conversão com mais clareza.</p>
        </div>

        <div style="display: flex; flex-direction: column; md:flex-row; justify-content: center; align-items: center; gap: 20px; margin-bottom: 50px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); padding: 24px; border-radius: 16px; max-width: 600px; margin-left: auto; margin-right: auto;">
           <img src="https://pdf.ms.credential.net/badge/image?env=production&credential=6j8zkser" alt="Selo Oficial Google Ads Search Certification" style="height: 110px; width: auto; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.4));" />
           <div style="text-align: left;">
             <h3 style="font-size: 1.15rem; font-weight: 700; color: #00BAFF; margin-bottom: 6px; font-family: 'Inter', sans-serif;">Gestão Certificada pelo Google</h3>
             <p style="font-size: 0.9rem; color: rgba(255,255,255,0.7); line-height: 1.5;">A Scale possui o selo <a href="https://www.credential.net/cdf1811d-e059-4074-9e10-b571c0bf86f8" target="_blank" rel="noopener noreferrer" style="color: white; text-decoration: underline;">Google Ads Search Certification</a>, garantindo domínio técnico absoluto sobre a plataforma de busca focada em intenção e performance para a área jurídica.</p>
           </div>
        </div>

        <div class="scale-videos__grid">
          <div class="scale-video-wrapper scale-video-card" data-video-id="hZxR3DadbTg">
            <picture>
              <source srcset="/scale-advogados/assets/capa-depoimento-bichara%20(1).webp" type="image/webp">
              <img src="/scale-advogados/assets/capa-depoimento-bichara.png" alt="Depoimento Bichara Advogados" class="scale-video-card__poster" loading="lazy" decoding="async">
            </picture>
            <div class="scale-video-card__play"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor"/></svg></div>
          </div>
          <div class="scale-video-wrapper scale-video-card" data-video-id="4V0ArJKXb-4">
            <picture>
              <source srcset="/scale-advogados/assets/capa-drvitor-miranda%20copy.webp" type="image/webp">
              <img src="/scale-advogados/assets/capa-drvitor-miranda.png" alt="Depoimento Dr. Vitor Miranda" class="scale-video-card__poster" loading="lazy" decoding="async">
            </picture>
            <div class="scale-video-card__play"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor"/></svg></div>
          </div>
        </div>
      </div>
    </section>

    <!-- VIDEO LIGHTBOX -->
    <div class="scale-video-lightbox" id="scale-video-lightbox">
      <button class="scale-video-lightbox__close" id="scale-video-lightbox-close" aria-label="Fechar">&times;</button>
      <div class="scale-video-lightbox__content" id="scale-video-lightbox-content"></div>
    </div>

    <!-- PRINTS -->
    <section class="scale-section scale-section--light" id="prints">
      <div class="scale-container">
        <div class="scale-section-heading">
          <span class="scale-kicker">Percepção de quem acompanha</span>
          <h2>Quando existe método, a percepção muda.</h2>
          <p>O projeto deixa de ser uma tentativa solta e passa a mostrar, semana a semana, o que gera conversa e onde melhorar.</p>
        </div>

        <div class="scale-stagger-wrapper">
          <div class="scale-prints-track" id="scale-stagger-testimonials"></div>
        </div>
      </div>
    </section>

    <!-- LIGHTBOX PRINTS -->
    <div class="scale-lightbox" id="scale-lightbox" role="dialog" aria-modal="true" aria-label="Visualizar depoimento">
      <button class="scale-lightbox__close" id="scale-lightbox-close" aria-label="Fechar">&times;</button>
      <img src="" alt="Print de depoimento ampliado" class="scale-lightbox__image" id="scale-lightbox-image">
    </div>

    <section class="scale-section scale-section--dark scale-section--team">
      <div class="scale-container">
        <div class="scale-section-heading">
          <span class="scale-kicker">Equipe</span>
          <h2>Mais de 32 profissionais acompanhando o mesmo funil: estratégia, mídia, criação, tecnologia e atendimento.</h2>
          <p>
            Página bonita não sustenta captação. O que sustenta é uma operação olhando mensagem, verba, criativo, velocidade, rastreamento e qualidade do contato toda semana.
          </p>
        </div>
      </div>

      <div class="scale-team-carousel" aria-label="Equipe Scale">
        <div class="scale-team-carousel__track">
          {[...legalTeam, ...legalTeam].map((member, index) => (
            <article class="scale-team-card" aria-hidden={index >= legalTeam.length ? 'true' : 'false'}>
              <div class="scale-team-card__photo">
                <img src={member.image} alt={index >= legalTeam.length ? '' : member.name} loading="lazy" decoding="async" />
              </div>
              <div class="scale-team-card__copy">
                <h3>{member.name}</h3>
                <p>{member.role}</p>
              </div>
            </article>
          ))}
          <article class="scale-team-card scale-team-card--plus" aria-hidden="true">
            <strong>+30</strong>
            <span>Profissionais</span>
          </article>
        </div>
      </div>
    </section>

    <section class="scale-section scale-section--light">
      <div class="scale-container scale-container--narrow">
        <div class="scale-section-heading">
          <span class="scale-kicker">FAQ</span>
