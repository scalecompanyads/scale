---
import { getCollection } from 'astro:content';
import BlogLayout from '@layouts/BlogLayout.astro';
import FallbackCover from '@components/ui/FallbackCover.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, publishDate, coverImage, coverImageAlt, category, readingTime, tags } = post.data;
const coverSrc = coverImage?.src;

const formattedDate = publishDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'criacao-de-sites': 'Criação de Sites',
  'landing-pages': 'Landing Pages',
  'seo': 'SEO',
  'trafego-pago': 'Tráfego Pago',
  'redes-sociais': 'Redes Sociais',
  'marketing-digital': 'Marketing Digital',
  'local': 'SEO Local',
  'nicho': 'Nicho',
};
const categoryLabel = categoryLabels[category] ?? category;
---

<BlogLayout article={post}>

  <!-- Barra de progresso de leitura -->
  <div
    id="read-progress"
    class="fixed top-16 left-0 z-50 h-[2px] w-0 pointer-events-none"
    style="background: linear-gradient(90deg, #1630DF, #00BAFF);"
    aria-hidden="true"
  ></div>

  <article class="pb-32 bg-[#010f1c]">

    <!-- HEADER: capa + metadados -->
    <header class="border-b border-white/10">
      <div class="relative w-full max-w-5xl mx-auto px-4 pt-8 md:pt-12">
        {coverSrc ? (
          <div class="relative aspect-video rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
            <img
              src={coverSrc}
              alt={coverImageAlt ?? title}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-[#010f1c]/90 via-[#010f1c]/20 to-transparent pointer-events-none"
              aria-hidden="true"
            />
          </div>
        ) : (
          <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl">
            <FallbackCover variant="hero" title={title} slug={post.slug} />
          </div>
        )}
      </div>

      <div class="container max-w-3xl pt-10 pb-10 md:pt-14 md:pb-12">
        <!-- Categoria + tempo de leitura -->
        <div class="flex items-center gap-3 mb-6 flex-wrap">
          <span class="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest text-[#00BAFF] bg-[#00BAFF]/10 border border-[#00BAFF]/20 px-3 py-1.5 rounded-full">
            {categoryLabel}
          </span>
          {readingTime != null && (
            <span class="text-xs text-white/35 font-medium">
              ⏱ {readingTime} min de leitura
            </span>
          )}
        </div>

        <!-- Título -->
        <h1
          class="font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight mb-5 leading-[1.1]"
          style="background: linear-gradient(to bottom, #ffffff 40%, rgba(255,255,255,0.65) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
        >
          {title}
        </h1>

        <!-- Descrição / lead -->
        <p class="text-white/60 text-lg leading-relaxed mb-6 max-w-2xl">
          {description}
        </p>

        <!-- Linha de meta: data + autor -->
        <div class="flex items-center gap-4 pt-5 border-t border-white/8">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#1630DF] to-[#00BAFF] flex items-center justify-content-center shrink-0 flex items-center justify-center">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <p class="text-xs font-semibold text-white/70">Equipe Scale</p>
            <time class="text-xs text-white/35" datetime={publishDate.toISOString()}>{formattedDate}</time>
          </div>
        </div>
      </div>
    </header>

    <!-- CORPO DO ARTIGO -->
    <div class="container max-w-3xl py-12 md:py-16 prose">
      <Content />
    </div>

    <!-- RODAPÉ DO ARTIGO: tags + CTA -->
    <footer class="container max-w-3xl">

      <!-- Tags -->
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12 pb-10 border-b border-white/10">
          {tags.map((tag) => (
            <span class="text-xs text-white/45 bg-white/5 border border-white/8 px-3 py-1 rounded-full">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <!-- CTA final -->
      <div
        class="rounded-2xl p-8 md:p-10 text-center"
        style="background: linear-gradient(135deg, rgba(22,48,223,0.18) 0%, rgba(0,186,255,0.10) 100%); border: 1px solid rgba(0,186,255,0.18);"
      >
        <p class="text-xs font-bold uppercase tracking-widest text-[#00BAFF] mb-3">Pronto para o próximo passo?</p>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-white mb-3 tracking-tight">
          Fale com um especialista da Scale
        </h2>
        <p class="text-white/55 text-base leading-relaxed mb-6 max-w-md mx-auto">
          Diagnóstico gratuito, sem compromisso. Entendemos o seu negócio antes de qualquer proposta.
        </p>
        <a
          href="/contato"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-semibold text-base text-white transition-opacity hover:opacity-85"
          style="background: linear-gradient(135deg, #1630DF, #00BAFF);"
        >
          Quero meu diagnóstico gratuito
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>

      <!-- Voltar ao blog -->
      <div class="mt-10 text-center">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 text-sm text-white/40 hover:text-white/70 transition-colors"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Voltar para o blog
        </a>
      </div>
    </footer>

  </article>

  <script>
    const bar = document.getElementById('read-progress');
    const article = document.querySelector('article');
    if (bar && article) {
      const update = () => {
        const { top, height } = article.getBoundingClientRect();
        const scrolled = Math.max(0, -top);
        const total = height - window.innerHeight;
        const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
        bar.style.width = pct + '%';
      };
      window.addEventListener('scroll', update, { passive: true });
      update();
    }
  </script>

</BlogLayout>
