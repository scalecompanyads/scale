---
import { getCollection } from 'astro:content';
import BlogLayout from '@layouts/BlogLayout.astro';
import FallbackCover from '@components/ui/FallbackCover.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, publishDate, coverImage, coverImageAlt, category, readingTime } = post.data;
const coverSrc = coverImage?.src;

const formattedDate = publishDate.toLocaleDateString('pt-BR', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<BlogLayout article={post}>
  <article class="pb-24 bg-[#010f1c]">
    <header class="border-b border-white/10">
      {coverSrc ? (
        <div class="relative w-full max-w-5xl mx-auto px-4 pt-8 md:pt-12">
          <div class="relative aspect-video rounded-xl overflow-hidden border border-white/10">
            <img
              src={coverSrc}
              alt={coverImageAlt ?? title}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-[#010f1c]/90 via-[#010f1c]/20 to-transparent pointer-events-none"
              aria-hidden="true"
            />
          </div>
        </div>
      ) : (
        <div class="relative w-full max-w-5xl mx-auto px-4 pt-8 md:pt-12">
          <div class="rounded-xl overflow-hidden border border-white/10">
            <FallbackCover variant="hero" title={title} slug={post.slug} />
          </div>
        </div>
      )}
      <div class="container max-w-3xl py-10 md:py-12">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-primary mb-4">{category}</p>
        <h1 class="font-heading text-3xl md:text-4xl lg:text-5xl font-extrabold text-white tracking-tight mb-4">
          {title}
        </h1>
        <p class="text-white/70 text-lg leading-relaxed mb-4">{description}</p>
        <p class="text-sm text-white/40">
          <time datetime={publishDate.toISOString()}>{formattedDate}</time>
          {readingTime != null && (
            <span class="ml-0.5"> · {readingTime} min de leitura</span>
          )}
        </p>
      </div>
    </header>
    <div class="container max-w-3xl py-10 md:py-14 prose">
      <Content />
    </div>
  </article>
</BlogLayout>
