---
/**
 * Blog — /blog
 * Redesign: Bento Grid Hero + Standard Grid for extra articles.
 * Following the premium home page aesthetic exactly.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import FallbackCover from '@components/ui/FallbackCover.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

/**
 * Categorias e Configurações de Cores (Sync com BlogBento.astro)
 */
const categoryConfig: Record<string, { label: string; color: string; rgb: string }> = {
  'trafego-pago':      { label: 'Tráfego Pago', color: '#a78bfa', rgb: '167,139,250' },
  'seo':               { label: 'SEO',          color: '#00BAFF', rgb: '0,186,255' },
  'criacao-de-sites':  { label: 'Sites',        color: '#4a78ff', rgb: '74,120,255' },
  'redes-sociais':     { label: 'Social',       color: '#34d399', rgb: '52,211,153' },
  'landing-pages':     { label: 'Conversão',    color: '#f59e0b', rgb: '245,158,11' },
  'marketing-digital': { label: 'Marketing',    color: '#00BAFF', rgb: '0,186,255' },
};

// 1. Encontra o artigo principal de tráfego
const trafficArticle = allArticles.find(a => a.data.category === 'trafego-pago');

// 2. Outros artigos para o bento
const bentoOthers = allArticles
  .filter(a => a.id !== trafficArticle?.id)
  .slice(0, 5);

// 3. Combina para formar o Bento (máximo 6 itens)
const displayBento = [trafficArticle, ...bentoOthers].filter(Boolean);

// 4. Artigos remanescentes (se houver mais de 6)
const bentoIds = new Set(displayBento.map(a => a?.id));
const remainingArticles = allArticles.filter(a => !bentoIds.has(a.id));

---

<BaseLayout
  title="Blog de Marketing Digital | Scale"
  description="Aprenda marketing digital, criação de sites, SEO, tráfego pago e mais. Conteúdo prático para empresas que querem crescer online."
>
  <!-- Layout Bento Hero -->
  <section id="blog-page-bento" class="py-12 md:py-20 overflow-hidden">
    <div class="container mb-12">
      <span class="bbn-label">Blog Oficial</span>
      <h1 class="section-title">Conteúdo que transforma negócios</h1>
      <p class="section-subtitle max-w-2xl">
        Acesse os melhores guias, estratégias e dicas práticas para empresas que buscam crescimento real através do digital.
      </p>
    </div>

    <!-- Grid Bento (Exact home layout) -->
    <div class="px-3 md:px-6">
      <div class="bbn-grid bbn-final">
        {displayBento.map((post, i) => {
          if (!post) return null;
          const config = categoryConfig[post.data.category] || categoryConfig['marketing-digital'];
          const coverSrc = post.data.coverImage?.src;
          return (
            <a
              href={`/blog/${post.slug}`}
              class="bbn-item"
              data-bbn={i}
              style={`--c: ${config.color}; --cr: ${config.rgb};`}
            >
              {coverSrc ? (
                <>
                  <img
                    src={coverSrc}
                    alt={post.data.coverImageAlt ?? post.data.title}
                    loading="lazy"
                    decoding="async"
                    class="bbn-cover"
                  />
                  <div class="bbn-cover-dim" aria-hidden="true"></div>
                </>
              ) : (
                <FallbackCover variant="bento" title={post.data.title} slug={post.slug} />
              )}
              <div class="bbn-bg" aria-hidden="true"></div>
              <div class="bbn-noise" aria-hidden="true"></div>
              <div class="bbn-content">
                <div class="bbn-body">
                  <h3 class:list={['bbn-title', !coverSrc && 'sr-only']}>{post.data.title}</h3>
                  {i === 0 && (
                    <p class="bbn-excerpt text-white/50">{post.data.description}</p>
                  )}
                  <span class="bbn-meta">{post.data.readingTime || '5'} min de leitura</span>
                </div>
              </div>
              <div class="bbn-arrow" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Demais Artigos (Grid Padrão) -->
  {remainingArticles.length > 0 && (
    <section class="section pt-0 pb-32">
      <div class="container">
        <h2 class="text-2xl font-bold text-white mb-10 tracking-tight">Mais Artigos</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {remainingArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style is:global>
  /* ── Bento Core Override ─────────────────────────────── */
  /* Reusing the same grid logic from BlogBento.astro to ensure exact match */
  .bbn-label {
    @apply block text-xs font-bold uppercase tracking-[0.2em] text-brand-primary mb-4;
  }
  
  .bbn-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: 360px 280px 220px;
    gap: 0.5rem;
    width: 100%;
  }

  .bbn-grid.bbn-final .bbn-item:nth-child(1) { grid-column: 1 / 4; grid-row: 1 / 3; }
  .bbn-grid.bbn-final .bbn-item:nth-child(2) { grid-column: 4 / 6; grid-row: 1; }
  .bbn-grid.bbn-final .bbn-item:nth-child(3) { grid-column: 4; grid-row: 2; }
  .bbn-grid.bbn-final .bbn-item:nth-child(4) { grid-column: 5; grid-row: 2; }
  .bbn-grid.bbn-final .bbn-item:nth-child(5) { grid-column: 1 / 3; grid-row: 3; }
  .bbn-grid.bbn-final .bbn-item:nth-child(6) { grid-column: 3 / 6; grid-row: 3; }

  .bbn-item {
    position: relative;
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.06);
    background: rgba(255,255,255,0.025);
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .bbn-cover {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.46;
    z-index: 0;
    transition: transform 0.35s ease, opacity 0.35s ease;
  }

  .bbn-cover-dim {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(1, 15, 28, 0.28) 0%, rgba(1, 15, 28, 0.62) 100%);
  }

  .bbn-item:hover {
    border-color: rgba(var(--cr), 0.30);
    box-shadow: 0 0 40px rgba(var(--cr), 0.12);
  }
  .bbn-item:hover .bbn-cover {
    transform: scale(1.03);
    opacity: 0.58;
  }

  .bbn-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 60% at 20% 110%, rgba(var(--cr), 0.22) 0%, transparent 60%),
      linear-gradient(180deg, rgba(1,15,28,0.18) 0%, rgba(1,15,28,0.9) 100%);
    z-index: 0;
    transition: opacity 0.3s ease;
  }

  .bbn-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 160px 160px;
    pointer-events: none;
  }

  .bbn-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: 1.25rem 1.4rem;
  }

  .bbn-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: auto;
  }

  .bbn-title {
    font-family: var(--font-heading);
    font-size: clamp(0.9rem, 1.3vw, 1.25rem);
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
  }

  .bbn-grid.bbn-final .bbn-item:nth-child(1) .bbn-title {
    font-size: clamp(1.4rem, 2.2vw, 2rem);
  }

  .bbn-excerpt {
    font-size: 0.875rem;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bbn-meta {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.28);
    text-transform: uppercase;
  }

  .bbn-arrow {
    position: absolute;
    bottom: 1.2rem;
    right: 1.2rem;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.10);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.35);
    transition: all 0.2s ease;
  }

  .bbn-item:hover .bbn-arrow {
    color: var(--c);
    border-color: rgba(var(--cr), 0.45);
    background: rgba(var(--cr), 0.10);
    transform: translate(2px, -2px);
  }

  @media (max-width: 767px) {
    .bbn-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: repeat(3, minmax(260px, auto));
    }
    .bbn-grid.bbn-final .bbn-item {
      grid-column: auto !important;
      grid-row: auto !important;
    }

    .bbn-grid.bbn-final .bbn-item:nth-child(1) .bbn-title {
      font-size: clamp(0.88rem, 3.4vw, 1.05rem);
      line-height: 1.3;
    }

    .bbn-grid.bbn-final .bbn-item:nth-child(1) .bbn-excerpt {
      -webkit-line-clamp: 2;
      font-size: 0.8125rem;
      line-height: 1.45;
    }

    .bbn-content {
      padding: 1rem 1rem 2.75rem;
    }
  }
</style>
