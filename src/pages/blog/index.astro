---
/**
 * Blog — /blog
 * Redesign: Standardized Grid Layout for all articles.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ArticleCard from '@components/ui/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allArticles = (await getCollection('blog')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
  title="Blog de Marketing Digital | Scale"
  description="Aprenda marketing digital, criação de sites, SEO, tráfego pago e mais. Conteúdo prático para empresas que querem crescer online."
>
  <section class="py-12 md:py-20 overflow-hidden">
    <div class="container mb-12">
      <span class="block text-xs font-bold uppercase tracking-[0.2em] text-brand-primary mb-4">Blog Oficial</span>
      <h1 class="section-title">Conteúdo que transforma negócios</h1>
      <p class="section-subtitle max-w-2xl">
        Acesse os melhores guias, estratégias e dicas práticas para empresas que buscam crescimento real através do digital.
      </p>
    </div>

    <div class="container pb-32">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {allArticles.map((article) => (
          <ArticleCard article={article} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
