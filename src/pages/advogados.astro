---
import BaseHead from '@components/layout/BaseHead.astro';
import AdvogadosLandingWithProvider from '@components/legacy-advogados/AdvogadosLandingWithProvider';
import '../styles/advogados-legacy.css';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <!-- Preconnect para GTM (carregado após interação) -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />

    <!-- Preload das imagens LCP do hero -->
    <link rel="preload" as="image" href="/images/hero-squad-1-480.webp" type="image/webp" fetchpriority="high" />
    <link rel="preload" as="image" href="/images/hero-squad-2-480.webp" type="image/webp" />
    <link rel="preload" as="image" href="/images/hero-squad-3-480.webp" type="image/webp" />

    <!-- Google Tag Manager (lazy loaded para não impactar LCP) -->
    <script is:inline>
      (function () {
        window.dataLayer = window.dataLayer || [];
        var loaded = false;
        function loadGTM() {
          if (loaded) return;
          loaded = true;
          window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var f = document.getElementsByTagName('script')[0];
          var j = document.createElement('script');
          j.async = true;
          j.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-KS5L52P9';
          f.parentNode.insertBefore(j, f);
        }
        var events = ['scroll', 'mousemove', 'touchstart', 'keydown', 'click'];
        function onFirstInteraction() {
          loadGTM();
          events.forEach(function (e) { window.removeEventListener(e, onFirstInteraction, { passive: true }); });
        }
        events.forEach(function (e) { window.addEventListener(e, onFirstInteraction, { passive: true, once: true }); });
      })();
    </script>
    <!-- End Google Tag Manager -->
    <BaseHead
      title="Marketing para Advogados | Scale"
      description="Landing page completa da Scale para advogados e escritórios."
      includeFonts={false}
    />
  </head>
  <body class="advogados-page">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KS5L52P9"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <AdvogadosLandingWithProvider client:load />
  </body>
</html>
