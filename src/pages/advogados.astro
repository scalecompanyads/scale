---
const iframeUrl = 'https://scale-umber-delta.vercel.app';
---

<style>
  .lp-frame-wrap {
    width: 100%;
    min-height: 100vh;
    background: #020617;
  }

  .lp-frame {
    width: 100%;
    height: 100vh;
    border: 0;
    display: block;
    background: #020617;
  }
</style>

<main class="lp-frame-wrap">
  <iframe
    class="lp-frame"
    src={iframeUrl}
    title="Landing page advogados"
    loading="eager"
    referrerpolicy="strict-origin-when-cross-origin"
    allow="clipboard-write"
  ></iframe>
</main>
