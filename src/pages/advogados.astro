---
import BaseHead from '@components/layout/BaseHead.astro';
import AdvogadosLandingWithProvider from '@components/legacy-advogados/AdvogadosLandingWithProvider';
import '@styles/global.css';
import '../styles/advogados-legacy.css';
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;800;900&display=swap"
      rel="stylesheet"
    />
    <BaseHead
      title="Marketing para Advogados | Scale"
      description="Landing page completa da Scale para advogados e escritórios."
    />
  </head>
  <body class="advogados-page">
  <AdvogadosLandingWithProvider client:load />
  </body>
</html>
