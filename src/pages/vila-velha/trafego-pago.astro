---
import LocalLayout from '@layouts/LocalLayout.astro';
import GlassEffect from '@components/ui/GlassEffect.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('vila-velha')!;

const barHeights = [100, 88, 76, 65, 55, 45, 37, 30, 37, 45, 55, 65, 76, 88, 100];

const channels = [
  {
    title: 'Google Ads',
    label: 'Intencao de busca',
    desc: 'Campanhas para aparecer quando o cliente procura por solucao, servico ou empresa em Vila Velha e regiao.',
    points: ['Pesquisa com termos locais', 'Extensoes e chamadas', 'Palavras negativas', 'Conversoes rastreadas'],
  },
  {
    title: 'Meta Ads',
    label: 'Demanda e remarketing',
    desc: 'Anuncios no Instagram e Facebook para aquecer publico, reforcar marca e recuperar quem visitou suas paginas.',
    points: ['Criativos testados', 'Publicos por perfil', 'Remarketing', 'Leitura de qualidade do lead'],
  },
];

const process = [
  {
    step: '01',
    title: 'Diagnostico da operacao',
    desc: 'Entendemos oferta, margem, historico de campanhas, area de atendimento e capacidade comercial antes de sugerir verba.',
  },
  {
    step: '02',
    title: 'Estrutura de campanha',
    desc: 'Organizamos canais, segmentacoes, criativos, landing pages e eventos de conversao para medir o que importa.',
  },
  {
    step: '03',
    title: 'Otimizacao semanal',
    desc: 'Ajustamos lances, anuncios, publicos e termos com base em custo, volume e qualidade real das conversas.',
  },
  {
    step: '04',
    title: 'Relatorio claro',
    desc: 'Voce acompanha investimento, leads, custo por oportunidade e proximos testes em linguagem de negocio.',
  },
];

const neighborhoods = city.neighborhoods ?? ['Praia da Costa', 'Itapoa', 'Gloria', 'Coqueiral de Itaparica'];

const metrics = [
  { value: 'CPA', label: 'Custo por oportunidade' },
  { value: 'ROAS', label: 'Retorno sobre investimento' },
  { value: 'CPL', label: 'Custo por lead' },
  { value: 'CTR', label: 'Taxa de clique qualificado' },
];

const faqs = [
  {
    question: 'Quanto investir em trafego pago em Vila Velha?',
    answer: 'Depende do mercado, concorrencia, ticket medio e meta de aquisicao. No diagnostico, a Scale estima uma verba de teste coerente para Google Ads, Meta Ads ou os dois canais, sem sugerir investimento maior do que a operacao consegue acompanhar.',
  },
  {
    question: 'Google Ads ou Instagram Ads: qual canal usar primeiro?',
    answer: 'Google Ads costuma ser melhor para capturar quem ja esta pesquisando uma solucao. Meta Ads ajuda a gerar demanda, remarketing e presenca. A escolha depende da oferta, maturidade do funil e velocidade esperada para gerar contatos.',
  },
  {
    question: 'A Scale atende empresas fora de Vila Velha?',
    answer: 'Sim. A Scale atende empresas em Vila Velha, Vitoria, Cariacica, Serra e outras regioes. Esta pagina tem foco local porque campanhas para negocios com atendimento regional precisam considerar bairros, raio de atendimento e comportamento de busca da cidade.',
  },
  {
    question: 'A gestao inclui criativos e relatorios?',
    answer: 'Sim. O trabalho inclui estrutura de campanhas, acompanhamento, testes de criativos e relatorios em linguagem de negocio. O objetivo e conectar midia paga com oportunidades reais, nao apenas gerar cliques.',
  },
];
---

<LocalLayout
  title="Trafego Pago em Vila Velha | Google Ads e Meta Ads | Scale"
  description="Gestao de trafego pago em Vila Velha para empresas que querem gerar leads qualificados com Google Ads, Meta Ads, relatorios claros e foco em retorno."
  city={city}
>
  <style>
    @keyframes localWave {
      0% { transform: scaleY(calc(var(--target-scale) * 0.35)); opacity: 0.22; }
      100% { transform: scaleY(var(--target-scale)); opacity: 0.82; }
    }

    .vv-hero-bar {
      flex: 1 0 calc(100% / 15);
      max-width: calc(100% / 15);
      height: 100%;
      background: linear-gradient(to top, #00BAFF, #1630DF 55%, transparent 100%);
      transform-origin: bottom;
      animation: localWave 2s ease-in-out infinite alternate;
    }

    .vv-grid-bg {
      background-image:
        linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
      background-size: 44px 44px;
    }

    .vv-glow {
      position: absolute;
      width: 32rem;
      height: 32rem;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(0, 186, 255, .22), transparent 62%);
      filter: blur(18px);
      pointer-events: none;
    }

    .vv-panel {
      border: 1px solid rgba(255,255,255,.10);
      background: linear-gradient(145deg, rgba(255,255,255,.075), rgba(255,255,255,.025));
      box-shadow: 0 24px 80px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.10);
      backdrop-filter: blur(14px);
    }

    .vv-chip {
      border: 1px solid rgba(0,186,255,.24);
      background: rgba(0,186,255,.08);
      color: rgba(255,255,255,.72);
    }

    .vv-process-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(7, 24, 39, .08);
      background:
        linear-gradient(135deg, rgba(255,255,255,1) 0%, rgba(247,250,255,1) 100%);
      box-shadow: 0 18px 45px rgba(7, 24, 39, .08);
      transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
    }

    .vv-process-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 4px;
      background: linear-gradient(90deg, #1630DF, #00BAFF);
    }

    .vv-process-card::after {
      content: "";
      position: absolute;
      right: -42px;
      top: -42px;
      width: 128px;
      height: 128px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(0, 186, 255, .14), transparent 68%);
      pointer-events: none;
    }

    .vv-process-card:hover {
      transform: translateY(-6px);
      border-color: rgba(0, 186, 255, .24);
      box-shadow: 0 24px 70px rgba(7, 24, 39, .13);
    }

    .vv-process-step {
      display: inline-flex;
      width: 46px;
      height: 46px;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(22, 48, 223, .10), rgba(0, 186, 255, .14));
      color: #1630DF;
      font-family: var(--font-heading, inherit);
      font-weight: 900;
      box-shadow: inset 0 0 0 1px rgba(22, 48, 223, .10);
    }
  </style>

  <section class="relative -mt-16 min-h-[92svh] overflow-hidden bg-[#010f1c] flex items-center">
    <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
      <div class="flex h-full w-full">
        {barHeights.map((h, i) => (
          <div
            class="vv-hero-bar"
            style={`--target-scale: ${h / 100}; animation-delay: -${Math.max(0, (i * 0.15) + Math.sin(i * 1.2) * 0.4).toFixed(2)}s;`}
          />
        ))}
      </div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,#010f1c_0%,rgba(1,15,28,.78)_24%,rgba(1,15,28,.58)_58%,#010f1c_100%)]"></div>
    </div>

    <div class="container relative z-10 py-28 md:py-36">
      <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_.95fr] gap-12 items-center">
        <div class="text-center lg:text-left">
          <div class="mb-7 inline-flex">
            <GlassEffect
              className="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-semibold !cursor-default"
              glassClass="bg-[#010f1c]/75"
              rounded="rounded-full"
            >
              <span style="color: rgba(0,186,255,.75);">+</span>
              <span style="color: rgba(255,255,255,.68);">Gestao de Google Ads e Meta Ads em Vila Velha</span>
            </GlassEffect>
          </div>

          <h1
            class="font-heading font-extrabold leading-[1.03] tracking-tight mb-6 text-balance"
            style="font-size: clamp(2.7rem, 5.5vw, 5rem); background: linear-gradient(to bottom, #fff 34%, rgba(255,255,255,.62)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Trafego pago em Vila Velha para transformar verba em oportunidade.
          </h1>

          <p class="text-lg md:text-xl leading-relaxed max-w-2xl mx-auto lg:mx-0 mb-9 text-white/62">
            A Scale estrutura campanhas de Google Ads e Meta Ads para empresas de Vila Velha que precisam gerar leads qualificados, medir retorno e parar de investir no escuro.
          </p>

          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4">
            <span class="relative inline-block overflow-hidden rounded-full p-[1.5px]">
              <span
                class="animate-spin-slow absolute pointer-events-none"
                aria-hidden="true"
                style="inset: -100%; background: conic-gradient(from 90deg at 50% 50%, #00BAFF 0%, #1630DF 50%, #00BAFF 100%);"
              ></span>
              <a
                href="/contato"
                class="relative inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-full transition-opacity hover:opacity-90"
                style="background: #010f1c; color: white;"
              >
                Solicitar diagnostico gratuito
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </span>

            <GlassEffect
              href="#processo"
              className="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white/80"
              glassClass="bg-white/5 group-hover:bg-white/10"
              rounded="rounded-full"
            >
              Ver processo
            </GlassEffect>
          </div>
        </div>

        <div class="relative">
          <div class="vv-glow -right-24 -top-24" aria-hidden="true"></div>
          <div class="vv-panel rounded-2xl p-5 md:p-7 relative overflow-hidden">
            <div class="flex items-center justify-between gap-4 mb-7">
              <div>
                <p class="text-white/42 text-xs uppercase tracking-[.22em] font-bold">Painel de midia</p>
                <h2 class="text-white font-heading text-2xl font-bold mt-2">Campanhas em leitura</h2>
              </div>
              <span class="vv-chip rounded-full px-3 py-1 text-xs font-bold">Vila Velha</span>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-6">
              {metrics.map((metric) => (
                <div class="rounded-xl border border-white/8 bg-white/[.045] p-4">
                  <strong class="block text-[#00BAFF] text-2xl font-heading">{metric.value}</strong>
                  <span class="text-white/45 text-xs leading-snug">{metric.label}</span>
                </div>
              ))}
            </div>

            <div class="space-y-3">
              {['Busca local com intencao real', 'Remarketing para visitantes do site', 'Criativos testados por oferta', 'Relatorio semanal de proximos passos'].map((item, index) => (
                <div class="flex items-center gap-3 rounded-xl bg-black/18 border border-white/8 p-3">
                  <span class="w-7 h-7 rounded-full bg-[#00BAFF]/12 text-[#00BAFF] flex items-center justify-center text-xs font-bold">{index + 1}</span>
                  <span class="text-white/68 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] vv-grid-bg border-y border-white/8">
    <div class="container py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[.8fr_1.2fr] gap-10 items-start">
        <div>
          <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">Diagnostico antes da verba</p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
            Trafego pago nao e apertar botao. E decidir onde a proxima oportunidade deve nascer.
          </h2>
          <p class="text-white/55 leading-relaxed">
            Empresas em Vila Velha competem por atencao em buscas locais, Instagram, WhatsApp e comparacao de fornecedores. A campanha precisa considerar bairro, oferta, velocidade de atendimento e margem de cada venda.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            ['Verba sem clareza', 'Antes de aumentar investimento, revisamos se a conta mede leads, vendas e qualidade das conversas.'],
            ['Lead que nao fecha', 'O problema nem sempre e o anuncio. Pode estar na pagina, no atendimento ou na oferta apresentada.'],
            ['Campanha local fraca', 'Termos amplos desperdicam dinheiro. Campanhas locais precisam de raio, bairros e intencao de compra.'],
            ['Relatorio dificil', 'Voce precisa entender o que fazer depois do dado, nao apenas receber graficos bonitos.'],
          ].map(([title, desc]) => (
            <div class="rounded-xl border border-white/8 bg-white/[.045] p-6">
              <h3 class="text-white font-semibold mb-2">{title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Google Ads e Meta Ads com papeis diferentes</h2>
        <p class="section-subtitle">A Scale combina captura de demanda, criativos e remarketing para criar um sistema de aquisicao mensuravel.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {channels.map((channel) => (
          <article class="rounded-xl border border-edge bg-surface-card p-7 shadow-sm">
            <div class="flex items-start justify-between gap-4 mb-5">
              <div>
                <span class="text-xs font-bold uppercase tracking-widest text-brand-primary">{channel.label}</span>
                <h3 class="font-heading text-2xl font-bold text-ink mt-2">{channel.title}</h3>
              </div>
              <span class="w-10 h-10 rounded-lg bg-brand-primary/10 text-brand-primary flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18"/><path d="M12 3v18"/><path d="m18 6-12 12"/></svg>
              </span>
            </div>
            <p class="text-ink-light leading-relaxed mb-6">{channel.desc}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {channel.points.map((point) => (
                <div class="flex items-center gap-2 text-sm text-ink">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-primary"></span>
                  {point}
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="processo" class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Como a gestao funciona na pratica</h2>
        <p class="section-subtitle">Um ciclo simples: diagnosticar, lancar, medir e melhorar.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map((item) => (
          <div class="vv-process-card rounded-2xl p-6 md:p-7 min-h-[260px] flex flex-col">
            <div class="relative z-10 flex items-center justify-between mb-8">
              <span class="vv-process-step">{item.step}</span>
              <span class="h-px flex-1 ml-4 bg-gradient-to-r from-[#1630DF]/20 to-transparent"></span>
            </div>
            <div class="relative z-10 mt-auto">
              <h3 class="font-heading text-xl font-bold text-[#071827] mb-3 leading-tight">{item.title}</h3>
              <p class="text-sm text-[#425466] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[.9fr_1.1fr] gap-10 items-center">
        <div>
          <p class="text-brand-primary text-xs uppercase tracking-[.22em] font-bold mb-4">Presenca local</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-ink mb-5">
            Campanhas pensadas para quem compra, visita ou contrata em Vila Velha.
          </h2>
          <p class="text-ink-light leading-relaxed mb-6">
            Uma empresa na Praia da Costa nao tem necessariamente a mesma busca, concorrencia e jornada de quem atende na Gloria, Itapoa ou Coqueiral de Itaparica. A segmentacao local reduz desperdicio e melhora a leitura dos resultados.
          </p>
          <a href="/blog/metricas-e-roas-em-trafego-pago-guia-para-empresas" class="inline-flex items-center gap-2 text-brand-primary font-semibold hover:text-brand-secondary">
            Entender metricas e ROAS
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {neighborhoods.map((item) => (
            <div class="rounded-xl border border-edge bg-surface-card p-5">
              <span class="block text-xs text-ink-light mb-2">Campanhas locais</span>
              <strong class="text-ink">{item}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] vv-grid-bg">
    <div class="container py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">Proximo passo</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
          Antes de investir mais, entenda onde sua campanha pode estar vazando resultado.
        </h2>
        <p class="text-white/58 leading-relaxed mb-8">
          O diagnostico gratuito mostra quais canais fazem sentido, o que precisa ser rastreado e como organizar uma primeira etapa de teste sem depender de achismo.
        </p>
        <a
          href="/contato"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-white transition-opacity hover:opacity-85"
          style="background: linear-gradient(135deg, #1630DF, #00BAFF);"
        >
          Quero meu diagnostico gratuito
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>

  <FAQ items={faqs} title="Perguntas frequentes sobre trafego pago em Vila Velha" />
</LocalLayout>
