---
import LocalLayout from '@layouts/LocalLayout.astro';
import GlassEffect from '@components/ui/GlassEffect.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('vila-velha')!;

const barHeights = [100, 88, 76, 65, 55, 45, 37, 30, 37, 45, 55, 65, 76, 88, 100];
const neighborhoods = city.neighborhoods ?? ['Praia da Costa', 'Itapoa', 'Gloria', 'Coqueiral de Itaparica'];

const pillars = [
  {
    title: 'Posicionamento por especialidade',
    desc: 'Organizamos a comunicacao por area de atuacao para o cliente entender quando deve procurar o escritorio.',
  },
  {
    title: 'SEO local para Vila Velha',
    desc: 'Criamos sinais de presenca regional em paginas, conteudo e Google Business Profile para gerar demanda local.',
  },
  {
    title: 'Conteudo informativo',
    desc: 'Transformamos duvidas reais do publico em artigos, pautas e paginas tecnicas sem linguagem apelativa.',
  },
  {
    title: 'Jornada de contato clara',
    desc: 'Ajustamos CTAs, formularios e fluxo de atendimento para reduzir atrito sem pressionar o potencial cliente.',
  },
];

const process = [
  {
    step: '01',
    title: 'Diagnostico do escritorio',
    desc: 'Analisamos presenca digital, areas prioritarias, concorrencia local, riscos de comunicacao e gargalos de contato.',
  },
  {
    step: '02',
    title: 'Arquitetura juridica',
    desc: 'Estruturamos paginas por especialidade, cidade, duvidas recorrentes e nivel de intencao do potencial cliente.',
  },
  {
    step: '03',
    title: 'Conteudo e autoridade',
    desc: 'Planejamos pauta editorial, SEO local, posts e materiais educativos alinhados a linguagem profissional.',
  },
  {
    step: '04',
    title: 'Acompanhamento mensal',
    desc: 'Medimos buscas, trafego, contatos, qualidade dos leads e oportunidades para melhorar a operacao.',
  },
];

const compliance = [
  'Publicidade informativa',
  'Sem promessa de resultado',
  'Sem sensacionalismo',
  'Sem comparacao depreciativa',
  'Tom tecnico e institucional',
  'Conteudo educativo',
];

const faqs = [
  {
    question: 'A Scale Company atende quais areas do direito?',
    answer:
      'Atendemos escritorios e advogados de diferentes especialidades, como civel, trabalhista, previdenciario, familia, empresarial, tributario, imobiliario e areas consultivas. A estrategia muda conforme o perfil de demanda e a jornada do cliente.',
  },
  {
    question: 'Como voces evitam problemas com a OAB?',
    answer:
      'A operacao prioriza publicidade informativa, conteudo educativo, linguagem sobria e posicionamento tecnico. Evitamos promessa de resultado, urgencia artificial, sensacionalismo e comunicacao mercantilizada.',
  },
  {
    question: 'Marketing juridico e captacao irregular de clientela?',
    answer:
      'Nao quando a estrategia e passiva, informativa e institucional. SEO local, conteudo tecnico, site bem estruturado e presenca digital ajudam o cliente a encontrar o escritorio sem abordagem agressiva.',
  },
  {
    question: 'Quanto tempo leva para aparecer no Google em Vila Velha?',
    answer:
      'SEO costuma exigir um ciclo de 3 a 6 meses, dependendo da concorrencia, autoridade do dominio e qualidade das paginas. Google Ads pode acelerar visibilidade enquanto o organico ganha tracao.',
  },
  {
    question: 'A Scale faz Instagram juridico?',
    answer:
      'Sim. A pauta e construida com foco em educacao do cliente final, autoridade tecnica e consistencia institucional, sem transformar a advocacia em oferta comercial agressiva.',
  },
];
---

<LocalLayout
  title="Marketing Juridico em Vila Velha | SEO, Conteudo e OAB | Scale"
  description="Marketing juridico em Vila Velha para escritorios que querem crescer com SEO local, conteudo informativo, presenca digital e comunicacao alinhada a etica da OAB."
  city={city}
>
  <style>
    @keyframes juridicoWave {
      0% { transform: scaleY(calc(var(--target-scale) * .34)); opacity: .22; }
      100% { transform: scaleY(var(--target-scale)); opacity: .84; }
    }

    .mj-hero-bar {
      flex: 1 0 calc(100% / 15);
      max-width: calc(100% / 15);
      height: 100%;
      background: linear-gradient(to top, #00BAFF, #1630DF 55%, transparent 100%);
      transform-origin: bottom;
      animation: juridicoWave 2s ease-in-out infinite alternate;
    }

    .mj-grid-bg {
      background-image:
        linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
      background-size: 44px 44px;
    }

    .mj-panel {
      border: 1px solid rgba(255,255,255,.10);
      background: linear-gradient(145deg, rgba(255,255,255,.075), rgba(255,255,255,.025));
      box-shadow: 0 24px 80px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.10);
      backdrop-filter: blur(14px);
    }

    .mj-chip {
      border: 1px solid rgba(0,186,255,.24);
      background: rgba(0,186,255,.08);
      color: rgba(255,255,255,.72);
    }

    .mj-process-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(7, 24, 39, .08);
      background: linear-gradient(135deg, #fff 0%, #f7faff 100%);
      box-shadow: 0 18px 45px rgba(7, 24, 39, .08);
      transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
    }

    .mj-process-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 4px;
      background: linear-gradient(90deg, #1630DF, #00BAFF);
    }

    .mj-process-card::after {
      content: "";
      position: absolute;
      right: -42px;
      top: -42px;
      width: 128px;
      height: 128px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(0, 186, 255, .14), transparent 68%);
      pointer-events: none;
    }

    .mj-process-card:hover {
      transform: translateY(-6px);
      border-color: rgba(0, 186, 255, .24);
      box-shadow: 0 24px 70px rgba(7, 24, 39, .13);
    }

    .mj-step {
      display: inline-flex;
      width: 46px;
      height: 46px;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(22, 48, 223, .10), rgba(0, 186, 255, .14));
      color: #1630DF;
      font-family: var(--font-heading, inherit);
      font-weight: 900;
      box-shadow: inset 0 0 0 1px rgba(22, 48, 223, .10);
    }
  </style>

  <section class="relative -mt-16 min-h-[92svh] overflow-hidden bg-[#010f1c] flex items-center">
    <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
      <div class="flex h-full w-full">
        {barHeights.map((h, i) => (
          <div
            class="mj-hero-bar"
            style={`--target-scale: ${h / 100}; animation-delay: -${Math.max(0, (i * 0.15) + Math.sin(i * 1.2) * 0.4).toFixed(2)}s;`}
          />
        ))}
      </div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,#010f1c_0%,rgba(1,15,28,.78)_24%,rgba(1,15,28,.58)_58%,#010f1c_100%)]"></div>
    </div>

    <div class="container relative z-10 py-28 md:py-36">
      <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_.95fr] gap-12 items-center">
        <div class="text-center lg:text-left">
          <div class="mb-7 inline-flex">
            <GlassEffect
              className="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-semibold !cursor-default"
              glassClass="bg-[#010f1c]/75"
              rounded="rounded-full"
            >
              <span style="color: rgba(0,186,255,.75);">+</span>
              <span style="color: rgba(255,255,255,.68);">Marketing juridico em Vila Velha com comunicacao informativa</span>
            </GlassEffect>
          </div>

          <h1
            class="font-heading font-extrabold leading-[1.03] tracking-tight mb-6 text-balance"
            style="font-size: clamp(2.25rem, 4.6vw, 4.2rem); background: linear-gradient(to bottom, #fff 34%, rgba(255,255,255,.62)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Marketing juridico para escritorios que querem crescer com autoridade e seguranca.
          </h1>

          <p class="text-lg md:text-xl leading-relaxed max-w-2xl mx-auto lg:mx-0 mb-9 text-white/62">
            A Scale estrutura SEO local, site, conteudo e aquisicao para escritorios de advocacia em Vila Velha, respeitando sobriedade, etica e comunicacao tecnica.
          </p>

          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4">
            <span class="relative inline-block overflow-hidden rounded-full p-[1.5px]">
              <span
                class="animate-spin-slow absolute pointer-events-none"
                aria-hidden="true"
                style="inset: -100%; background: conic-gradient(from 90deg at 50% 50%, #00BAFF 0%, #1630DF 50%, #00BAFF 100%);"
              ></span>
              <a
                href="/contato"
                class="relative inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-full transition-opacity hover:opacity-90"
                style="background: #010f1c; color: white;"
              >
                Solicitar diagnostico juridico
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </span>

            <GlassEffect
              href="#processo"
              className="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white/80"
              glassClass="bg-white/5 group-hover:bg-white/10"
              rounded="rounded-full"
            >
              Ver metodologia
            </GlassEffect>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -right-20 -top-24 w-[30rem] h-[30rem] rounded-full bg-[#00BAFF]/20 blur-3xl" aria-hidden="true"></div>
          <div class="mj-panel rounded-2xl p-5 md:p-7 relative overflow-hidden">
            <div class="flex items-center justify-between gap-4 mb-7">
              <div>
                <p class="text-white/42 text-xs uppercase tracking-[.22em] font-bold">Mapa da operacao</p>
                <h2 class="text-white font-heading text-2xl font-bold mt-2">Presenca juridica</h2>
              </div>
              <span class="mj-chip rounded-full px-3 py-1 text-xs font-bold">OAB-aware</span>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-6">
              {[
                ['SEO', 'busca local'],
                ['Site', 'conversao'],
                ['Conteudo', 'autoridade'],
                ['Ads', 'demanda ativa'],
              ].map(([value, label]) => (
                <div class="rounded-xl border border-white/8 bg-white/[.045] p-4">
                  <strong class="block text-[#00BAFF] text-2xl font-heading">{value}</strong>
                  <span class="text-white/45 text-xs leading-snug">{label}</span>
                </div>
              ))}
            </div>

            <div class="space-y-3">
              {compliance.slice(0, 4).map((item, index) => (
                <div class="flex items-center gap-3 rounded-xl bg-black/18 border border-white/8 p-3">
                  <span class="w-7 h-7 rounded-full bg-[#00BAFF]/12 text-[#00BAFF] flex items-center justify-center shrink-0" aria-hidden="true">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  </span>
                  <span class="text-white/68 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] mj-grid-bg border-y border-white/8">
    <div class="container py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[.82fr_1.18fr] gap-10 items-start">
        <div>
          <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">O desafio juridico</p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
            Escritorios precisam ser encontrados sem transformar advocacia em oferta agressiva.
          </h2>
          <p class="text-white/55 leading-relaxed">
            Marketing juridico bom organiza reputacao, clareza e presenca digital. O foco nao e promessa, pressao ou volume de posts. E criar um caminho confiavel para o cliente certo chegar ate o escritorio.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            ['Dependencia de indicacao', 'O escritorio cresce em ciclos e nao consegue prever a entrada de novas oportunidades.'],
            ['Site institucional fraco', 'O visitante chega, mas nao entende especialidade, autoridade ou proximo passo de contato.'],
            ['Conteudo generico', 'Posts e artigos nao conectam duvida real, area do direito e intencao local.'],
            ['Risco de comunicacao', 'Linguagem promocional demais pode prejudicar reputacao e gerar inseguranca etica.'],
          ].map(([title, desc]) => (
            <div class="rounded-xl border border-white/8 bg-white/[.045] p-6">
              <h3 class="text-white font-semibold mb-2">{title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Como o escritorio ganha visibilidade com seguranca</h2>
        <p class="section-subtitle">Uma operacao que combina SEO local, conteudo, site e aquisicao sem perder sobriedade.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {pillars.map((item) => (
          <article class="rounded-2xl border border-edge bg-white p-6 shadow-sm">
            <h3 class="font-heading text-lg font-bold text-[#071827] mb-3">{item.title}</h3>
            <p class="text-sm text-[#425466] leading-relaxed">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="processo" class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Processo da Scale para marketing juridico</h2>
        <p class="section-subtitle">Da leitura do escritorio a execucao mensal, com foco em autoridade e demanda qualificada.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map((item) => (
          <div class="mj-process-card rounded-2xl p-6 md:p-7 min-h-[260px] flex flex-col">
            <div class="relative z-10 flex items-center justify-between mb-8">
              <span class="mj-step">{item.step}</span>
              <span class="h-px flex-1 ml-4 bg-gradient-to-r from-[#1630DF]/20 to-transparent"></span>
            </div>
            <div class="relative z-10 mt-auto">
              <h3 class="font-heading text-xl font-bold text-[#071827] mb-3 leading-tight">{item.title}</h3>
              <p class="text-sm text-[#425466] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[.9fr_1.1fr] gap-10 items-center">
        <div>
          <p class="text-brand-primary text-xs uppercase tracking-[.22em] font-bold mb-4">SEO local juridico</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-ink mb-5">
            Presenca por especialidade, cidade e bairros de Vila Velha.
          </h2>
          <p class="text-ink-light leading-relaxed mb-5">
            O Google precisa entender onde o escritorio atende, quais areas sao prioritarias e quais duvidas o publico faz antes de contratar. Por isso, SEO local juridico combina paginas, conteudo, mapa e consistencia institucional.
          </p>
          <a href="/blog/seo-local-para-advogados-em-vila-velha" class="inline-flex items-center gap-2 text-brand-primary font-semibold hover:text-brand-secondary">
            Ler guia de SEO local para advogados
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {neighborhoods.map((item) => (
            <div class="rounded-xl border border-edge bg-surface-card p-5">
              <span class="block text-xs text-ink-light mb-2">Contexto local</span>
              <strong class="text-ink">{item}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] mj-grid-bg">
    <div class="container py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[.9fr_1.1fr] gap-10 items-center">
        <div>
          <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">Compliance editorial</p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
            Comunicacao juridica precisa gerar confianca, nao pressao.
          </h2>
          <p class="text-white/58 leading-relaxed">
            A Scale planeja conteudo e campanhas com linguagem informativa, tecnica e institucional. A linha editorial evita promessas, comparacoes indevidas e chamadas apelativas.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {compliance.map((item) => (
            <div class="rounded-xl border border-white/8 bg-white/[.045] p-4 flex items-center gap-3">
              <span class="w-7 h-7 rounded-full bg-[#00BAFF]/12 text-[#00BAFF] flex items-center justify-center shrink-0" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span class="text-white/70 text-sm">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Conteudos relacionados</h2>
        <p class="section-subtitle">Guias para aprofundar marketing juridico, SEO, site e publicidade digital.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          ['/blog/regras-oab-publicidade-digital-2026', 'Regras da OAB para Publicidade Digital em 2026'],
          ['/blog/como-captar-clientes-na-advocacia-sem-ferir-a-etica', 'Como captar clientes na advocacia sem ferir a etica'],
          ['/blog/site-para-advogados-5-itens-obrigatorios-para-converter-leads', 'Site para advogados: 5 itens obrigatorios para converter leads'],
        ].map(([href, title]) => (
          <a href={href} class="group rounded-2xl border border-edge bg-surface-card p-6 hover:border-brand-primary/35 hover:shadow-lg transition-all">
            <span class="text-xs uppercase tracking-widest font-bold text-brand-primary">Blog</span>
            <h3 class="font-heading text-xl font-bold text-ink mt-3 group-hover:text-brand-primary transition-colors">{title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ title="FAQ - Marketing Juridico e Compliance" items={faqs} />

  <section class="section text-center bg-surface-subtle">
    <div class="container-narrow">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-ink mb-4">Quer estruturar o crescimento do escritorio com mais previsibilidade?</h2>
      <p class="text-ink-light mb-8">No diagnostico, analisamos presenca digital, concorrencia local, riscos de comunicacao e oportunidades de aquisicao para o seu escritorio.</p>
      <a href="/contato" class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-white transition-opacity hover:opacity-85" style="background: linear-gradient(135deg, #1630DF, #00BAFF);">
        Solicitar diagnostico juridico
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</LocalLayout>
