---
import LocalLayout from '@layouts/LocalLayout.astro';
import ScaleLegalLocalLanding from '@components/legal/ScaleLegalLocalLanding.astro';
import { getLegalLocalCityBySlug } from '@data/legalLocalCities';

const city = getLegalLocalCityBySlug('vila-velha')!;
---

<LocalLayout
  title="Marketing Jurídico em Vila Velha | SEO, Conteúdo e OAB | Scale"
  description="Marketing jurídico em Vila Velha para escritórios que querem crescer com SEO local, conteúdo informativo, site comercial e comunicação alinhada à ética da OAB."
  city={city}
>
  <ScaleLegalLocalLanding city={city} />
</LocalLayout>
