---
/**
 * SEO em Vila Velha — /vila-velha/seo
 * Keywords: "agência de SEO em Vila Velha", "consultoria de SEO Vila Velha"
 */
import LocalLayout from '@layouts/LocalLayout.astro';
import MapEmbed from '@components/ui/MapEmbed.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getCityBySlug } from '@data/cities';
const city = getCityBySlug('vila-velha')!;

const faqs = [
  { question: 'Em quanto tempo minha empresa aparece no Google com SEO?', answer: 'Para termos locais como "SEO em Vila Velha", é possível chegar à 1ª página em 60 a 90 dias. Termos nacionais levam mais tempo.' },
  { question: 'A Scale faz SEO para empresas de toda Vila Velha?', answer: 'Sim. Atendemos empresas de todos os bairros de Vila Velha e da Grande Vitória.' },
];
---
<LocalLayout
  title="Agência de SEO em Vila Velha – ES | Scale"
  description="SEO em Vila Velha para empresas que querem ganhar visibilidade no Google com base tecnica forte, paginas melhores e foco em buscas locais."
  city={city}
>
  <section class="section bg-surface-subtle">
    <div class="container">
      <span class="inline-flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        📍 Vila Velha – ES
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
        Agência de SEO em Vila Velha – ES
      </h1>
      <p class="text-lg text-ink-light leading-relaxed mb-8 max-w-2xl">
        Apareça na 1ª página do Google quando seus clientes em Vila Velha buscarem pelo seu serviço. Consultoria de SEO local com foco em resultado rápido.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contato" class="px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
          Diagnóstico gratuito
        </a>
        <a href="tel:+5527XXXXXXXX" class="px-8 py-4 text-lg font-semibold rounded-lg border-2 border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-ink-inverse transition-colors">
          (27) XXXX-XXXX
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <!-- TODO: Dev 2 preenche com conteúdo exclusivo sobre SEO local em VV -->
      <p class="text-ink-light leading-relaxed">Conteúdo exclusivo a ser criado. Deve incluir: contexto do mercado local de VV, por que SEO local converte mais, bairros atendidos.</p>
    </div>
  </section>

  <FAQ items={faqs} />

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-heading text-2xl font-bold text-ink mb-4">Scale em Vila Velha</h2>
          <address class="not-italic space-y-3">
            <div class="flex gap-3">
              <span class="text-sm font-semibold text-ink-light w-20 shrink-0">Telefone</span>
              <a href="tel:+5527XXXXXXXX" class="text-brand-primary hover:underline">(27) XXXX-XXXX</a>
            </div>
          </address>
        </div>
        <MapEmbed />
      </div>
    </div>
  </section>
</LocalLayout>
