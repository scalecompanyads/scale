---
import LocalLayout from '@layouts/LocalLayout.astro';
import { getCityBySlug } from '@data/cities';
const city = getCityBySlug('vila-velha')!;
---
<LocalLayout
  title="Gestão de Redes Sociais em Vila Velha – ES | Scale"
  description="Gestao de redes sociais em Vila Velha para empresas que querem manter consistencia de conteudo, posicionamento de marca e presenca digital local."
  city={city}
>
  <section class="section bg-surface-subtle">
    <div class="container">
      <span class="inline-flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        📍 Vila Velha – ES
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
        Gestão de Redes Sociais em Vila Velha – ES
      </h1>
      <p class="text-lg text-ink-light leading-relaxed mb-8 max-w-2xl">
        Social media estratégico para empresas de Vila Velha: Instagram, Facebook e mais, com conteúdo que vende.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contato" class="px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
          Solicitar proposta
        </a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container-narrow">
      <!-- TODO: Dev 2 preenche com conteúdo exclusivo sobre social media em VV -->
      <p class="text-ink-light leading-relaxed">Conteúdo exclusivo a ser criado.</p>
    </div>
  </section>
</LocalLayout>
