---
/**
 * Contato — /contato
 * Inclui endereço NAP, Google Maps embed e formulário
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import LeadForm from '@components/lead/LeadForm';
import MapEmbed from '@components/ui/MapEmbed.astro';
---

<BaseLayout
  title="Contato | Scale | Agência de Marketing Digital em Vila Velha – ES"
  description="Fale com a Scale sobre sites, SEO, trafego pago e marketing digital para sua empresa. Atendimento consultivo em Vila Velha e projetos para negocios de todo o Brasil."
>
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div>
          <span class="section-label">Fale conosco</span>
          <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
            Vamos conversar sobre seu projeto?
          </h1>
          <p class="text-lg text-ink-light leading-relaxed mb-8">
            Preencha o formulário e nossa agência de marketing entrará em contato em até 24 horas úteis para apresentar os melhores serviços de marketing para você.
          </p>

          <LeadForm client:load variant="page" />
        </div>

        <div>
          <!-- Trust Factor -->
          <div class="mb-10">
            <a href="/certificacao-google-ads" class="inline-flex items-center gap-3 px-6 py-3 rounded-full border border-[#00BAFF]/30 bg-[#00BAFF]/10 hover:bg-[#00BAFF]/20 transition-all hover:scale-105 group text-ink decoration-none shadow-sm mb-2">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00BAFF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
              <span class="font-bold text-sm text-[#010000] group-hover:text-[#1630DF] transition-colors">Agência Oficialmente Certificada pelo Google</span>
            </a>
          </div>

          <!-- NAP — deve ser IDÊNTICO ao Google Business Profile -->
          <address class="not-italic mb-8">
            <p class="font-semibold text-ink mb-3">Scale Marketing Digital</p>
            <!-- TODO: endereço completo -->
            <p class="text-ink-light mb-2">Vila Velha – ES</p>
            <p class="text-ink-light mb-2">(27) XXXX-XXXX</p>
            <p class="text-ink-light">contato@scale.com.br</p>
          </address>

          <MapEmbed title="Scale | Vila Velha, ES" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
