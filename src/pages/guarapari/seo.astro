---
import LocalLayout from '@layouts/LocalLayout.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('guarapari')!;

const faqs = [
  { question: 'Em quanto tempo o SEO começa a funcionar em Guarapari?', answer: 'Os primeiros sinais de melhora aparecem entre 60 e 90 dias. Resultados consistentes e duradouros chegam a partir de 4 a 6 meses, dependendo da competitividade das palavras-chave.' },
  { question: 'SEO local é diferente de SEO nacional?', answer: 'Sim. SEO local foca em termos com intenção geográfica, como "restaurante em Guarapari" ou "pousada Guarapari ES". Trabalhamos especificamente para aparecer nessas buscas.' },
  { question: 'O que está incluso na consultoria de SEO?', answer: 'Auditoria técnica do site, otimização das páginas existentes, estratégia de conteúdo, link building local e relatório mensal de posicionamento e tráfego orgânico.' },
  { question: 'Preciso de um site antes de contratar SEO?', answer: 'Sim, o SEO é aplicado sobre um site existente. Se você ainda não tem, podemos criar um já otimizado e iniciar o SEO na sequência.' },
  { question: 'Como acompanho os resultados do SEO?', answer: 'Relatórios mensais com posicionamento de palavras-chave, tráfego orgânico e impressões no Google Search Console. Você acompanha a evolução com dados reais.' },
];
---

<LocalLayout
  title="SEO em Guarapari – ES | Consultoria e Gestão | Scale"
  description="Consultoria de SEO para empresas em Guarapari (ES). Apareça na 1ª página do Google para buscas locais. Auditoria técnica, conteúdo e link building."
  city={city}
>
  <section class="section bg-surface-subtle">
    <div class="container">
      <span class="inline-flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        📍 Guarapari – ES
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
        SEO em Guarapari – ES: apareça no Google e atraia mais clientes
      </h1>
      <p class="text-lg text-ink-light leading-relaxed mb-8 max-w-2xl">
        Consultoria e gestão de SEO para empresas de Guarapari. Auditoria técnica, otimização de páginas e conteúdo estratégico para sua empresa aparecer na 1ª página do Google.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contato" class="px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
          Solicitar diagnóstico gratuito
        </a>
        <a href="tel:+5528XXXXXXXX" class="px-8 py-4 text-lg font-semibold rounded-lg border-2 border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-ink-inverse transition-colors">
          (28) XXXX-XXXX
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container-narrow">
      <h2 class="font-heading text-2xl font-bold text-ink mb-4">Por que SEO é essencial para empresas de Guarapari</h2>
      <p class="text-ink-light leading-relaxed mb-4">
        Em Guarapari, a busca orgânica tem um papel especialmente importante: turistas pesquisam no Google antes de viajar, e clientes locais fazem o mesmo na hora de escolher um serviço. Estar na primeira página não é diferencial, é necessidade.
      </p>
      <p class="text-ink-light leading-relaxed mb-4">
        Nossa consultoria cobre desde a auditoria técnica do seu site até a criação de conteúdo otimizado para palavras-chave com alto potencial de conversão para o mercado de Guarapari.
      </p>
      <p class="text-ink-light leading-relaxed">
        Você recebe relatórios mensais com posicionamento, tráfego orgânico e evolução das principais palavras-chave, com análise clara do que está funcionando.
      </p>
    </div>
  </section>

  <FAQ items={faqs} title="Dúvidas sobre SEO em Guarapari" />

  <section class="section text-center bg-surface-subtle">
    <div class="container-narrow">
      <h2 class="font-heading text-3xl font-bold text-ink mb-4">Apareça no Google em Guarapari</h2>
      <p class="text-lg text-ink-light mb-8">Diagnóstico SEO gratuito para empresas de Guarapari.</p>
      <a href="/contato" class="inline-block px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
        Solicitar diagnóstico gratuito
      </a>
    </div>
  </section>
</LocalLayout>
