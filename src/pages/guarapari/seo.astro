---
import LocalLayout from '@layouts/LocalLayout.astro';
import ScaleLocalLanding from '@components/local/ScaleLocalLanding.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('guarapari')!;

const conversionCards = [
  { title: 'Busca local', desc: 'Quem pesquisa em Guarapari geralmente ja tem alguma intencao geografica forte. SEO local ajuda a empresa a entrar nessa disputa antes do clique pago.' },
  { title: 'Turismo', desc: 'O turista pesquisa antes de viajar. Ganhar visibilidade organica nesse momento abre espaco para demanda que chegaria pronta.' },
  { title: 'Conteudo', desc: 'Conteudo sem leitura de busca nao sustenta crescimento. E preciso mapear duvidas, servicos e contexto local com mais precisao.' },
  { title: 'Ativo', desc: 'SEO bem feito acumula autoridade com o tempo e melhora a dependencia da empresa em relacao a midia paga e sazonalidade.' },
];

const differentials = [
  { title: 'Estrutura local bem orientada', desc: 'A pagina precisa mostrar contexto regional, servicos relevantes e sinais claros para o Google e para o visitante.' },
  { title: 'Conteudo com intencao pratica', desc: 'O foco e ganhar relevancia para buscas que podem gerar demanda comercial, e nao produzir volume de texto sem estrategia.' },
  { title: 'Acompanhamento de evolucao real', desc: 'A Scale observa pagina, impressao, clique e ganho de relevancia para transformar SEO em um ativo compreensivel.' },
];

const relatedItems = [
  { title: 'Hub de Guarapari', href: '/guarapari', desc: 'Visao geral da estrategia digital para empresas da cidade e da regiao.', metrics: ['hub local', 'estrategia'] },
  { title: 'Criacao de sites em Guarapari', href: '/guarapari/criacao-de-sites', desc: 'Base mais forte para SEO local, performance e melhor conversao do acesso organico.', metrics: ['site', 'estrutura'] },
  { title: 'Guia de SEO local', href: '/blog/seo-local-google-meu-negocio-o-que-fazer-primeiro', desc: 'Primeiros movimentos para melhorar visibilidade em busca geografica.', metrics: ['Google', 'mapa'] },
  { title: 'Consultoria SEO', href: '/servicos/consultoria-seo', desc: 'Estrutura tecnica e editorial para empresas que querem tratar o organico com mais seriedade.', metrics: ['auditoria', 'crescimento'] },
];

const faqs = [
  { question: 'SEO em Guarapari ajuda a atrair turista e cliente local?', answer: 'Sim. O SEO local bem estruturado permite que a empresa apareca para quem mora na regiao e para quem pesquisa antes de visitar a cidade.' },
  { question: 'Quanto tempo leva para o SEO ganhar tracao?', answer: 'Os ganhos variam conforme concorrencia, base atual e qualidade das paginas. O importante e tratar o SEO como ativo de medio prazo e nao como promessa imediata.' },
  { question: 'Preciso de um site melhor antes de investir em SEO?', answer: 'Em muitos casos, sim. Se o site for lento, raso ou mal estruturado, ele limita tanto o ranqueamento quanto a conversao do acesso organico.' },
  { question: 'Como a Scale mede resultado no SEO local?', answer: 'Avaliamos busca geografica, paginas relevantes, impressao, clique, posicionamento e valor comercial do trafego que esta sendo conquistado.' },
];
---

<LocalLayout
  title="SEO em Guarapari - ES | Estrategia Local | Scale"
  description="SEO em Guarapari para empresas que querem aparecer melhor no Google com estrutura tecnica, conteudo local e estrategia organica consistente."
  city={city}
>
  <ScaleLocalLanding
    heroEyebrow="SEO em Guarapari para empresas que querem ser encontradas com mais consistencia."
    heroTitle="SEO em Guarapari com foco em busca local, visibilidade organica e demanda mais qualificada."
    heroDescription="A Scale organiza o SEO para empresas de Guarapari que precisam aparecer melhor no Google, aproveitar busca local e construir um ativo organico que sustente crescimento ao longo do tempo."
    heroMetrics={[{ value: 'SEO', label: 'local', icon: 'search' }, { value: 'Google', label: 'visibilidade', icon: 'shield' }]}
    logosLabel="Empresas que ja confiaram na Scale para fortalecer o organico"
    problemTitle="Em Guarapari, aparecer no Google na hora certa pode significar demanda nova antes da concorrencia reagir."
    problemParagraphs={['O cliente local e o turista digitalizam a decisao muito antes do contato. Por isso, SEO local importa para quem quer crescer com mais previsibilidade.', 'Quando a empresa constroi paginas melhores e ganha contexto regional, ela para de depender so de anuncio ou de rede social para ser encontrada.']}
    conversionCards={conversionCards}
    engineeringKicker="Engenharia organica"
    engineeringTitle="SEO local bom combina contexto da cidade, pagina forte e conteudo com funcao."
    engineeringText="Nao basta produzir texto. O trabalho precisa conectar estrutura tecnica, busca geografica e paginas que o mercado realmente quer encontrar."
    differentials={differentials}
    areasTitle="As frentes que ajudam o SEO em Guarapari a ganhar tracao."
    areasText="A Scale organiza base tecnica, pagina, conteudo e contexto local para melhorar visibilidade e relevancia comercial."
    relatedItems={relatedItems}
    complianceTitle="SEO local nao e atalho. E construcao de presenca digital que acumula valor."
    complianceText="Quando a empresa aparece melhor no Google de forma recorrente, ela ganha mais autonomia para competir ao longo do ano."
    complianceTags={['Busca local', 'Conteudo com intencao', 'Google', 'Contexto regional', 'Paginas fortes', 'Ativo organico']}
    videosTitle="Projetos que trataram o organico como ativo e ganharam mais clareza"
    videosText="Quando a leitura do SEO fica mais madura, a empresa entende melhor como o mercado busca e o que precisa melhorar para ser encontrada."
    printsTitle="Mais contexto local e pagina melhor mudam o resultado do organico."
    printsText="O crescimento no Google fica mais consistente quando a empresa deixa de publicar por publicar e passa a construir relevancia."
    teamTitle="Mais de 32 profissionais apoiando estrategia, pagina, conteudo e visibilidade organica."
    teamText="SEO forte pede constancia, estrutura e leitura inteligente do comportamento de busca."
    faqTitle="Perguntas frequentes sobre SEO em Guarapari."
    faqs={faqs}
    finalTitle="Se sua empresa em Guarapari ainda aparece pouco no Google, talvez o problema esteja mais na estrutura do que no esforco."
    finalText="A Scale ajuda a construir um SEO mais claro, local e comercial para transformar busca em ativo de crescimento."
    ctaLabel="Solicitar diagnostico SEO"
    areasCtaLabel="Quero crescer no Google"
  />
</LocalLayout>
