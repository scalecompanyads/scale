---
import LocalLayout from '@layouts/LocalLayout.astro';
import ScaleLocalLanding from '@components/local/ScaleLocalLanding.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('guarapari')!;

const conversionCards = [
  { title: 'Sazonalidade', desc: 'Em Guarapari, parte da demanda oscila com turismo e temporada. A presenca digital precisa aproveitar esse movimento em vez de correr atras dele.' },
  { title: 'Busca', desc: 'O cliente local e o turista pesquisam antes. Quem aparece melhor no Google e comunica mais claro sai na frente da decisao.' },
  { title: 'Confianca', desc: 'Negocios ligados a servicos, comercio e experiencia precisam parecer profissionais no primeiro acesso para converter melhor.' },
  { title: 'Base', desc: 'Sem site, SEO e estrutura, a empresa depende demais de rede social e indicacao, perdendo previsibilidade ao longo do ano.' },
];

const differentials = [
  { title: 'Leitura do mercado local e turistico', desc: 'A estrategia considera o comportamento de quem mora em Guarapari e de quem pesquisa antes de chegar na cidade.' },
  { title: 'Ativos proprios mais fortes', desc: 'Site, busca local e paginas bem resolvidas ajudam o negocio a depender menos de impulso e mais de presenca consolidada.' },
  { title: 'Mais clareza para crescer', desc: 'A Scale organiza oferta, canal e pagina para o negocio saber o que esta gerando visibilidade e demanda de verdade.' },
];

const relatedItems = [
  { title: 'Criacao de sites em Guarapari', href: '/guarapari/criacao-de-sites', desc: 'Sites para empresas que querem captar cliente local e turista com mais confianca e conversao.', metrics: ['site', 'conversao'] },
  { title: 'SEO em Guarapari', href: '/guarapari/seo', desc: 'Presenca organica local para negocios que precisam aparecer melhor no Google ao longo do ano.', metrics: ['Google', 'organico'] },
  { title: 'Landing pages', href: '/servicos/criacao-de-landing-pages', desc: 'Paginas focadas em campanhas, servicos especificos e ofertas sazonais.', metrics: ['campanha', 'foco'] },
  { title: 'Gestao de redes sociais', href: '/servicos/gestao-redes-sociais', desc: 'Conteudo com mais consistencia para reforcar marca, contexto local e percepcao profissional.', metrics: ['marca', 'presenca'] },
];

const faqs = [
  { question: 'A Scale atende empresas em Guarapari?', answer: 'Sim. Atendemos empresas em Guarapari com leitura do contexto local e da demanda sazonal da cidade.' },
  { question: 'Marketing digital funciona para negocios de turismo e comercio local?', answer: 'Sim. Em Guarapari, busca local, site forte e presenca bem organizada ajudam tanto na demanda recorrente quanto nos picos de temporada.' },
  { question: 'Preciso investir em tudo ao mesmo tempo?', answer: 'Nao. O ideal e priorizar o que mais limita a captacao hoje e crescer em cima dessa base, sem dispersar verba e energia.' },
  { question: 'A Scale atende so empresas grandes?', answer: 'Nao. Atendemos negocios locais, empresas em crescimento e operacoes que precisam de mais clareza para vender melhor no digital.' },
];
---

<LocalLayout
  title="Agencia de Marketing Digital em Guarapari - ES | Scale"
  description="Agencia de marketing digital em Guarapari para empresas que querem fortalecer sua presenca online com site, SEO e estrategia voltada ao mercado local."
  city={city}
>
  <ScaleLocalLanding
    heroEyebrow="Agencia de marketing digital em Guarapari com leitura local e turistica."
    heroTitle="Agencia de Marketing Digital em Guarapari para negocios que querem crescer com mais presenca."
    heroDescription="A Scale ajuda empresas de Guarapari a estruturarem site, busca local, posicionamento e ativos digitais para captar mais clientes da regiao e aproveitar melhor a demanda sazonal."
    heroMetrics={[{ value: 'Guarapari', label: 'mercado local', icon: 'search' }, { value: 'Presenca', label: 'mais forte', icon: 'shield' }]}
    logosLabel="Empresas que ja confiaram na Scale para crescer com mais estrutura"
    problemTitle="Em Guarapari, aparecer melhor na hora certa muda o faturamento da temporada e do ano inteiro."
    problemParagraphs={['Negocios locais que dependem de visibilidade online precisam ser encontrados antes da concorrencia, tanto pelo morador quanto pelo visitante.', 'Quando a empresa organiza bem sua presenca digital, ela aproveita melhor os picos de procura e sustenta mais demanda fora deles.']}
    conversionCards={conversionCards}
    engineeringKicker="Engenharia da presenca local"
    engineeringTitle="Mais visibilidade em Guarapari nasce de base digital forte, nao de acao isolada."
    engineeringText="Site, busca local, paginas e comunicacao precisam trabalhar juntos para que a empresa pareca mais preparada e seja escolhida com menos hesitacao."
    differentials={differentials}
    areasTitle="As frentes que mais ajudam empresas em Guarapari."
    areasText="A Scale organiza os ativos e canais que fazem mais sentido para negocios locais e sazonais."
    relatedItems={relatedItems}
    complianceTitle="Quem depende de busca local nao pode tratar a pagina como detalhe."
    complianceText="Em mercados ligados a servico, comercio e turismo, uma base digital ruim desperdiça demanda pronta para comprar."
    complianceTags={['Busca local', 'Site profissional', 'Sazonalidade', 'Google', 'Marca', 'Conversao']}
    videosTitle="Projetos que ganharam mais clareza de crescimento com a Scale"
    videosText="Quando a empresa organiza melhor sua presenca, ela passa a aproveitar com mais criterio o que o mercado local ja esta buscando."
    printsTitle="Mais presenca digital melhora a percepcao antes do primeiro contato."
    printsText="O cliente sente mais confianca quando encontra um negocio que parece preparado para atender bem desde o primeiro clique."
    teamTitle="Mais de 32 profissionais apoiando estrategia, conteudo, pagina e captacao local."
    teamText="Negocios regionais precisam de metodo para crescer com consistencia, especialmente em mercados mais sazonais."
    faqTitle="Perguntas frequentes sobre marketing digital em Guarapari."
    faqs={faqs}
    finalTitle="Se sua empresa em Guarapari ainda depende demais de acaso, temporada ou indicacao, a estrutura digital pode estar abaixo do potencial do negocio."
    finalText="A Scale ajuda a construir uma presenca mais forte para o mercado local, com mais clareza, mais confianca e mais chance de conversao."
    ctaLabel="Solicitar diagnostico"
    areasCtaLabel="Quero crescer em Guarapari"
  />
</LocalLayout>
