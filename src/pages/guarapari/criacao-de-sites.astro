---
import LocalLayout from '@layouts/LocalLayout.astro';
import ScaleLocalLanding from '@components/local/ScaleLocalLanding.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('guarapari')!;

const conversionCards = [
  { title: 'Imagem', desc: 'Em negocios ligados a servico, turismo e comercio, o site precisa passar mais confianca logo no primeiro acesso.' },
  { title: 'Mobile', desc: 'Boa parte da busca em Guarapari acontece no celular. Se a pagina nao carrega bem, a empresa perde atencao e oportunidade.' },
  { title: 'SEO', desc: 'Um site melhor ajuda a empresa a aparecer no Google com mais relevancia e a aproveitar melhor o que o mercado ja pesquisa.' },
  { title: 'Conversao', desc: 'Pagina bonita sem clareza comercial nao basta. O site precisa facilitar o entendimento e o proximo passo do cliente.' },
];

const differentials = [
  { title: 'Base pronta para busca local', desc: 'O projeto nasce com performance, organizacao de pagina e estrutura para a empresa disputar melhor visibilidade regional.' },
  { title: 'Pagina mais alinhada ao mercado', desc: 'A comunicacao precisa refletir o perfil do negocio e o jeito como o cliente escolhe servicos na cidade.' },
  { title: 'Site que sustenta crescimento', desc: 'A base digital fica preparada para SEO, campanhas e evolucoes futuras sem parecer provisoria.' },
];

const relatedItems = [
  { title: 'Hub de Guarapari', href: '/guarapari', desc: 'Visao geral da presenca digital e das frentes que ajudam empresas da cidade a crescer.', metrics: ['hub', 'mercado local'] },
  { title: 'SEO em Guarapari', href: '/guarapari/seo', desc: 'Estrutura organica para empresas que precisam aparecer melhor no Google local.', metrics: ['SEO', 'Google'] },
  { title: 'Landing pages', href: '/servicos/criacao-de-landing-pages', desc: 'Paginas especificas para servicos, campanhas e ofertas com foco mais direto em conversao.', metrics: ['campanha', 'foco'] },
  { title: 'Quanto custa criar um site', href: '/blog/quanto-custa-criar-um-site-profissional', desc: 'Guia para entender melhor escopo, investimento e impacto de um projeto bem resolvido.', metrics: ['orcamento', 'escopo'] },
];

const faqs = [
  { question: 'Um site melhor ajuda a captar cliente local e turista?', answer: 'Sim. Em Guarapari, um site forte ajuda a empresa a ser encontrada e a transmitir mais confianca para quem pesquisa antes de comprar ou visitar.' },
  { question: 'O site ja pode nascer preparado para Google?', answer: 'Sim. A estrutura tecnica e a organizacao das paginas ja entram pensando em performance, busca local e conversao.' },
  { question: 'A Scale cria site so para negocios de turismo?', answer: 'Nao. Atendemos negocios de servico, comercio, saude, gastronomia e outras operacoes que precisam de uma base digital melhor.' },
  { question: 'Posso evoluir o site depois com SEO e campanhas?', answer: 'Sim. A ideia e justamente criar uma base que sustente os proximos movimentos de crescimento digital.' },
];
---

<LocalLayout
  title="Criacao de Site em Guarapari - ES | Scale"
  description="Criacao de site em Guarapari para empresas que querem mais confianca, mais performance e uma base digital forte para SEO e conversao."
  city={city}
>
  <ScaleLocalLanding
    heroEyebrow="Criacao de sites em Guarapari para negocios que precisam parecer mais fortes."
    heroTitle="Criacao de Site em Guarapari com foco em performance, busca local e mais conversao."
    heroDescription="A Scale desenvolve sites para empresas de Guarapari que querem captar melhor cliente local e turista, com uma base digital mais profissional, rapida e preparada para crescer."
    heroMetrics={[{ value: 'Site', label: 'performance', icon: 'search' }, { value: 'Base', label: 'para crescer', icon: 'shield' }]}
    logosLabel="Empresas que ja confiaram na Scale para construir uma base digital melhor"
    problemTitle="Em uma cidade onde a pesquisa online influencia tanto a decisao, site fraco custa mais do que parece."
    problemParagraphs={['Em Guarapari, boa parte da comparacao acontece antes da visita, da reserva ou do contato. Por isso, o site precisa passar mais seguranca e clareza.', 'Uma pagina lenta, rasa ou com cara de improviso reduz o efeito de SEO, anuncio e qualquer outro canal que tente levar trafego para ela.']}
    conversionCards={conversionCards}
    engineeringKicker="Engenharia do site"
    engineeringTitle="Site bom nao e so vitrine. E a base digital que sustenta presenca e crescimento."
    engineeringText="Quando a pagina e leve, clara e orientada ao mercado, ela melhora confianca, aumenta a chance de contato e fortalece o efeito dos outros canais."
    differentials={differentials}
    areasTitle="O que a Scale conecta ao criar um site em Guarapari."
    areasText="O projeto une performance, leitura comercial, busca local e uma base pronta para evoluir com o negocio."
    relatedItems={relatedItems}
    complianceTitle="O melhor anuncio e o melhor SEO perdem forca quando chegam em uma pagina fraca."
    complianceText="Criar um site melhor nao e um capricho visual. E uma decisao que afeta visibilidade, confianca e conversao ao mesmo tempo."
    complianceTags={['Performance', 'Mobile', 'Busca local', 'Conversao', 'Confianca', 'Base digital']}
    videosTitle="Projetos que ganharam mais forca ao melhorar a base digital"
    videosText="Quando o site deixa de ser um gargalo, o negocio aproveita melhor cada acesso e passa a crescer com mais consistencia."
    printsTitle="Mais clareza e mais performance mudam a forma como a empresa e percebida."
    printsText="A presenca digital ganha mais peso quando o cliente sente que esta diante de um negocio mais bem estruturado."
    teamTitle="Mais de 32 profissionais apoiando pagina, mensagem, performance e leitura de resultado."
    teamText="Criar um site que ajude a empresa a crescer exige mais do que design. Exige criterio comercial e estrutura tecnica."
    faqTitle="Perguntas frequentes sobre criacao de sites em Guarapari."
    faqs={faqs}
    finalTitle="Se o seu site atual nao ajuda sua empresa a crescer em Guarapari, ele pode estar freando a demanda que ja existe."
    finalText="A Scale ajuda a construir uma base digital mais forte para gerar mais confianca, mais visibilidade e mais conversao."
    ctaLabel="Solicitar orcamento"
    areasCtaLabel="Quero um site melhor"
  />
</LocalLayout>
