---
import LocalLayout from '@layouts/LocalLayout.astro';
import GlassEffect from '@components/ui/GlassEffect.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('vitoria')!;

const barHeights = [100, 88, 76, 65, 55, 45, 37, 30, 37, 45, 55, 65, 76, 88, 100];
const neighborhoods = city.neighborhoods ?? ['Enseada do Sua', 'Praia do Canto', 'Jardim Camburi', 'Mata da Praia'];

const features = [
  {
    title: 'Site institucional que vende melhor',
    desc: 'Estruturamos paginas, proposta de valor, provas e chamadas para contato para transformar visita em oportunidade.',
  },
  {
    title: 'SEO tecnico desde a base',
    desc: 'O site ja nasce com velocidade, estrutura semantica, sitemap, meta tags e paginas pensadas para busca local.',
  },
  {
    title: 'Design alinhado a marca',
    desc: 'Criamos uma experiencia visual sobria, moderna e responsiva, sem depender de template generico.',
  },
  {
    title: 'Integracao com captacao',
    desc: 'Conectamos formularios, WhatsApp, eventos e paginas de servico para facilitar campanhas e mensuracao.',
  },
];

const process = [
  {
    step: '01',
    title: 'Diagnostico e briefing',
    desc: 'Entendemos negocio, publico, servicos, concorrencia em Vitoria e o papel do site dentro da captacao.',
  },
  {
    step: '02',
    title: 'Arquitetura e conteudo',
    desc: 'Organizamos paginas, hierarquia, mensagens, CTAs e termos de busca antes de partir para o visual.',
  },
  {
    step: '03',
    title: 'Design e desenvolvimento',
    desc: 'Construimos uma interface responsiva, rapida e consistente com a identidade da empresa.',
  },
  {
    step: '04',
    title: 'Publicacao e melhoria',
    desc: 'Entregamos o site com rastreamento, revisoes tecnicas e proximos passos para SEO e campanhas.',
  },
];

const metrics = [
  { value: 'SEO', label: 'Base tecnica para Google' },
  { value: 'UX', label: 'Jornada clara de contato' },
  { value: 'Core', label: 'Velocidade e estabilidade' },
  { value: 'CRM', label: 'Leads prontos para atender' },
];

const outcomes = [
  'Site responsivo para celular, tablet e desktop',
  'Paginas por servico, cidade e intencao de busca',
  'Formulario, WhatsApp e eventos de conversao configurados',
  'Estrutura pronta para Google Ads, Meta Ads e SEO local',
  'Conteudo mais claro para reduzir duvidas antes do contato',
  'Entrega com leitura de performance e proximos ajustes',
];

const faqs = [
  {
    question: 'Quanto custa criar um site em Vitoria?',
    answer:
      'Depende do tamanho do site, quantidade de paginas, complexidade visual, conteudo, integracoes e prazo. No diagnostico, a Scale monta uma proposta de escopo coerente com o objetivo comercial da empresa.',
  },
  {
    question: 'O site ja fica otimizado para aparecer no Google?',
    answer:
      'Sim. A entrega considera SEO tecnico, velocidade, estrutura de headings, metadados, sitemap e paginas com intencao de busca. Para disputar posicoes mais fortes, o ideal e manter conteudo e SEO local depois da publicacao.',
  },
  {
    question: 'A Scale atende empresas de quais bairros de Vitoria?',
    answer:
      'Atendemos empresas de toda Vitoria e Grande Vitoria, incluindo Praia do Canto, Enseada do Sua, Jardim Camburi, Mata da Praia, Bento Ferreira, Centro e outras regioes.',
  },
  {
    question: 'Vocês criam landing pages tambem?',
    answer:
      'Sim. Podemos criar site institucional completo, landing pages para campanhas ou uma estrutura hibrida com paginas de servico focadas em conversao.',
  },
];
---

<LocalLayout
  title="Criacao de Site em Vitoria | Sites Profissionais e SEO | Scale"
  description="Criacao de sites em Vitoria para empresas que precisam de um site rapido, responsivo, otimizado para Google e preparado para gerar leads."
  city={city}
>
  <style>
    @keyframes siteWave {
      0% { transform: scaleY(calc(var(--target-scale) * .34)); opacity: .22; }
      100% { transform: scaleY(var(--target-scale)); opacity: .84; }
    }

    .vc-hero-bar {
      flex: 1 0 calc(100% / 15);
      max-width: calc(100% / 15);
      height: 100%;
      background: linear-gradient(to top, #00BAFF, #1630DF 55%, transparent 100%);
      transform-origin: bottom;
      animation: siteWave 2s ease-in-out infinite alternate;
    }

    .vc-grid-bg {
      background-image:
        linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
      background-size: 44px 44px;
    }

    .vc-panel {
      border: 1px solid rgba(255,255,255,.10);
      background: linear-gradient(145deg, rgba(255,255,255,.075), rgba(255,255,255,.025));
      box-shadow: 0 24px 80px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.10);
      backdrop-filter: blur(14px);
    }

    .vc-chip {
      border: 1px solid rgba(0,186,255,.24);
      background: rgba(0,186,255,.08);
      color: rgba(255,255,255,.72);
    }

    .vc-process-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(7, 24, 39, .08);
      background: linear-gradient(135deg, #fff 0%, #f7faff 100%);
      box-shadow: 0 18px 45px rgba(7, 24, 39, .08);
      transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
    }

    .vc-process-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 4px;
      background: linear-gradient(90deg, #1630DF, #00BAFF);
    }

    .vc-process-card::after {
      content: "";
      position: absolute;
      right: -42px;
      top: -42px;
      width: 128px;
      height: 128px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(0, 186, 255, .14), transparent 68%);
      pointer-events: none;
    }

    .vc-process-card:hover {
      transform: translateY(-6px);
      border-color: rgba(0, 186, 255, .24);
      box-shadow: 0 24px 70px rgba(7, 24, 39, .13);
    }

    .vc-step {
      display: inline-flex;
      width: 46px;
      height: 46px;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(22, 48, 223, .10), rgba(0, 186, 255, .14));
      color: #1630DF;
      font-family: var(--font-heading, inherit);
      font-weight: 900;
      box-shadow: inset 0 0 0 1px rgba(22, 48, 223, .10);
    }
  </style>

  <section class="relative -mt-16 min-h-[92svh] overflow-hidden bg-[#010f1c] flex items-center">
    <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
      <div class="flex h-full w-full">
        {barHeights.map((h, i) => (
          <div
            class="vc-hero-bar"
            style={`--target-scale: ${h / 100}; animation-delay: -${Math.max(0, (i * 0.15) + Math.sin(i * 1.2) * 0.4).toFixed(2)}s;`}
          />
        ))}
      </div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,#010f1c_0%,rgba(1,15,28,.78)_24%,rgba(1,15,28,.58)_58%,#010f1c_100%)]"></div>
    </div>

    <div class="container relative z-10 py-28 md:py-36">
      <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_.95fr] gap-12 items-center">
        <div class="text-center lg:text-left">
          <div class="mb-7 inline-flex">
            <GlassEffect
              className="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-semibold !cursor-default"
              glassClass="bg-[#010f1c]/75"
              rounded="rounded-full"
            >
              <span style="color: rgba(0,186,255,.75);">+</span>
              <span style="color: rgba(255,255,255,.68);">Criacao de sites em Vitoria para empresas locais</span>
            </GlassEffect>
          </div>

          <h1
            class="font-heading font-extrabold leading-[1.03] tracking-tight mb-6 text-balance"
            style="font-size: clamp(2.7rem, 5.5vw, 5rem); background: linear-gradient(to bottom, #fff 34%, rgba(255,255,255,.62)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Sites profissionais em Vitoria para transformar visitas em contatos.
          </h1>

          <p class="text-lg md:text-xl leading-relaxed max-w-2xl mx-auto lg:mx-0 mb-9 text-white/62">
            A Scale cria sites rapidos, responsivos e otimizados para Google, com estrutura pensada para empresas que precisam apresentar valor e gerar oportunidades reais.
          </p>

          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4">
            <span class="relative inline-block overflow-hidden rounded-full p-[1.5px]">
              <span
                class="animate-spin-slow absolute pointer-events-none"
                aria-hidden="true"
                style="inset: -100%; background: conic-gradient(from 90deg at 50% 50%, #00BAFF 0%, #1630DF 50%, #00BAFF 100%);"
              ></span>
              <a
                href="/contato"
                class="relative inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-full transition-opacity hover:opacity-90"
                style="background: #010f1c; color: white;"
              >
                Solicitar diagnostico gratuito
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </span>

            <GlassEffect
              href="#processo"
              className="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white/80"
              glassClass="bg-white/5 group-hover:bg-white/10"
              rounded="rounded-full"
            >
              Ver processo
            </GlassEffect>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -right-20 -top-24 w-[30rem] h-[30rem] rounded-full bg-[#00BAFF]/20 blur-3xl" aria-hidden="true"></div>
          <div class="vc-panel rounded-2xl p-5 md:p-7 relative overflow-hidden">
            <div class="flex items-center justify-between gap-4 mb-7">
              <div>
                <p class="text-white/42 text-xs uppercase tracking-[.22em] font-bold">Site em producao</p>
                <h2 class="text-white font-heading text-2xl font-bold mt-2">Base de conversao</h2>
              </div>
              <span class="vc-chip rounded-full px-3 py-1 text-xs font-bold">Vitoria</span>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-6">
              {metrics.map((metric) => (
                <div class="rounded-xl border border-white/8 bg-white/[.045] p-4">
                  <strong class="block text-[#00BAFF] text-2xl font-heading">{metric.value}</strong>
                  <span class="text-white/45 text-xs leading-snug">{metric.label}</span>
                </div>
              ))}
            </div>

            <div class="space-y-3">
              {['Pagina inicial com proposta clara', 'Servicos organizados por intencao', 'Formulario e WhatsApp rastreados', 'SEO tecnico pronto para evoluir'].map((item, index) => (
                <div class="flex items-center gap-3 rounded-xl bg-black/18 border border-white/8 p-3">
                  <span class="w-7 h-7 rounded-full bg-[#00BAFF]/12 text-[#00BAFF] flex items-center justify-center text-xs font-bold">{index + 1}</span>
                  <span class="text-white/68 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] vc-grid-bg border-y border-white/8">
    <div class="container py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[.82fr_1.18fr] gap-10 items-start">
        <div>
          <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">Antes do layout</p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
            Um site bonito ajuda. Um site claro vende melhor.
          </h2>
          <p class="text-white/55 leading-relaxed">
            Empresas em Vitoria competem em um mercado de decisao rapida, comparacao local e busca no Google. O site precisa explicar valor, reduzir duvidas e facilitar o contato sem virar uma peca solta da operacao comercial.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            ['Mensagem confusa', 'O visitante entra, mas nao entende o diferencial, os servicos ou o proximo passo.'],
            ['Site lento no celular', 'A experiencia ruim derruba conversao e prejudica campanhas de trafego pago.'],
            ['Sem SEO local', 'A empresa existe, mas o Google nao entende bem onde atende nem quais buscas deve disputar.'],
            ['Contato sem rastreamento', 'Leads chegam pelo WhatsApp, mas a origem das oportunidades fica invisivel.'],
          ].map(([title, desc]) => (
            <div class="rounded-xl border border-white/8 bg-white/[.045] p-6">
              <h3 class="text-white font-semibold mb-2">{title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">O que a Scale entrega no site</h2>
        <p class="section-subtitle">Uma estrutura pensada para apresentacao, busca local, performance e captacao.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((item) => (
          <article class="rounded-2xl border border-edge bg-white p-6 shadow-sm">
            <h3 class="font-heading text-lg font-bold text-[#071827] mb-3">{item.title}</h3>
            <p class="text-sm text-[#425466] leading-relaxed">{item.desc}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="processo" class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Processo de criacao de site</h2>
        <p class="section-subtitle">Da estrategia a publicacao, com cada etapa conectada ao objetivo comercial.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map((item) => (
          <div class="vc-process-card rounded-2xl p-6 md:p-7 min-h-[260px] flex flex-col">
            <div class="relative z-10 flex items-center justify-between mb-8">
              <span class="vc-step">{item.step}</span>
              <span class="h-px flex-1 ml-4 bg-gradient-to-r from-[#1630DF]/20 to-transparent"></span>
            </div>
            <div class="relative z-10 mt-auto">
              <h3 class="font-heading text-xl font-bold text-[#071827] mb-3 leading-tight">{item.title}</h3>
              <p class="text-sm text-[#425466] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[.9fr_1.1fr] gap-10 items-center">
        <div>
          <p class="text-brand-primary text-xs uppercase tracking-[.22em] font-bold mb-4">SEO local em Vitoria</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-ink mb-5">
            Paginas pensadas para quem procura fornecedores na cidade.
          </h2>
          <p class="text-ink-light leading-relaxed mb-5">
            Um site local precisa mostrar servicos, area de atendimento e contexto regional. Isso ajuda tanto o cliente quanto o Google a entenderem por que sua empresa e uma boa opcao em Vitoria.
          </p>
          <a href="/servicos/criacao-de-sites" class="inline-flex items-center gap-2 text-brand-primary font-semibold hover:text-brand-secondary">
            Ver servico nacional de criacao de sites
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-3">
          {neighborhoods.map((item) => (
            <div class="rounded-xl border border-edge bg-surface-card p-5">
              <span class="block text-xs text-ink-light mb-2">Presenca local</span>
              <strong class="text-ink">{item}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] vc-grid-bg">
    <div class="container py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[.9fr_1.1fr] gap-10 items-center">
        <div>
          <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">Depois da publicacao</p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
            O site vira a base para SEO, anuncios e atendimento.
          </h2>
          <p class="text-white/58 leading-relaxed">
            A entrega nao precisa parar no layout. Com rastreamento e paginas bem estruturadas, sua empresa consegue medir origem dos leads, testar campanhas e evoluir conteudo com mais clareza.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {outcomes.map((item) => (
            <div class="rounded-xl border border-white/8 bg-white/[.045] p-4 flex items-start gap-3">
              <span class="w-7 h-7 rounded-full bg-[#00BAFF]/12 text-[#00BAFF] flex items-center justify-center shrink-0 mt-0.5" aria-hidden="true">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <span class="text-white/70 text-sm leading-relaxed">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <FAQ title="Perguntas frequentes sobre criacao de sites em Vitoria" items={faqs} />

  <section class="section text-center bg-surface-subtle">
    <div class="container-narrow">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-ink mb-4">Quer um site mais bonito, rapido e preparado para gerar leads?</h2>
      <p class="text-ink-light mb-8">No diagnostico gratuito, avaliamos seu site atual, concorrentes locais e oportunidades para uma nova estrutura digital.</p>
      <a href="/contato" class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-white transition-opacity hover:opacity-85" style="background: linear-gradient(135deg, #1630DF, #00BAFF);">
        Solicitar diagnostico gratuito
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</LocalLayout>
