        <script is:inline>
          (function initScrollDrivenPipelineAnimation() {
            const cards = document.querySelectorAll('.scale-journey-card');
            const nodes = document.querySelectorAll('.scale-pipeline-node');
            const hub = document.querySelector('.scale-pipeline-hub');
            const phone = document.querySelector('.scale-pipeline-phone-mockup');
            const section = document.querySelector('.scale-pipeline-section');
            if (cards.length === 0 || nodes.length === 0 || !section) return;

            let whatsappTriggered = false;
            let ticking = false;

            function updateScrollAnimation() {
              if (window.innerWidth > 768) {
                // Desktop remains normal static cards
                cards.forEach((card, idx) => {
                  card.classList.remove('active');
                  const bar = card.querySelector('.scale-journey-card__progress-bar');
                  if (bar) bar.style.width = '0%';
                  const beam = document.getElementById('scale-beam-v-' + idx);
                  if (beam) beam.classList.remove('active');
                  nodes[idx].classList.remove('active');
                });
                if (hub) hub.classList.remove('active');
                if (phone) phone.classList.remove('active');
                return;
              }

              const grid = document.querySelector('.scale-journey-grid');
              if (!grid) return;

              const rect = grid.getBoundingClientRect();
              const viewportHeight = window.innerHeight;
              const gridTop = rect.top + window.scrollY;
              const gridHeight = rect.height;

              // Safe Scroll Range Calculation:
              // Start: when the top of the cards grid enters the middle-bottom viewport (75% from top)
              // End: when the bottom of the cards grid leaves near top (15% from top)
              const startY = gridTop - viewportHeight * 0.75;
              const endY = gridTop + gridHeight - viewportHeight * 0.15;
              const totalRange = endY - startY;

              const currentScroll = window.scrollY;
              let progress = (currentScroll - startY) / totalRange;
              progress = Math.max(0, Math.min(1, progress));

              // Active range mapping with deadzones
              const activeRangeStart = 0.08; // 8% deadzone at entry so first card enters clean
              const activeRangeEnd = 0.92;   // 8% deadzone at exit
              const usableRange = activeRangeEnd - activeRangeStart;
              const stepSize = usableRange / 4; // 21% per card

              cards.forEach((card, idx) => {
                const bar = card.querySelector('.scale-journey-card__progress-bar');
                const stepStart = activeRangeStart + idx * stepSize;
                const stepEnd = activeRangeStart + (idx + 1) * stepSize;

                let stepProgress = 0;
                if (progress > stepEnd) {
                  stepProgress = 1;
                } else if (progress < stepStart) {
                  stepProgress = 0;
                } else {
                  // Map progress inside this specific step range to 0..1
                  stepProgress = (progress - stepStart) / stepSize;
                }

                if (bar) {
                  bar.style.transition = 'none'; // absolute real-time scroll sync
                  bar.style.width = (stepProgress * 100) + '%';
                }

                // Determine active step based on scroll segment
                const isActive = progress >= stepStart && progress < stepEnd;
                const beam = document.getElementById('scale-beam-v-' + idx);

                if (isActive) {
                  card.classList.add('active');
                  nodes[idx].classList.add('active');
                  if (beam) beam.classList.add('active');

                  // Highlight phone mockup at WhatsApp step (Step 4)
                  if (idx === 3) {
                    if (phone) phone.classList.add('active');
                    if (!whatsappTriggered) {
                      whatsappTriggered = true;
                      if (typeof window.__triggerImmediateWhatsAppNotification === 'function') {
                        window.__triggerImmediateWhatsAppNotification();
                      }
                    }
                  } else {
                    if (phone) phone.classList.remove('active');
                    whatsappTriggered = false;
                  }
                } else {
                  card.classList.remove('active');
                  nodes[idx].classList.remove('active');
                  if (beam) beam.classList.remove('active');
                }
              });

              // Pre-scroll state: ensure everything is completely static & inactive when entering view
              if (progress < activeRangeStart) {
                cards.forEach((card, idx) => {
                  card.classList.remove('active');
                  nodes[idx].classList.remove('active');
                  const beam = document.getElementById('scale-beam-v-' + idx);
                  if (beam) beam.classList.remove('active');
                });
                if (phone) phone.classList.remove('active');
                whatsappTriggered = false;
              }

              // Pulse the hub when data flows past stage 1
              if (hub) {
                if (progress > activeRangeStart + stepSize) {
                  hub.classList.add('active');
                } else {
                  hub.classList.remove('active');
                }
              }

              ticking = false;
            }

            // Scroll listener with requestAnimationFrame throttling for perfect 60fps scrolling
            window.addEventListener('scroll', () => {
              if (!ticking) {
                window.requestAnimationFrame(updateScrollAnimation);
                ticking = true;
              }
            }, { passive: true });

            // Trigger once initially
            updateScrollAnimation();
          })();
        </script>
      </div>
    </section>

