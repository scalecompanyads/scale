        <script is:inline>
          (function updatePhoneTime() {
            function run() {
              const el = document.getElementById('scale-live-phone-time');
              if (!el) return;
              const now = new Date();
              const hours = String(now.getHours()).padStart(2, '0');
              const minutes = String(now.getMinutes()).padStart(2, '0');
              el.textContent = hours + ':' + minutes;
            }
            run();
            setInterval(run, 60000);
          })();

          (function liveNotificationLoop() {
            const notificationTrigger = document.querySelector('.scale-pipeline-phone-mockup');
            // Expose a public trigger hook for instant activation when step 4 is highlighted
            window.__triggerImmediateWhatsAppNotification = function() {
              if (typeof addNextNotification === 'function') {
                startNotificationLoop();
                addNextNotification();
              }
            };
            const notificationsPool = [
              { sender: 'Lucas Oliveira • Inventário', message: 'Olá Dr., vi seu anúncio no Google e gostaria de fazer uma consulta. Meu pai faleceu e deixou dois imóveis...' },
              { sender: 'Cláudia Ramos • Família', message: 'Preciso de uma advogada especialista em divórcio litigioso para me orientar sobre a partilha de bens...' },
              { sender: 'Mariana Silva • Contratos', message: 'Gostaria de agendar uma análise de contrato de prestação de serviços empresariais para amanhã...' },
              { sender: 'Roberto Dias • Criminal', message: 'Preciso de um advogado criminalista urgente para acompanhamento em delegacia nas próximas horas...' },
              { sender: 'Pedro Santos • Previdenciário', message: 'Olá, gostaria de saber se tenho direito a me aposentar por tempo de contribuição especial...' },
              { sender: 'Felipe Costa • Trabalhista', message: 'Fui demitido sem justa causa após 5 anos de empresa e gostaria de calcular minhas verbas rescisórias...' },
              { sender: 'Larissa Lima • Imobiliário', message: 'Olá Dr., preciso de ajuda com um atraso na entrega das chaves do meu apartamento comprado na planta...' },
              { sender: 'Scale Ads • Google Ads', message: 'Novo lead qualificado capturado na campanha de Advocacia Criminal.' },
              { sender: 'Scale Ads • Meta Ads', message: 'Campanha de Autoridade gerou nova conversa iniciada no WhatsApp.' }
            ];

            const container = document.querySelector('.scale-phone-notifications');
            if (!container) return;

            let poolIndex = 0;
            let notificationLoopStarted = false;
            let notificationIntervalId = null;
            let notificationStopTimeoutId = null;
            const notificationLoopDurationMs = 16000;

            function createNotificationElement(data) {
              const notif = document.createElement('article');
              notif.className = 'scale-phone-notification';
              
              const isScale = data.sender.startsWith('Scale');
              const iconSvg = isScale 
                ? '<svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>'
                : '<svg viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M19.05 4.91A9.82 9.82 0 0 0 12.03 2c-5.46 0-9.9 4.44-9.9 9.9 0 1.74.45 3.43 1.31 4.92L2 22l5.32-1.39a9.87 9.87 0 0 0 4.71 1.2h.01c5.46 0 9.9-4.44 9.9-9.9a9.86 9.86 0 0 0-2.89-7ZM12.04 20.14h-.01a8.2 8.2 0 0 1-4.18-1.14l-.3-.18-3.16.83.84-3.08-.2-.32a8.18 8.18 0 0 1-1.26-4.35c0-4.52 3.68-8.2 8.21-8.2 2.19 0 4.24.85 5.79 2.4a8.14 8.14 0 0 1 2.4 5.8c0 4.52-3.68 8.2-8.13 8.24Zm4.5-6.16c-.25-.13-1.47-.73-1.7-.82-.23-.08-.39-.12-.56.13-.16.24-.64.81-.78.97-.14.16-.28.18-.53.06-.25-.13-1.04-.38-1.98-1.22-.73-.65-1.22-1.45-1.36-1.69-.14-.24-.01-.37.11-.5.11-.11.25-.28.37-.42.13-.14.17-.24.25-.4.08-.16.04-.3-.02-.42-.07-.13-.56-1.35-.77-1.85-.2-.48-.4-.41-.56-.42h-.48c-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.31.98 2.47c.12.16 1.69 2.57 4.09 3.61.57.25 1.02.4 1.37.5.58.18 1.1.15 1.52.09.46-.07 1.47-.6 1.67-1.18.21-.58.21-1.08.15-1.18-.06-.1-.22-.16-.47-.29Z"/></svg>';

              const appName = isScale ? 'Scale Ads' : 'WhatsApp';
              const appColorClass = isScale ? 'scale-notif-app-icon--scale' : '';

              notif.innerHTML = `
                <div class="scale-notif-header">
                  <div class="scale-notif-app">
                    <div class="scale-notif-app-icon ${appColorClass}">
                      ${iconSvg}
                    </div>
                    <span>${appName}</span>
                  </div>
                  <span class="scale-notif-time">Agora</span>
                </div>
                <div class="scale-notif-body">
                  <h4 class="scale-notif-sender">${data.sender}</h4>
                  <p class="scale-notif-message">"${data.message}"</p>
                </div>
              `;
              return notif;
            }

            function addNextNotification() {
              const data = notificationsPool[poolIndex % notificationsPool.length];
              poolIndex++;

              const notifElement = createNotificationElement(data);
              container.appendChild(notifElement);

              // Stagger anim to show
              requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                  notifElement.classList.add('show');
                });
              });

              // Prune old notifications if more than 3
              const activeNotifs = container.querySelectorAll('.scale-phone-notification:not(.fade-out)');
              if (activeNotifs.length > 3) {
                const oldest = activeNotifs[0];
                oldest.classList.add('fade-out');
                setTimeout(() => {
                  oldest.remove();
                }, 500);
              }

              // Smoothly scroll down
              setTimeout(() => {
                container.scrollTo({
                  top: container.scrollHeight,
                  behavior: 'smooth'
                });
              }, 100);
            }

            function startNotificationLoop() {
              if (notificationLoopStarted) return;
              notificationLoopStarted = true;

              setTimeout(addNextNotification, 120);
              setTimeout(addNextNotification, 820);
              notificationIntervalId = window.setInterval(addNextNotification, 2400);
              notificationStopTimeoutId = window.setTimeout(() => {
                if (notificationIntervalId !== null) {
                  window.clearInterval(notificationIntervalId);
                  notificationIntervalId = null;
                }
              }, notificationLoopDurationMs);
            }

            if ('IntersectionObserver' in window && notificationTrigger) {
              const notificationObserver = new IntersectionObserver((entries) => {
                const hasVisibleEntry = entries.some((entry) => entry.isIntersecting && entry.intersectionRatio >= 0.35);
                if (!hasVisibleEntry) return;
                startNotificationLoop();
                notificationObserver.disconnect();
              }, {
                threshold: [0.35]
              });

              notificationObserver.observe(notificationTrigger);
            } else {
              startNotificationLoop();
            }
          })();
        </script>

