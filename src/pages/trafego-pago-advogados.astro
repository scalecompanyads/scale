    /* ==========================================================================
       SEÇÃO MÁQUINA DE AQUISIÇÃO (ENTREGÁVEIS)
       ========================================================================== */
    .scale-machine-section {
      position: relative;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      background: linear-gradient(180deg, #010000 0%, #05070a 100%);
    }

    .scale-machine-section .scale-section-heading h2 span {
      background: linear-gradient(90deg, #0077ff 0%, #00d2ff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .scale-machine-layout {
      margin-top: 2rem;
    }



    /* Grade de Entregáveis (9 Itens) */
    .scale-machine-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1.25rem;
    }

    .scale-machine-card {
      position: relative;
      padding: 1.6rem 1.5rem;
      border-radius: 1.2rem;
      border: 1px solid rgba(255, 255, 255, 0.05);
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.035) 0%, rgba(255, 255, 255, 0.008) 100%);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
      transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
    }

    .scale-machine-card:hover {
      transform: translateY(-3px);
      border-color: rgba(0, 119, 255, 0.25);
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.05) 0%, rgba(0, 119, 255, 0.015) 100%);
      box-shadow: 0 20px 45px rgba(0, 119, 255, 0.05);
    }

    .scale-machine-card__header {
      display: flex;
      align-items: center;
      gap: 0.9rem;
      margin-bottom: 0.75rem;
    }

    .scale-machine-card h3 {
      margin: 0;
      color: #ffffff;
      font-size: 1.15rem;
      font-weight: 800;
      line-height: 1.2;
    }

    .scale-machine-card p {
      margin: 0;
      color: rgba(255, 255, 255, 0.65);
      font-size: 0.88rem;
      line-height: 1.6;
    }

    /* Icones Dinâmicos */
    .scale-machine-card__icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 0.65rem;
      flex: 0 0 auto;
    }

    .scale-machine-card__icon--blue {
      background: rgba(0, 119, 255, 0.1);
      color: #0077ff;
      border: 1px solid rgba(0, 119, 255, 0.15);
    }

    .scale-machine-card__icon--green {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
      border: 1px solid rgba(16, 185, 129, 0.15);
    }

    .scale-machine-card__icon--purple {
      background: rgba(139, 92, 246, 0.1);
      color: #8b5cf6;
      border: 1px solid rgba(139, 92, 246, 0.15);
    }

    .scale-machine-card__icon--orange {
      background: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
      border: 1px solid rgba(245, 158, 11, 0.15);
    }

    /* Responsividade */
    @media (max-width: 1024px) {
      .scale-machine-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .scale-machine-grid {
        grid-template-columns: 1fr;
        gap: 1rem;
      }
      .scale-machine-card {
        padding: 1.4rem;
      }
    }

    /* ==========================================================================
       SEÇÃO MÉTODO SCALE
       ========================================================================== */
    .scale-method-section {
      position: relative;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      background: linear-gradient(180deg, #05070a 0%, #010000 100%);
    }

    .scale-method-section .scale-section-heading h2 span {
      background: linear-gradient(90deg, #0077ff 0%, #00d2ff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .scale-method-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.5rem;
      margin-top: 3.5rem;
    }

    .scale-method-card {
      position: relative;
      display: flex;
      flex-direction: column;
      padding: 2.2rem 2rem;
      border-radius: 1.5rem;
      border: 1px solid rgba(255, 255, 255, 0.05);
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.035) 0%, rgba(255, 255, 255, 0.008) 100%);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
      transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), border-color 0.3s ease, background 0.3s ease;
    }

    .scale-method-card:hover {
      transform: translateY(-5px);
      border-color: rgba(0, 119, 255, 0.3);
      background: linear-gradient(145deg, rgba(255, 255, 255, 0.05) 0%, rgba(0, 119, 255, 0.02) 100%);
      box-shadow: 
        0 25px 55px rgba(0, 119, 255, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .scale-method-card__top {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
    }

    .scale-method-card__num {
      font-size: 2.5rem;
      font-weight: 950;
      line-height: 1;
      font-family: Inter, system-ui, sans-serif;
      background: linear-gradient(180deg, #0077ff 0%, rgba(0, 119, 255, 0.2) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      letter-spacing: -0.04em;
    }

    .scale-method-card h3 {
      margin: 0;
      color: #ffffff;
      font-size: 1.35rem;
      font-weight: 800;
      line-height: 1.2;
    }

    .scale-method-card p {
      margin: 0 0 1.75rem;
      color: rgba(255, 255, 255, 0.65);
      font-size: 0.94rem;
      line-height: 1.65;
    }

    .scale-method-card__list {
      margin: auto 0 0 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 0.8rem;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding-top: 1.5rem;
    }

    .scale-method-card__list li {
      display: flex;
      align-items: flex-start;
      gap: 0.65rem;
    }

    .scale-method-check {
      color: #00d2ff;
      flex: 0 0 auto;
      margin-top: 0.25rem;
    }

    .scale-method-card__list span {
      color: rgba(255, 255, 255, 0.85);
      font-size: 0.88rem;
      line-height: 1.5;
      font-weight: 600;
    }

    /* Responsividade */
    @media (max-width: 1024px) {
      .scale-method-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .scale-method-grid {
        grid-template-columns: 1fr;
        gap: 1.25rem;
        margin-top: 2.5rem;
      }
      .scale-method-card {
        padding: 1.8rem 1.6rem;
      }
      .scale-method-card__num {
        font-size: 2.2rem;
      }
    }

    /* ==========================================================================
       SEÇÃO TESTEMUNHOS DESTAQUES (RESULTADOS REAIS)
       ========================================================================== */
    .scale-spotlight-section {
      position: relative;
      border-top: 1px solid rgba(255, 255, 255, 0.04);
      background: linear-gradient(180deg, #010000 0%, #05070a 100%);
      padding: 7rem 0 5rem;
    }

    .scale-spotlight-section .scale-section-heading h2 span {
      background: linear-gradient(90deg, #0077ff 0%, #00d2ff 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    /* Menu de Abas (Tabs) */
    .scale-spotlight-tabs-wrapper {
      position: relative;
      width: 100%;
      overflow-x: auto;
      padding-bottom: 0.75rem;
      margin-bottom: 3.5rem;
      scrollbar-width: none; /* Firefox */
    }

    .scale-spotlight-tabs-wrapper::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }

    .scale-spotlight-tabs {
      display: flex;
      gap: 0.75rem;
      width: max-content;
      margin: 0 auto;
      padding: 0 1rem;
    }

    .scale-spotlight-tab {
      padding: 0.85rem 1.45rem;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(255, 255, 255, 0.02);
      color: rgba(255, 255, 255, 0.65);
      font-size: 0.88rem;
      font-weight: 700;
      cursor: pointer;
      white-space: nowrap;
      transition: all 0.25s ease;
      font-family: Inter, system-ui, sans-serif;
    }

    .scale-spotlight-tab:hover {
      border-color: rgba(0, 119, 255, 0.3);
      color: #ffffff;
      background: rgba(0, 119, 255, 0.04);
    }

    .scale-spotlight-tab.active {
      border-color: rgba(0, 119, 255, 0.45);
      background: #0077ff;
      color: #ffffff;
      box-shadow: 
        0 10px 25px rgba(0, 119, 255, 0.22),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    /* Container de Slides */
    .scale-spotlight-container {
      position: relative;
      width: 100%;
    }

    .scale-spotlight-content {
      display: none;
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .scale-spotlight-content.active {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      justify-items: center;
      text-align: center;
      opacity: 1;
      transform: translateY(0);
    }

    /* Lado Esquerdo - Celular Mockup */
    .scale-spotlight-visual-side {
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
    }

    .scale-phone-mockup {
      position: relative;
      width: 100%;
      max-width: 377px;
      height: auto;
      border-radius: 2.5rem;
      border: 8px solid #0f131a;
      background: #000000;
      box-shadow: 
        0 30px 65px rgba(0, 0, 0, 0.6),
        0 0 0 1px rgba(255, 255, 255, 0.08);
      overflow: hidden;
      cursor: pointer;
      transition: border-color 0.3s ease, box-shadow 0.3s ease;
    }

    .scale-phone-mockup:hover {
      border-color: #1a2230;
