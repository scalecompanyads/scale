const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': `${canonical}#service`,
  name: 'Tráfego Pago Especializado para Escritórios de Advocacia',
  alternateName: 'Marketing juridico para escritorios de advocacia',
  description: pageDescription,
  url: canonical,
  provider: {
    '@id': organizationId,
  },
  isPartOf: {
    '@id': websiteId,
  },
  areaServed: {
    '@type': 'Country',
    name: 'Brasil',
  },
  serviceType: 'Estruturação de Google Ads, Meta Ads e landing pages para escritórios de advocacia',
  audience: {
    '@type': 'Audience',
    audienceType: 'Advogados e escritórios de advocacia',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Áreas jurídicas atendidas',
    itemListElement: legalAreas.map((area) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: `Tráfego pago para ${area.name}`,
        description: area.metaDescription,
      },
    })),
  },
  brand: {
    '@type': 'Brand',
    name: brand.name,
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': `${canonical}#faq`,
  isPartOf: {
    '@id': websiteId,
  },
  mainEntity: tofFaqs.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<BaseLayout
  title="Tráfego Pago Especializado para Escritórios de Advocacia | Scale"
  description={pageDescription}
  canonical={canonical}
  noindex={true}
  showHeader={false}
  showFooter={false}
  showGlassFilter={false}
  showPreloader={false}
  showLeadCaptureModal={false}
  includeFonts={false}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <link slot="head" rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript slot="head"><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" /></noscript>
  <!-- Google Tag Manager -->
  <script slot="head">(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-KS5L52P9');</script>
  <!-- End Google Tag Manager -->
  <style slot="head" is:global>
    html.trafego-advogados-page #header-outer,
    html.trafego-advogados-page #mobile-panel,
    html.trafego-advogados-page #nav-overlay {
      display: none !important;
    }

    #main-content {
      padding-top: 0 !important;
    }

    /* Oculta o preloader nesta página */
    html.trafego-advogados-page #preloader {
      display: none !important;
    }

    /* Mobile Fixed Header */
    .scale-mobile-header {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 9999;
      height: 56px;
      padding: 0 16px;
      align-items: center;
      justify-content: space-between;
      background: rgba(6, 8, 16, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    @media (max-width: 768px) {
      .scale-mobile-header {
        display: flex;
      }
      .paid-advogados {
        padding-top: 56px;
      }
    }

    .paid-advogados .scale-v3-hero-shell .nav-menu {
      display: none;
    }

    .paid-advogados .scale-v3-hero-shell .hero-nav {
      justify-content: center;
    }

    /* ACTIVE STYLES FOR JOURNEY PIPELINE LOOP ANIMATION */
    /* Desktop (Normal Static Cards) */
    @media (min-width: 769px) {
      .scale-journey-card {
        opacity: 1 !important;
        transform: none !important;
        cursor: default !important;
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        box-shadow: 0 20px 44px rgba(0, 0, 0, 0.24) !important;
      }
      .scale-step-visual-box {
        display: none !important;
      }
      .scale-journey-card__progress-track {
        display: none !important;
      }
      .scale-pipeline-node {
        cursor: default !important;
      }
    }

    /* Mobile (Active Animated Scroll cards) */
    @media (max-width: 768px) {
      .scale-journey-card {
        display: grid;
        gap: 1rem;
        padding: 1.35rem;
        border-radius: 1rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        background:
          linear-gradient(180deg, rgba(255, 255, 255, 0.03), rgba(255, 255, 255, 0.012)),
          #090c12;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        position: relative;
        overflow: hidden;
        cursor: pointer;
        opacity: 0.35;
        transform: scale(0.97);
        transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .scale-journey-card:hover {
        opacity: 0.7;
        transform: translateY(-2px) scale(0.99);
        border-color: rgba(255, 255, 255, 0.12);
      }

      .scale-journey-card.active {
        opacity: 1;
        transform: translateY(-4px) scale(1.02);
        border-color: rgba(0, 119, 255, 0.45);
        background: linear-gradient(180deg, rgba(0, 119, 255, 0.05) 0%, rgba(9, 12, 18, 0.85) 100%), #090c12;
        box-shadow: 
          0 20px 44px rgba(0, 0, 0, 0.35),
          0 0 25px rgba(0, 119, 255, 0.16);
      }

      .scale-journey-card__progress-track {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: rgba(255, 255, 255, 0.04);
        border-bottom-left-radius: 1rem;
        border-bottom-right-radius: 1rem;
        overflow: hidden;
      }

      .scale-journey-card__progress-bar {
        width: 0%;
        height: 100%;
        background: linear-gradient(90deg, #0f6fff 0%, #00d2ff 100%);
      }

      .scale-pipeline-node {
        cursor: pointer;
        transition: all 0.4s ease;
      }

      .scale-pipeline-node__icon {
        transition: border-color 0.4s ease, transform 0.4s ease, box-shadow 0.4s ease, background 0.4s ease;
      }

      .scale-pipeline-node__icon svg {
        transition: stroke 0.4s ease, filter 0.4s ease;
      }

      .scale-pipeline-node.active .scale-pipeline-node__icon {
        border-color: #0077ff;
        background: linear-gradient(180deg, #122138 0%, #08101a 100%);
        box-shadow: 0 0 20px rgba(0, 119, 255, 0.4), inset 0 0 10px rgba(0, 119, 255, 0.2);
        transform: scale(1.1) translateY(-3px);
      }

      .scale-pipeline-node.active .scale-pipeline-node__icon svg {
        stroke: #80b6ff;
        filter: drop-shadow(0 0 3px rgba(0, 119, 255, 0.8));
      }

      .scale-pipeline-node__label {
        transition: color 0.4s ease, text-shadow 0.4s ease;
      }

      .scale-pipeline-node.active .scale-pipeline-node__label {
        color: #80b6ff;
        text-shadow: 0 0 8px rgba(0, 119, 255, 0.4);
        font-weight: 800;
      }

      .scale-pipeline-beam-svg.active {
        stroke: #00d2ff !important;
        stroke-width: 0.62 !important;
        filter: drop-shadow(0 0 4px rgba(0, 210, 255, 0.85)) !important;
      }

      .scale-pipeline-hub {
        transition: all 0.5s ease;
      }

      .scale-pipeline-hub.active {
        transform: scale(1.08);
      }

      .scale-pipeline-hub.active .scale-pipeline-hub__icon {
        border-color: #0077ff;
        box-shadow: 0 0 20px rgba(0, 119, 255, 0.4);
        background: linear-gradient(135deg, #122138 0%, #08101a 100%);
      }

      .scale-pipeline-hub.active svg {
        stroke: #80b6ff;
        filter: drop-shadow(0 0 3px rgba(0, 119, 255, 0.6));
      }

      .scale-pipeline-phone-mockup {
        transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .scale-pipeline-phone-mockup.active {
        transform: translateY(-5px);
      }

      .scale-pipeline-phone-mockup.active .scale-phone-device {
        box-shadow: 
          0 40px 100px rgba(0, 0, 0, 0.75),
          0 0 0 2px rgba(255, 255, 255, 0.05),
          0 0 45px rgba(0, 119, 255, 0.35);
        border-color: #1e293b;
      }

      .scale-step-visual-box {
        width: 100%;
        height: 90px;
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px;
        margin: 8px 0 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }

      /* STEP 1: Google Search bar mockup */
      .scale-mock-search-bar {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.07);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 99px;
        padding: 6px 14px;
        width: 85%;
        box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.3);
      }
      .scale-mock-search-text {
        display: inline-block;
        white-space: nowrap;
        overflow: hidden;
        width: 0;
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.72rem;
        font-weight: 600;
      }
      .scale-journey-card.active .scale-mock-search-text {
        animation: mock-type 4.2s steps(20) infinite;
      }
      @keyframes mock-type {
        0% { width: 0; }
        45%, 100% { width: 110px; }
      }
      .scale-mock-search-cursor {
        color: #0077ff;
        font-weight: 700;
        font-size: 0.72rem;
        margin-left: 1px;
        animation: cursor-blink 0.8s infinite;
      }
      @keyframes cursor-blink {
        50% { opacity: 0; }
      }

      /* STEP 2: Patrocinado / Google Ads mockup */
      .scale-mock-ad-result {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 3px;
        width: 85%;
        position: relative;
      }
      .scale-mock-ad-badge {
        font-size: 0.58rem;
        font-weight: 750;
        color: rgba(255,255,255,0.4);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 3px;
        padding: 1px 4px;
        background: rgba(255,255,255,0.03);
      }
      .scale-mock-ad-title {
        font-size: 0.7rem;
        font-weight: 700;
        color: #58a6ff;
        transition: color 0.3s ease;
      }
      .scale-mock-ad-desc {
        font-size: 0.62rem;
        color: rgba(255,255,255,0.55);
      }
      .scale-mock-click-cursor {
        position: absolute;
        bottom: -22px;
        right: 5px;
        transform: translate(0, 0);
        pointer-events: none;
      }
      .scale-journey-card.active .scale-mock-click-cursor {
        animation: mock-click 4.2s infinite;
      }
      @keyframes mock-click {
        0% { transform: translate(0, 0); }
        30% { transform: translate(-30px, -18px); }
        40% { transform: translate(-30px, -18px) scale(0.8); }
