---
/**
 * Cases — /cases
 * Portfólio de resultados: sites criados, campanhas, resultados de SEO
 */
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Cases de Sucesso | Scale"
  description="Conheca cases da Scale em SEO, trafego pago, sites e geracao de demanda para empresas do Espirito Santo e de outras regioes."
>
  <section class="section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">Portfólio</span>
        <h1 class="section-title">Cases de Sucesso</h1>
        <p class="section-subtitle">
          Resultados reais para empresas do Espírito Santo.
        </p>
      </div>

      <!-- TODO: adicionar cards de cases após acumular resultados -->
      <p class="text-center text-ink-light py-16">
        Cases em breve. Resultados em construção.
      </p>
    </div>
  </section>
</BaseLayout>
