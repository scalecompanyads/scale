---
import LocalLayout from '@layouts/LocalLayout.astro';
import ScaleLocalLanding from '@components/local/ScaleLocalLanding.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('cariacica')!;

const conversionCards = [
  { title: 'Potencial', desc: 'Cariacica tem mercado grande e menos maturidade digital em muitos segmentos. Isso abre espaco para quem se posiciona melhor.' },
  { title: 'Presenca', desc: 'Empresas locais perdem demanda quando dependem so de indicacao, Instagram solto ou um site que nao sustenta confianca.' },
  { title: 'Google', desc: 'Boa parte da comparacao acontece em buscas locais. Quem aparece com mais clareza tende a receber mais atencao.' },
  { title: 'Direcao', desc: 'Site, trafego e posicionamento precisam trabalhar em conjunto para o marketing deixar de parecer custo sem previsao.' },
];

const differentials = [
  { title: 'Leitura real do mercado de Cariacica', desc: 'A estrategia considera comportamento local, bairros relevantes e a forma como a empresa compete por atencao na regiao.' },
  { title: 'Base digital mais forte', desc: 'A Scale organiza o que a empresa comunica, onde ela aparece e como o cliente encontra o proximo passo.' },
  { title: 'Crescimento menos improvisado', desc: 'A ideia e criar uma operacao mais clara, medivel e menos dependente de tentativa e erro.' },
];

const relatedItems = [
  { title: 'Criacao de sites em Cariacica', href: '/cariacica/criacao-de-sites', desc: 'Sites mais fortes para melhorar confianca, presenca digital e conversao local.', metrics: ['site', 'conversao'] },
  { title: 'Trafego pago em Cariacica', href: '/cariacica/trafego-pago', desc: 'Google Ads e Meta Ads para acelerar demanda com mais criterio e menos desperdicio.', metrics: ['leads', 'retorno'] },
  { title: 'Consultoria SEO', href: '/servicos/consultoria-seo', desc: 'Crescimento organico para empresas que querem depender menos de indicacao e mais de busca.', metrics: ['Google', 'SEO'] },
  { title: 'Landing pages', href: '/servicos/criacao-de-landing-pages', desc: 'Paginas focadas em servicos e campanhas para melhorar clareza de oferta e conversao.', metrics: ['pagina', 'foco'] },
];

const faqs = [
  { question: 'A Scale atende empresas de Cariacica?', answer: 'Sim. Atendemos empresas de Cariacica com leitura do mercado local e foco em construir uma presenca digital mais forte para a regiao.' },
  { question: 'Cariacica e um bom mercado para investir em marketing digital?', answer: 'Sim. A cidade tem alto volume comercial e, em muitos segmentos, ainda existe bastante espaco para crescer com uma operacao digital melhor estruturada.' },
  { question: 'Qual servico costuma funcionar melhor em Cariacica?', answer: 'Depende do momento do negocio. Algumas empresas precisam primeiro fortalecer o site, outras ganham mais ao ativar midia paga ou organizar SEO local.' },
  { question: 'Como saber por onde comecar?', answer: 'O diagnostico avalia seu posicionamento, sua presenca atual e os gargalos de captacao para indicar a prioridade mais coerente.' },
];
---

<LocalLayout
  title="Agencia de Marketing Digital em Cariacica - ES | Scale"
  description="Agencia de marketing digital em Cariacica para empresas que querem crescer com mais presenca em site, Google, SEO e canais de aquisicao."
  city={city}
>
  <ScaleLocalLanding
    heroEyebrow="Agencia de marketing digital em Cariacica com foco em mercado local."
    heroTitle="Agencia de Marketing Digital em Cariacica para empresas que querem crescer com mais estrutura."
    heroDescription="A Scale ajuda empresas de Cariacica a organizarem site, posicionamento, SEO e aquisicao para transformar presenca digital em mais visibilidade, mais confianca e mais demanda."
    heroMetrics={[{ value: 'Cariacica', label: 'mercado local', icon: 'search' }, { value: 'Scale', label: 'metodo', icon: 'shield' }]}
    logosLabel="Empresas que ja confiaram na Scale para crescer com mais clareza"
    problemTitle="Cariacica tem mercado e demanda. O que muitas empresas nao tem ainda e estrutura digital a altura."
    problemParagraphs={['Quando a empresa comunica mal, aparece pouco ou parece improvisada no digital, ela perde espaco para concorrentes que nem sempre entregam melhor.', 'Por isso, a estrategia certa aqui nao e fazer mais do mesmo. E organizar uma base mais forte para competir melhor por atencao e confianca.']}
    conversionCards={conversionCards}
    engineeringKicker="Engenharia da presenca local"
    engineeringTitle="Mais resultado em Cariacica vem de pagina forte, canal certo e proposta clara."
    engineeringText="O marketing funciona melhor quando a empresa sabe como quer ser percebida, onde deve aparecer e o que precisa acontecer depois do clique."
    differentials={differentials}
    areasTitle="As principais frentes de crescimento digital em Cariacica."
    areasText="A Scale monta a base e os canais certos para o momento do negocio, sem empilhar solucao sem prioridade."
    relatedItems={relatedItems}
    complianceTitle="Antes de investir mais, vale entender o que esta travando visibilidade e conversao."
    complianceText="Em muitos casos, o problema nao e falta de esforco. E falta de estrutura para o mercado perceber mais valor na empresa."
    complianceTags={['Site', 'Google', 'Posicionamento', 'Aquisicao', 'Prioridade', 'Leitura comercial']}
    videosTitle="Projetos que destravaram crescimento com mais organizacao"
    videosText="Quando existe metodo, a empresa entende melhor o papel de cada canal e para de desperdiçar energia em acao sem direcao."
    printsTitle="Mais clareza operacional melhora a percepcao de valor da empresa."
    printsText="Pagina, estrategia e comunicacao bem alinhadas ajudam o mercado a levar o negocio mais a serio no primeiro contato."
    teamTitle="Mais de 32 profissionais apoiando estrategia, pagina, midia e acompanhamento comercial."
    teamText="Crescimento consistente vem de coordenacao, e nao de sorte ou de tentativa isolada."
    faqTitle="Perguntas frequentes sobre marketing digital em Cariacica."
    faqs={faqs}
    finalTitle="Se sua empresa em Cariacica ainda depende demais de acaso ou indicacao, talvez a base digital esteja abaixo do potencial do negocio."
    finalText="A Scale ajuda a organizar presenca, pagina e aquisicao para transformar mais atencao em oportunidade."
    ctaLabel="Solicitar diagnostico"
    areasCtaLabel="Quero crescer em Cariacica"
  />
</LocalLayout>
