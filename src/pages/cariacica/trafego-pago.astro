---
import LocalLayout from '@layouts/LocalLayout.astro';
import ScaleLocalLanding from '@components/local/ScaleLocalLanding.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('cariacica')!;

const conversionCards = [
  { title: 'Verba', desc: 'Trafego pago sem leitura local vira clique demais e lead de menos. O problema costuma estar na segmentacao e na pagina.' },
  { title: 'Oferta', desc: 'Nem sempre a campanha falha por canal. Em muitos casos, a proposta da empresa nao esta clara o suficiente para quem clicou.' },
  { title: 'Pagina', desc: 'Quando o anuncio entrega atencao para uma pagina fraca, a empresa paga pela visita e perde a conversa para o atrito.' },
  { title: 'Leitura', desc: 'A Scale acompanha custo, lead e contexto comercial para aproximar anuncio de oportunidade real, nao so de volume.' },
];

const differentials = [
  { title: 'Segmentacao mais local', desc: 'A campanha considera o comportamento do mercado em Cariacica e os recortes que fazem sentido para o negocio.' },
  { title: 'Anuncio conectado a pagina', desc: 'Criativo, oferta e destino precisam conversar. Sem isso, o clique fica caro mesmo quando o CPC parece bom.' },
  { title: 'Midia com leitura de negocio', desc: 'A analise nao termina na plataforma. O que importa e entender se a verba esta trazendo conversa com chance real.' },
];

const relatedItems = [
  { title: 'Hub de Cariacica', href: '/cariacica', desc: 'Visao geral da estrategia digital e das frentes mais importantes para empresas da cidade.', metrics: ['hub local', 'estrategia'] },
  { title: 'Criacao de sites em Cariacica', href: '/cariacica/criacao-de-sites', desc: 'Base digital mais forte para receber melhor o trafego e converter mais.', metrics: ['pagina', 'conversao'] },
  { title: 'Servico de trafego pago', href: '/servicos/trafego-pago', desc: 'Entenda como a Scale estrutura Google Ads e Meta Ads para empresas de diferentes segmentos.', metrics: ['Google Ads', 'Meta Ads'] },
  { title: 'Metricas e ROAS', href: '/blog/metricas-e-roas-em-trafego-pago-guia-para-empresas', desc: 'Guia para entender melhor leitura de retorno e qualidade de campanha.', metrics: ['ROAS', 'CPL'] },
];

const faqs = [
  { question: 'Trafego pago funciona para empresas pequenas em Cariacica?', answer: 'Sim. Quando a oferta e a pagina estao bem ajustadas, a midia paga pode gerar demanda mesmo para operacoes menores.' },
  { question: 'Qual canal costuma funcionar melhor?', answer: 'Depende do negocio. Google Ads tende a capturar intencao mais ativa. Meta Ads ajuda a aquecer publico, reforcar marca e fazer remarketing.' },
  { question: 'Quanto tempo o trafego leva para comecar a responder?', answer: 'Campanhas bem estruturadas costumam gerar sinais mais rapidos, mas a qualidade do resultado melhora com ajuste e leitura dos primeiros dados.' },
  { question: 'Como a Scale acompanha o desempenho da midia?', answer: 'Avaliamos investimento, custo por lead, qualidade da conversa e contexto comercial para nao parar na metrica vaidosa.' },
];
---

<LocalLayout
  title="Trafego Pago em Cariacica - ES | Google Ads e Meta Ads | Scale"
  description="Trafego pago em Cariacica para empresas que querem gerar demanda com Google Ads e Meta Ads de forma mais clara, local e orientada a resultado."
  city={city}
>
  <ScaleLocalLanding
    heroEyebrow="Trafego pago em Cariacica com leitura local e foco em resultado."
    heroTitle="Trafego Pago em Cariacica para empresas que querem transformar verba em oportunidade."
    heroDescription="A Scale estrutura Google Ads e Meta Ads para empresas de Cariacica que precisam parar de investir no escuro e organizar campanhas com mais criterio, pagina melhor e leitura de negocio."
    heroMetrics={[{ value: 'Ads', label: 'demanda ativa', icon: 'search' }, { value: 'Scale', label: 'leitura', icon: 'shield' }]}
    logosLabel="Empresas que ja confiaram na Scale para organizar sua midia paga"
    problemTitle="Anuncio sem pagina e sem leitura local vira custo. Nao crescimento."
    problemParagraphs={['Em Cariacica, a midia paga pode acelerar demanda com bastante eficiencia, desde que a campanha chegue no publico certo com mensagem e destino coerentes.', 'Quando a verba roda sem estrutura, o negocio recebe clique, mas nao transforma isso em conversa boa nem em decisao comercial melhor.']}
    conversionCards={conversionCards}
    engineeringKicker="Engenharia da midia"
    engineeringTitle="Campanha boa combina segmentacao, oferta, pagina e leitura de qualidade."
    engineeringText="O trabalho certo nao e so subir anuncio. E construir uma operacao em que cada real tenha mais chance de virar oportunidade util para a empresa."
    differentials={differentials}
    areasTitle="Os pilares do trafego pago em Cariacica."
    areasText="A Scale conecta pagina, campanha e leitura comercial para fazer a midia responder com mais qualidade."
    relatedItems={relatedItems}
    complianceTitle="Antes de aumentar a verba, vale entender onde a campanha pode estar vazando resultado."
    complianceText="O gargalo pode estar na oferta, no criativo, na segmentacao ou na pagina. Ajustar isso normalmente vale mais do que so investir mais."
    complianceTags={['Google Ads', 'Meta Ads', 'Pagina forte', 'Segmentacao local', 'Leitura comercial', 'Menos desperdicio']}
    videosTitle="Projetos que transformaram midia paga em operacao mais clara"
    videosText="Quando a empresa entende melhor o que entra no funil e o que realmente fecha, a verba ganha outra qualidade."
    printsTitle="Midia bem lida melhora mais do que numero. Melhora decisao."
    printsText="Com mais clareza sobre o que gera oportunidade, a empresa deixa de patinar entre campanhas e comeca a aprender com mais velocidade."
    teamTitle="Mais de 32 profissionais conectando estrategia, criativo, pagina e leitura de campanha."
    teamText="Trafego pago bom exige mais do que plataforma. Exige metodo para transformar clique em negocio."
    faqTitle="Perguntas frequentes sobre trafego pago em Cariacica."
    faqs={faqs}
    finalTitle="Se sua empresa em Cariacica investe em anuncio sem muita clareza do que volta, o proximo passo nao precisa ser aumentar verba."
    finalText="A Scale ajuda a organizar campanha, pagina e leitura para transformar mais investimento em oportunidade com sentido comercial."
    ctaLabel="Solicitar diagnostico de midia"
    areasCtaLabel="Quero melhorar meus anuncios"
  />
</LocalLayout>
