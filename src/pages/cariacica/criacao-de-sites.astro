---
import LocalLayout from '@layouts/LocalLayout.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('cariacica')!;

const faqs = [
  { question: 'Qual o prazo para criar um site em Cariacica?', answer: 'Entregamos em 20 a 30 dias úteis após aprovação do briefing e recebimento dos materiais (textos, logo e imagens).' },
  { question: 'O site aparece no Google para buscas em Cariacica?', answer: 'Sim. Desenvolvemos com SEO técnico e podemos incluir páginas otimizadas para buscas locais como "serviço em Cariacica", aumentando sua visibilidade na região.' },
  { question: 'Vocês atendem presencialmente em Cariacica?', answer: 'Atendemos de forma remota com a mesma qualidade de um atendimento presencial. Todo o processo é feito por videochamada, e-mail e WhatsApp.' },
  { question: 'Consigo editar o site depois de pronto?', answer: 'Sim. Entregamos acesso a um CMS simples onde você edita textos e imagens sem precisar de programação.' },
  { question: 'O site inclui hospedagem e domínio?', answer: 'A hospedagem pode ser inclusa no plano ou você pode usar sua própria. O domínio (ex: suaempresa.com.br) pode ser adquirido por nós ou transferido do seu atual provedor.' },
];

const benefits = [
  { title: 'Design responsivo e profissional', desc: 'Site adaptado para celular, tablet e desktop com identidade visual alinhada à sua marca.' },
  { title: 'SEO técnico incluso', desc: 'Velocidade, meta tags, sitemap, schema markup e otimização para buscas locais em Cariacica.' },
  { title: 'CMS para edição fácil', desc: 'Gerencie textos, imagens e conteúdo sem precisar de programador.' },
  { title: 'Carregamento rápido', desc: 'Performance otimizada para melhor experiência do usuário e melhor posicionamento no Google.' },
  { title: 'SSL e segurança', desc: 'Certificado HTTPS incluso, protegendo os dados dos seus visitantes e clientes.' },
  { title: 'Suporte pós-entrega', desc: 'Acompanhamento após o go-live para garantir que tudo funcione como esperado.' },
];
---

<LocalLayout
  title="Criação de Site em Cariacica – ES | Scale"
  description="Criação de sites profissionais para empresas em Cariacica (ES). Responsivo, rápido e otimizado para o Google. Diagnóstico gratuito. (27) XXXX-XXXX."
  city={city}
>
  <section class="section bg-surface-subtle">
    <div class="container">
      <span class="inline-flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 px-4 py-1.5 rounded-full text-sm font-semibold mb-6">
        📍 Cariacica – ES
      </span>
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-4">
        Criação de Site para Empresas em Cariacica – ES
      </h1>
      <p class="text-lg text-ink-light leading-relaxed mb-8 max-w-2xl">
        Sites profissionais, responsivos e otimizados para o Google, desenvolvidos para empresas de Cariacica que querem atrair mais clientes pela internet.
      </p>
      <div class="flex gap-4 flex-wrap">
        <a href="/contato" class="px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
          Solicitar orçamento grátis
        </a>
        <a href="tel:+5527XXXXXXXX" class="px-8 py-4 text-lg font-semibold rounded-lg border-2 border-brand-primary text-brand-primary hover:bg-brand-primary hover:text-ink-inverse transition-colors">
          (27) XXXX-XXXX
        </a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Por que criar um site profissional em Cariacica?</h2>
        <p class="section-subtitle">Empresas de Cariacica que investem em presença digital captam clientes que os concorrentes perdem.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(item => (
          <div class="p-6 rounded-xl border border-edge bg-surface-card">
            <h3 class="font-semibold text-ink text-lg mb-2">{item.title}</h3>
            <p class="text-sm text-ink-light leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqs} title="Dúvidas sobre criação de site em Cariacica" />

  <section class="section text-center bg-surface-subtle">
    <div class="container-narrow">
      <h2 class="font-heading text-3xl font-bold text-ink mb-4">Sua empresa merece um site à altura</h2>
      <p class="text-lg text-ink-light mb-8">Diagnóstico gratuito para empresas de Cariacica. Sem compromisso.</p>
      <a href="/contato" class="inline-block px-8 py-4 text-lg font-semibold rounded-lg bg-brand-primary text-ink-inverse hover:bg-brand-secondary border-2 border-brand-primary transition-colors">
        Solicitar orçamento grátis
      </a>
    </div>
  </section>
</LocalLayout>
