---
import LocalLayout from '@layouts/LocalLayout.astro';
import ScaleLocalLanding from '@components/local/ScaleLocalLanding.astro';
import { getCityBySlug } from '@data/cities';

const city = getCityBySlug('cariacica')!;

const conversionCards = [
  { title: 'Confianca', desc: 'Em mercados locais, o site ajuda a empresa a parecer mais seria, organizada e pronta para atender melhor.' },
  { title: 'Performance', desc: 'Pagina lenta ou mal organizada reduz o efeito de SEO, midia paga e da propria indicacao que chega para validar a empresa.' },
  { title: 'Clareza', desc: 'O visitante precisa entender servico, diferencial e proximo passo rapidamente para que o interesse nao esfrie.' },
  { title: 'Base', desc: 'Site bom nao e acessorio. E a base que sustenta crescimento, busca local e percepcao comercial da marca.' },
];

const differentials = [
  { title: 'Estrutura tecnica preparada', desc: 'Performance, SEO tecnico e boa leitura mobile entram desde o inicio do projeto.' },
  { title: 'Pagina mais comercial', desc: 'O foco e construir um site que ajude a vender melhor, e nao apenas uma apresentacao bonita.' },
  { title: 'Base pronta para evoluir', desc: 'O projeto nasce preparado para SEO, campanhas, novos servicos e crescimento digital no medio prazo.' },
];

const relatedItems = [
  { title: 'Hub de Cariacica', href: '/cariacica', desc: 'Entenda como a Scale atua na cidade e quais frentes fazem mais sentido para negocios locais.', metrics: ['hub local', 'estrategia'] },
  { title: 'Trafego pago em Cariacica', href: '/cariacica/trafego-pago', desc: 'Campanhas para gerar demanda mais rapida e melhor leitura comercial.', metrics: ['midia', 'leads'] },
  { title: 'Landing pages', href: '/servicos/criacao-de-landing-pages', desc: 'Paginas focadas para campanhas e servicos mais especificos.', metrics: ['campanha', 'conversao'] },
  { title: 'Quanto custa criar um site', href: '/blog/quanto-custa-criar-um-site-profissional', desc: 'Veja o que impacta escopo, investimento e retorno de um site bem estruturado.', metrics: ['orcamento', 'escopo'] },
];

const faqs = [
  { question: 'Um site melhor ajuda empresas de Cariacica a vender mais?', answer: 'Sim. Um site melhor melhora confianca, ajuda na busca local e faz o visitante entender mais rapido porque deve entrar em contato.' },
  { question: 'O site ja sai preparado para SEO?', answer: 'Sim. A estrutura tecnica e o desenho das paginas ja entram pensando em performance, Google e boa experiencia mobile.' },
  { question: 'A Scale faz site so institucional?', answer: 'Nao. Criamos sites comerciais, paginas de servico, landing pages e estruturas que sustentam aquisicao e crescimento.' },
  { question: 'Depois posso usar o site em anuncios e SEO?', answer: 'Sim. Essa e justamente a ideia: construir uma base digital que apoie os proximos movimentos do marketing.' },
];
---

<LocalLayout
  title="Criacao de Site em Cariacica - ES | Scale"
  description="Criacao de site em Cariacica para empresas que precisam de uma base digital mais forte, rapida e preparada para SEO, anuncios e conversao."
  city={city}
>
  <ScaleLocalLanding
    heroEyebrow="Criacao de sites em Cariacica para empresas que querem parecer mais fortes."
    heroTitle="Criacao de Site em Cariacica com foco em clareza comercial, performance e crescimento."
    heroDescription="A Scale desenvolve sites para empresas de Cariacica que precisam melhorar presenca digital, confianca e conversao com uma base preparada para SEO e campanhas."
    heroMetrics={[{ value: 'Site', label: 'performance', icon: 'search' }, { value: 'Base', label: 'comercial', icon: 'shield' }]}
    logosLabel="Empresas que ja confiaram na Scale para construir uma base digital melhor"
    problemTitle="Site fraco faz a empresa parecer menor, menos preparada e mais dificil de escolher."
    problemParagraphs={['Em Cariacica, onde muitas empresas ainda disputam mercado com presencas digitais fracas, um bom site se torna diferencial real de percepcao e conversao.', 'A pagina precisa ajudar o cliente a entender valor e diminuir hesitacao antes do contato.']}
    conversionCards={conversionCards}
    engineeringKicker="Engenharia do site"
    engineeringTitle="O site certo ajuda a empresa a parecer mais forte e a transformar melhor cada visita."
    engineeringText="Quando performance, mensagem e estrutura caminham juntas, a base digital passa a sustentar SEO, midia paga e uma percepcao comercial mais alta."
    differentials={differentials}
    areasTitle="O que a Scale conecta ao criar um site em Cariacica."
    areasText="O projeto une estrutura tecnica, posicionamento e base pronta para os proximos passos do marketing."
    relatedItems={relatedItems}
    complianceTitle="Site bom amplia o efeito dos outros canais e reduz o atrito do processo comercial."
    complianceText="SEO, anuncio e indicacao funcionam melhor quando chegam em uma pagina que sustenta a atencao e reforca confianca."
    complianceTags={['Performance', 'Clareza comercial', 'Busca local', 'Base para SEO', 'Conversao', 'Mobile']}
    videosTitle="Projetos que ficaram mais fortes ao melhorar a base digital"
    videosText="Quando o site deixa de ser gargalo, a empresa passa a aproveitar melhor o interesse que ja existe no mercado."
    printsTitle="Mais clareza na pagina melhora a forma como o negocio e percebido."
    printsText="A base digital certa aumenta confianca, melhora leitura de valor e ajuda o cliente a decidir mais rapido."
    teamTitle="Mais de 32 profissionais apoiando pagina, estrategia, performance e conversao."
    teamText="Criar um site que realmente ajude a vender exige mais do que design. Exige estrutura e metodo."
    faqTitle="Perguntas frequentes sobre criacao de sites em Cariacica."
    faqs={faqs}
    finalTitle="Se o seu site atual nao ajuda sua empresa a crescer em Cariacica, talvez ele esteja segurando mais do que voce imagina."
    finalText="A Scale ajuda a construir uma base digital mais forte para gerar mais confianca, mais visibilidade e melhores contatos."
    ctaLabel="Solicitar orcamento"
    areasCtaLabel="Quero um site melhor"
  />
</LocalLayout>
