---
/**
 * Sobre — /sobre
 * Menciona Vila Velha explicitamente, DDD 27, equipe local
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import LocalCTA from '@components/sections/LocalCTA.astro';
---

<BaseLayout
  title="Sobre a Scale | Agência de Marketing Digital em Vila Velha – ES"
  description="Conheça a Scale: agência de marketing digital localizada em Vila Velha (ES), especializada em criar resultados reais para empresas locais e de todo o Brasil."
>
  <section class="section">
    <div class="container-narrow">
      <span class="section-label">Nossa história</span>
      <h1 class="font-heading text-4xl sm:text-5xl font-extrabold text-ink leading-tight mb-6">
        Uma agência de Vila Velha com resultado de nível nacional
      </h1>
      <!-- TODO: preencher texto com a história real da Scale -->
      <p class="text-lg text-ink-light leading-relaxed mb-10">
        Conteúdo sobre a Scale a ser adicionado: fundação, equipe, missão e valores.
      </p>

      <a href="/certificacao-google-ads" class="inline-flex items-center gap-3 px-6 py-3 rounded-full border border-[#00BAFF]/30 bg-[#00BAFF]/10 hover:bg-[#00BAFF]/20 transition-all hover:scale-105 group text-ink decoration-none shadow-sm">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#00BAFF" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <path d="M9 12l2 2 4-4"/>
        </svg>
        <span class="font-bold text-sm text-[#010000] group-hover:text-[#1630DF] transition-colors">Agência Oficialmente Certificada pelo Google</span>
      </a>
    </div>
  </section>

  <LocalCTA city="Vila Velha" />
</BaseLayout>
