---
/**
 * Hub de Serviços — /servicos
 * Quatro frentes principais + CTA local
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import ServicesGrid from '@components/sections/ServicesGrid.astro';
import LocalCTA from '@components/sections/LocalCTA.astro';
---

<BaseLayout
  title="Serviços de Marketing Digital | Scale"
  description="Tráfego pago, landing pages, SEO e gestão de redes sociais — automações, treinamento comercial e criação de artes integrados às nossas frentes."
>
  <section class="section bg-surface-subtle border-b border-edge">
    <div class="container">
      <div class="max-w-xl">
        <span class="section-label">O que fazemos</span>
        <h1 class="font-heading text-3xl font-extrabold text-ink leading-tight md:text-4xl">
          Soluções para crescer seu negócio
        </h1>
        <p class="mt-3 text-base text-ink-light leading-relaxed md:text-lg">
          Tráfego, páginas, SEO e conteúdo — na mesma equipe.
        </p>
      </div>

      <div class="mt-10 md:mt-12">
        <ServicesGrid embedded showLink={true} />
      </div>
    </div>
  </section>

  <LocalCTA city="Vila Velha" />
</BaseLayout>
