---
/**
 * Trafego Pago - /servicos/trafego-pago
 * Keywords: gestao Google Ads, Meta Ads, agencia de trafego pago, gestor de trafego
 */
import ServiceLayout from '@layouts/ServiceLayout.astro';
import GlassEffect from '@components/ui/GlassEffect.astro';
import FAQ from '@components/sections/FAQ.astro';
import { getServiceBySlug } from '@data/services';

const service = getServiceBySlug('trafego-pago')!;

const barHeights = [100, 88, 76, 65, 55, 45, 37, 30, 37, 45, 55, 65, 76, 88, 100];

const faqs = [
  {
    question: 'O que faz um gestor de trafego?',
    answer:
      'Um gestor de trafego estrutura campanhas, define publicos e palavras-chave, cria e testa anuncios, acompanha metricas como CPC, CPA e ROAS e otimiza com base em dados reais para aproximar cada real investido do melhor resultado possivel.',
  },
  {
    question: 'Quanto custa contratar gestao de trafego pago?',
    answer:
      'O valor depende do escopo, canais, volume de criativos, complexidade do funil e investimento em midia. No diagnostico, a Scale separa fee de gestao e verba de anuncios com transparencia para evitar pacote generico.',
  },
  {
    question: 'Qual a diferenca entre Google Ads e Meta Ads?',
    answer:
      'Google Ads captura demanda de quem ja esta pesquisando. Meta Ads, no Instagram e Facebook, cria demanda, aquece publico e sustenta remarketing. Em muitos funis, os dois canais trabalham juntos.',
  },
  {
    question: 'Trafego pago funciona para qualquer empresa?',
    answer:
      'Funciona melhor quando existe oferta clara, pagina de destino adequada, margem para adquirir cliente e capacidade de atendimento. No diagnostico avaliamos se o canal e o investimento fazem sentido para o estagio da empresa.',
  },
  {
    question: 'Como acompanho os resultados?',
    answer:
      'Voce acompanha relatorios em linguagem de negocio: investimento, leads, custo por oportunidade, conversoes, ROAS e aprendizados do periodo. O foco e decisao, nao metrica de vaidade.',
  },
];

const benefits = [
  {
    title: 'Campanhas focadas em conversao',
    desc: 'A conta e gerenciada por lead, venda, CPA e ROAS, nao por impressao ou clique isolado.',
  },
  {
    title: 'Google Ads com intencao',
    desc: 'Pesquisa, Display, YouTube ou Shopping com estrutura, palavras negativas, extensoes e rastreamento.',
  },
  {
    title: 'Meta Ads com criativos',
    desc: 'Instagram e Facebook com testes de mensagem, publico, formato e remarketing para reduzir desperdicio.',
  },
  {
    title: 'Rastreamento bem configurado',
    desc: 'Pixel, tags, eventos e conversoes revisados para medir a origem das oportunidades.',
  },
  {
    title: 'Testes continuos',
    desc: 'Criativos, copies, publicos, landing pages e ofertas sao comparados para encontrar o que escala.',
  },
  {
    title: 'Relatorio de negocio',
    desc: 'Voce entende o que aconteceu, o que sera ajustado e onde a verba deve ganhar ou perder prioridade.',
  },
];

const channels = [
  {
    title: 'Google Ads',
    label: 'Captura demanda',
    desc: 'Apareca quando o cliente esta pesquisando ativamente por produto, servico, problema ou fornecedor.',
    bullets: ['Search e Performance Max', 'Termos de alta intencao', 'Conversoes e chamadas', 'Negativas e ajustes semanais'],
  },
  {
    title: 'Meta Ads',
    label: 'Cria demanda',
    desc: 'Use Instagram e Facebook para gerar lembranca, testar ofertas, fazer remarketing e ampliar escala.',
    bullets: ['Criativos por etapa', 'Publicos e lookalikes', 'Remarketing', 'Teste de oferta e mensagem'],
  },
];

const process = [
  {
    step: '01',
    title: 'Diagnostico e estrategia',
    desc: 'Analisamos negocio, margem, concorrencia, historico de campanhas, funil e verba viavel antes de lancar.',
  },
  {
    step: '02',
    title: 'Configuracao e lancamento',
    desc: 'Montamos campanhas, criativos, rastreamento, eventos de conversao e primeiras hipoteses de teste.',
  },
  {
    step: '03',
    title: 'Otimizacao com dados',
    desc: 'Pausamos o que desperdiça verba, escalamos o que performa e testamos novas variacoes com metodo.',
  },
  {
    step: '04',
    title: 'Relatorio e melhoria',
    desc: 'Organizamos indicadores, aprendizados e proximos passos para conectar midia paga a decisao comercial.',
  },
];

const metrics = [
  { value: 'CPA', label: 'Custo por aquisicao' },
  { value: 'ROAS', label: 'Retorno sobre anuncio' },
  { value: 'CPL', label: 'Custo por lead' },
  { value: 'LTV', label: 'Valor do cliente' },
];

const outcomes = [
  'Leads qualificados com previsibilidade maior',
  'Menos verba perdida com segmentacao ampla ou conta sem leitura',
  'Campanhas alinhadas ao ciclo de venda e capacidade comercial',
  'Dados para decidir quais ofertas, canais e paginas merecem escala',
  'Visibilidade imediata enquanto SEO e conteudo amadurecem',
  'Relatorios que mostram custo, qualidade e proximos testes',
];
---

<ServiceLayout
  title="Gestao de Trafego Pago | Google Ads e Meta Ads | Scale"
  description="Agencia de trafego pago com gestao de Google Ads e Meta Ads, criativos, rastreamento, relatorios claros e foco em CPA, ROAS e leads qualificados."
  service={service}
>
  <style>
    @keyframes serviceWave {
      0% { transform: scaleY(calc(var(--target-scale) * .34)); opacity: .22; }
      100% { transform: scaleY(var(--target-scale)); opacity: .84; }
    }

    .tp-hero-bar {
      flex: 1 0 calc(100% / 15);
      max-width: calc(100% / 15);
      height: 100%;
      background: linear-gradient(to top, #00BAFF, #1630DF 55%, transparent 100%);
      transform-origin: bottom;
      animation: serviceWave 2s ease-in-out infinite alternate;
    }

    .tp-grid-bg {
      background-image:
        linear-gradient(rgba(255,255,255,.045) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,.045) 1px, transparent 1px);
      background-size: 44px 44px;
    }

    .tp-panel {
      border: 1px solid rgba(255,255,255,.10);
      background: linear-gradient(145deg, rgba(255,255,255,.075), rgba(255,255,255,.025));
      box-shadow: 0 24px 80px rgba(0,0,0,.28), inset 0 1px 0 rgba(255,255,255,.10);
      backdrop-filter: blur(14px);
    }

    .tp-process-card {
      position: relative;
      overflow: hidden;
      border: 1px solid rgba(7, 24, 39, .08);
      background: linear-gradient(135deg, #fff 0%, #f7faff 100%);
      box-shadow: 0 18px 45px rgba(7, 24, 39, .08);
      transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
    }

    .tp-process-card::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 4px;
      background: linear-gradient(90deg, #1630DF, #00BAFF);
    }

    .tp-process-card::after {
      content: "";
      position: absolute;
      right: -42px;
      top: -42px;
      width: 128px;
      height: 128px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(0, 186, 255, .14), transparent 68%);
      pointer-events: none;
    }

    .tp-process-card:hover {
      transform: translateY(-6px);
      border-color: rgba(0, 186, 255, .24);
      box-shadow: 0 24px 70px rgba(7, 24, 39, .13);
    }

    .tp-step {
      display: inline-flex;
      width: 46px;
      height: 46px;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: linear-gradient(135deg, rgba(22, 48, 223, .10), rgba(0, 186, 255, .14));
      color: #1630DF;
      font-family: var(--font-heading, inherit);
      font-weight: 900;
      box-shadow: inset 0 0 0 1px rgba(22, 48, 223, .10);
    }

    .tp-chip {
      border: 1px solid rgba(0,186,255,.24);
      background: rgba(0,186,255,.08);
      color: rgba(255,255,255,.72);
    }
  </style>

  <section class="relative -mt-16 min-h-[92svh] overflow-hidden bg-[#010f1c] flex items-center">
    <div class="absolute inset-0 z-0 overflow-hidden" aria-hidden="true">
      <div class="flex h-full w-full">
        {barHeights.map((h, i) => (
          <div
            class="tp-hero-bar"
            style={`--target-scale: ${h / 100}; animation-delay: -${Math.max(0, (i * 0.15) + Math.sin(i * 1.2) * 0.4).toFixed(2)}s;`}
          />
        ))}
      </div>
      <div class="absolute inset-0 bg-[linear-gradient(to_bottom,#010f1c_0%,rgba(1,15,28,.78)_24%,rgba(1,15,28,.58)_58%,#010f1c_100%)]"></div>
    </div>

    <div class="container relative z-10 py-28 md:py-36">
      <div class="grid grid-cols-1 lg:grid-cols-[1.05fr_.95fr] gap-12 items-center">
        <div class="text-center lg:text-left">
          <div class="mb-7 inline-flex">
            <GlassEffect
              className="inline-flex items-center gap-2 px-5 py-2.5 text-xs font-semibold !cursor-default"
              glassClass="bg-[#010f1c]/75"
              rounded="rounded-full"
            >
              <span style="color: rgba(0,186,255,.75);">+</span>
              <span style="color: rgba(255,255,255,.68);">Google Ads, Meta Ads e performance com relatorio claro</span>
            </GlassEffect>
          </div>

          <h1
            class="font-heading font-extrabold leading-[1.03] tracking-tight mb-6 text-balance"
            style="font-size: clamp(2.7rem, 5.5vw, 5rem); background: linear-gradient(to bottom, #fff 34%, rgba(255,255,255,.62)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;"
          >
            Gestao de trafego pago para transformar midia em crescimento previsivel.
          </h1>

          <p class="text-lg md:text-xl leading-relaxed max-w-2xl mx-auto lg:mx-0 mb-9 text-white/62">
            A Scale estrutura campanhas de Google Ads e Meta Ads com rastreamento, criativos, otimizacao e leitura de negocio para reduzir desperdicio e aumentar oportunidades qualificadas.
          </p>

          <div class="flex flex-wrap items-center justify-center lg:justify-start gap-4">
            <span class="relative inline-block overflow-hidden rounded-full p-[1.5px]">
              <span
                class="animate-spin-slow absolute pointer-events-none"
                aria-hidden="true"
                style="inset: -100%; background: conic-gradient(from 90deg at 50% 50%, #00BAFF 0%, #1630DF 50%, #00BAFF 100%);"
              ></span>
              <a
                href="/contato"
                class="relative inline-flex items-center gap-2 px-8 py-4 text-base font-semibold rounded-full transition-opacity hover:opacity-90"
                style="background: #010f1c; color: white;"
              >
                Solicitar diagnostico gratuito
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            </span>

            <GlassEffect
              href="#processo"
              className="inline-flex items-center gap-2 px-5 py-3 text-sm font-semibold text-white/80"
              glassClass="bg-white/5 group-hover:bg-white/10"
              rounded="rounded-full"
            >
              Ver metodologia
            </GlassEffect>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -right-20 -top-24 w-[30rem] h-[30rem] rounded-full bg-[#00BAFF]/20 blur-3xl" aria-hidden="true"></div>
          <div class="tp-panel rounded-2xl p-5 md:p-7 relative overflow-hidden">
            <div class="flex items-center justify-between gap-4 mb-7">
              <div>
                <p class="text-white/42 text-xs uppercase tracking-[.22em] font-bold">Painel de performance</p>
                <h2 class="text-white font-heading text-2xl font-bold mt-2">Conta em otimizacao</h2>
              </div>
              <span class="tp-chip rounded-full px-3 py-1 text-xs font-bold">Google + Meta</span>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-6">
              {metrics.map((metric) => (
                <div class="rounded-xl border border-white/8 bg-white/[.045] p-4">
                  <strong class="block text-[#00BAFF] text-2xl font-heading">{metric.value}</strong>
                  <span class="text-white/45 text-xs leading-snug">{metric.label}</span>
                </div>
              ))}
            </div>

            <div class="space-y-3">
              {['Eventos de conversao revisados', 'Criativos em teste semanal', 'Verba alocada por retorno', 'Relatorio com proximas decisoes'].map((item, index) => (
                <div class="flex items-center gap-3 rounded-xl bg-black/18 border border-white/8 p-3">
                  <span class="w-7 h-7 rounded-full bg-[#00BAFF]/12 text-[#00BAFF] flex items-center justify-center text-xs font-bold">{index + 1}</span>
                  <span class="text-white/68 text-sm">{item}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] tp-grid-bg border-y border-white/8">
    <div class="container py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[.82fr_1.18fr] gap-10 items-start">
        <div>
          <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">O problema</p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
            Anuncio pago sem metodo vira uma forma rapida de queimar dinheiro.
          </h2>
          <p class="text-white/55 leading-relaxed">
            Trafego pago funciona quando oferta, criativo, pagina, rastreamento e atendimento caminham juntos. A Scale olha para a operacao inteira antes de aumentar verba.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            ['Clique sem venda', 'A campanha movimenta a conta, mas o comercial nao sente aumento real de oportunidades.'],
            ['Rastreamento quebrado', 'Sem evento confiavel, o algoritmo otimiza para o sinal errado e o relatorio perde valor.'],
            ['Criativo sem ritmo', 'Poucas variacoes fazem a campanha cansar rapido e aumentam custo por lead.'],
            ['Relatorio sem decisao', 'Numero solto nao basta. O relatorio precisa indicar o que muda na proxima semana.'],
          ].map(([title, desc]) => (
            <div class="rounded-xl border border-white/8 bg-white/[.045] p-6">
              <h3 class="text-white font-semibold mb-2">{title}</h3>
              <p class="text-sm text-white/50 leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Dois canais, funcoes diferentes</h2>
        <p class="section-subtitle">Google Ads captura a demanda existente. Meta Ads cria demanda, aquece e recupera publico.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        {channels.map((channel) => (
          <article class="rounded-xl border border-edge bg-surface-card p-7 shadow-sm">
            <div class="flex items-start justify-between gap-4 mb-5">
              <div>
                <span class="text-xs font-bold uppercase tracking-widest text-brand-primary">{channel.label}</span>
                <h3 class="font-heading text-2xl font-bold text-ink mt-2">{channel.title}</h3>
              </div>
              <span class="w-10 h-10 rounded-lg bg-brand-primary/10 text-brand-primary flex items-center justify-center">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12h18"/><path d="M12 3v18"/><path d="m18 6-12 12"/></svg>
              </span>
            </div>
            <p class="text-ink-light leading-relaxed mb-6">{channel.desc}</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {channel.bullets.map((point) => (
                <div class="flex items-center gap-2 text-sm text-ink">
                  <span class="w-1.5 h-1.5 rounded-full bg-brand-primary"></span>
                  {point}
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">O que entra na gestao</h2>
        <p class="section-subtitle">Campanha boa nao depende de uma configuracao isolada. Ela depende de um sistema de melhoria.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((item) => (
          <div class="rounded-2xl border border-edge bg-white p-6 shadow-sm">
            <h3 class="font-heading text-lg font-bold text-[#071827] mb-3">{item.title}</h3>
            <p class="text-sm text-[#425466] leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="processo" class="section bg-surface-subtle">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Como funciona o processo</h2>
        <p class="section-subtitle">Da estrategia ao relatorio, com ciclo de melhoria continua.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {process.map((item) => (
          <div class="tp-process-card rounded-2xl p-6 md:p-7 min-h-[260px] flex flex-col">
            <div class="relative z-10 flex items-center justify-between mb-8">
              <span class="tp-step">{item.step}</span>
              <span class="h-px flex-1 ml-4 bg-gradient-to-r from-[#1630DF]/20 to-transparent"></span>
            </div>
            <div class="relative z-10 mt-auto">
              <h3 class="font-heading text-xl font-bold text-[#071827] mb-3 leading-tight">{item.title}</h3>
              <p class="text-sm text-[#425466] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-[.9fr_1.1fr] gap-10 items-center">
        <div>
          <p class="text-brand-primary text-xs uppercase tracking-[.22em] font-bold mb-4">Quanto custa</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-ink mb-5">
            O investimento precisa nascer do custo de aquisicao que o seu negocio suporta.
          </h2>
          <p class="text-ink-light leading-relaxed mb-5">
            Trafego pago tem duas partes: verba de midia, que vai para Google e Meta, e gestao profissional, que organiza estrategia, criativos, rastreamento e otimizacao. Nao existe numero unico para todo negocio.
          </p>
          <p class="text-ink-light leading-relaxed">
            No diagnostico, a Scale calcula uma verba de teste coerente com concorrencia, ticket medio, margem e capacidade comercial. A meta e aprender rapido sem desperdiçar orcamento.
          </p>
        </div>

        <div class="rounded-2xl border border-edge bg-surface-card p-7">
          <h3 class="font-heading text-2xl font-bold text-ink mb-5">O que avaliamos antes de sugerir verba</h3>
          <div class="space-y-3">
            {['Ticket medio e margem', 'Capacidade de atendimento', 'Qualidade da pagina de destino', 'Concorrencia e custo por clique', 'Historico de leads e vendas'].map((item) => (
              <div class="flex items-center gap-3 rounded-xl bg-surface-subtle border border-edge p-3">
                <span class="w-7 h-7 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center text-xs font-bold">✓</span>
                <span class="text-sm text-ink">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface-subtle">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Resultados esperados</h2>
        <p class="section-subtitle">O que muda quando a midia paga passa a ser operada com dados e consistencia.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {outcomes.map((item) => (
          <div class="rounded-xl border border-edge bg-surface-card p-5 flex items-start gap-3">
            <span class="w-7 h-7 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center shrink-0 text-xs font-bold">✓</span>
            <p class="text-sm text-ink leading-relaxed">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-[#010f1c] tp-grid-bg">
    <div class="container py-16 md:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <p class="text-[#00BAFF] text-xs uppercase tracking-[.24em] font-bold mb-4">Conteudo complementar</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold leading-tight text-white mb-5">
          Quer entender melhor antes de investir?
        </h2>
        <p class="text-white/58 leading-relaxed mb-8">
          Temos guias sobre funcionamento de trafego pago, metricas e ROAS para ajudar sua equipe a tomar decisoes com mais clareza.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/blog/como-funciona-trafego-pago-para-empresas" class="inline-flex justify-center px-5 py-3 rounded-full border border-white/12 text-white/78 hover:text-white hover:bg-white/8 transition-colors">
            Como funciona trafego pago
          </a>
          <a href="/blog/metricas-e-roas-em-trafego-pago-guia-para-empresas" class="inline-flex justify-center px-5 py-3 rounded-full border border-white/12 text-white/78 hover:text-white hover:bg-white/8 transition-colors">
            Metricas e ROAS
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faqs} title="Perguntas frequentes sobre trafego pago" />

  <section class="section text-center">
    <div class="container-narrow">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-ink mb-4">Pronto para transformar verba em resultado?</h2>
      <p class="text-ink-light mb-8">Diagnostico gratuito, sem compromisso. Analisamos seu cenario atual e apresentamos um plano realista para escalar.</p>
      <a href="/contato" class="inline-flex items-center gap-2 px-8 py-4 rounded-full font-semibold text-white transition-opacity hover:opacity-85" style="background: linear-gradient(135deg, #1630DF, #00BAFF);">
        Solicitar diagnostico gratuito
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</ServiceLayout>
