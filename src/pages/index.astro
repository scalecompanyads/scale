<script>
  // Controla o wrapper coletivo das barras, sem NUNCA tocar na animação individual
  const barsWrapper = document.getElementById('hero-bars-wrapper');
  if (barsWrapper) {
    let lastScrollY = window.scrollY;
    let scrollState = 'top';

    window.addEventListener('scroll', () => {
      const currentScrollY = window.scrollY;

      if (currentScrollY <= 50 && scrollState !== 'top') {
        // Volta ao topo -> Mostra tudo (ondas continuam rodando naturalmente)
        barsWrapper.style.transform = 'scaleY(1)';
        scrollState = 'top';
      } else if (currentScrollY > lastScrollY && currentScrollY > 100 && scrollState !== 'down') {
        // Rolou para baixo -> Esconde suavemente
        barsWrapper.style.transform = 'scaleY(0)';
        scrollState = 'down';
      } else if (currentScrollY < lastScrollY && scrollState === 'down') {
        // Rolou para cima -> Mostra suavemente
        barsWrapper.style.transform = 'scaleY(1)';
        scrollState = 'up';
      }

      lastScrollY = currentScrollY;
    }, { passive: true });
  }
</script>

<script>
  // --- Hero reveal after preloader ---
  const preloader = document.getElementById('preloader');
  if (preloader) {
    const mo = new MutationObserver(() => {
      if (preloader.classList.contains('preloader-done') || preloader.style.display === 'none') {
        document.body.classList.add('hero-ready');
        mo.disconnect();
      }
    });
    mo.observe(preloader, { attributes: true, attributeFilter: ['class', 'style'] });
    // Fallback if preloader already gone
    setTimeout(() => document.body.classList.add('hero-ready'), 2500);
  } else {
    document.body.classList.add('hero-ready');
  }

  // --- Scroll reveal IntersectionObserver ---
  const revealEls = document.querySelectorAll('[class*="reveal-"]');
  if (revealEls.length) {
    // Assign stagger indexes
    document.querySelectorAll('.reveal-stagger').forEach((parent) => {
      parent.querySelectorAll('[class*="reveal-"]').forEach((child, i) => {
        (child as HTMLElement).style.setProperty('--reveal-i', String(i));
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

    revealEls.forEach((el) => observer.observe(el));
  }
</script>

