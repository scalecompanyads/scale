    <script>
      (() => {
        const INTERVAL = 4000;
        const steps   = Array.from(document.querySelectorAll<HTMLElement>('[data-pain-step]'));
        const circles = Array.from(document.querySelectorAll<HTMLElement>('[data-pain-circle]'));
        const slides  = Array.from(document.querySelectorAll<HTMLElement>('[data-pain-slide]'));
        const progWraps = Array.from(document.querySelectorAll<HTMLElement>('[data-pain-progress]'));

        let current = 0;
        let elapsed = 0;
        let ticker: ReturnType<typeof setInterval>;

        function activate(next: number) {
          const prev = current;

          // slides
          slides[prev].classList.remove('is-entering');
          slides[prev].classList.add('is-leaving');
          slides[next].style.transform = 'translateY(100%)';
          slides[next].style.opacity = '0';
          slides[next].style.zIndex = '2';
          requestAnimationFrame(() => {
            slides[next].classList.add('is-entering');
          });
          setTimeout(() => {
            slides[prev].classList.remove('is-leaving');
            slides[prev].style.zIndex = '0';
            slides[prev].style.opacity = '0';
          }, 520);

          // steps
          steps.forEach((s, i) => s.classList.toggle('is-active', i === next));

          // circles
          circles.forEach((c, i) => {
            c.classList.remove('is-active', 'is-done');
            const num   = c.querySelector<HTMLElement>('.pain-step-num')!;
            const check = c.querySelector<HTMLElement>('.pain-step-check')!;
            if (i < next)       { c.classList.add('is-done');   num.classList.add('hidden');    check.classList.remove('hidden'); }
            else if (i === next){ c.classList.add('is-active');  num.classList.remove('hidden'); check.classList.add('hidden'); }
            else                 {                                num.classList.remove('hidden'); check.classList.add('hidden'); }
          });

          // progress bars
          progWraps.forEach((pw, i) => {
            const fill = pw.querySelector<HTMLElement>('.pain-progress-fill')!;
            if (i === next) { pw.classList.remove('hidden'); fill.style.width = '0%'; }
            else            { pw.classList.add('hidden');    fill.style.width = '0%'; }
          });

          current = next;
          elapsed = 0;
        }

        function tick() {
          elapsed += 100;
          const pct = Math.min((elapsed / INTERVAL) * 100, 100);
          const fill = progWraps[current]?.querySelector<HTMLElement>('.pain-progress-fill');
          if (fill) fill.style.width = pct + '%';
          if (elapsed >= INTERVAL) activate((current + 1) % steps.length);
        }

        // click manual
        steps.forEach((s, i) => s.addEventListener('click', () => {
          clearInterval(ticker);
          activate(i);
          ticker = setInterval(tick, 100);
        }));

        // init — só começa quando a seção entrar no viewport
        activate(0);
        const section = document.getElementById('pain-feature');
        if (section) {
          const obs = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                if (!ticker) ticker = setInterval(tick, 100);
              } else {
                clearInterval(ticker);
                ticker = undefined as any;
              }
            });
          }, { threshold: 0.3 });
          obs.observe(section);
        } else {
          ticker = setInterval(tick, 100);
        }
      })();
    </script>

